[
  {"word":"term","level":"middle","meaning":"용어, 기간, 학기","pronunciation":"/tɜːrm/","parts":[{"type":"root","text":"term","meaning":"끝, 한계 (end)"}],"story":"어떤 의미나 시간의 '한계(term)'를 지어 놓은 것.","example":{"en":"A medical term.","ko":"의학 용어."}},
