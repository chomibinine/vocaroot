[
  {"word":"elevate","level":"high","meaning":"올리다, 승진시키다","pronunciation":"/ˈelɪveɪt/","parts":[{"type":"prefix","text":"e(x)-","meaning":"밖으로, 위로 (out)"},{"type":"root","text":"lev","meaning":"가벼운, 들어 올리다 (light)"},{"type":"suffix","text":"-ate","meaning":"동사형"}],"story":"물건이나 사람의 지위를 '위쪽으로(e)' '들어 올리다(lev)' → 높이다, 승진시키다.","example":{"en":"Elevate your feet.","ko":"발을 (위로) 올려라."}},
  {"word":"elevator","level":"middle","meaning":"엘리베이터, 승강기","pronunciation":"/ˈelɪveɪtər/","parts":[{"type":"root","text":"elevate","meaning":"올리다"},{"type":"suffix","text":"-or","meaning":"기계"}],"story":"사람이나 짐을 층 위로 '들어 올려주는(elevate)' '기계(or)' → 엘리베이터.","example":{"en":"Take the elevator.","ko":"엘리베이터를 타다."}},
  {"word":"relieve","level":"middle","meaning":"(고통을) 덜어주다, 안도하게 하다","pronunciation":"/rɪˈliːv/","parts":[{"type":"prefix","text":"re-","meaning":"다시, 뒤로 (back)"},{"type":"root","text":"lieve(lev)","meaning":"가벼운 (light)"}],"story":"마음을 짓누르던 걱정이나 고통을 덜어내어 '다시(re)' '가볍게(lieve)' 만들다.","example":{"en":"Relieve stress.","ko":"스트레스를 덜어주다."}},
  {"word":"relief","level":"middle","meaning":"안도, 구호(품)","pronunciation":"/rɪˈliːf/","parts":[{"type":"root","text":"relieve","meaning":"덜어주다의 명사형"}],"story":"재난이나 걱정으로부터 마음이 '가벼워진' 상태. 또는 고통을 덜어주는 '구호품'.","example":{"en":"A sigh of relief.","ko":"안도의 한숨."}},
  {"word":"lever","level":"middle","meaning":"지레, 레버, 수단","pronunciation":"/ˈlevər/","parts":[{"type":"root","text":"lev","meaning":"들어 올리다 (raise)"},{"type":"suffix","text":"-er","meaning":"도구"}],"story":"작은 힘으로 무거운 것을 쉽게 '들어 올릴(lev)' 수 있게 해주는 '도구(er)' → 지렛대.","example":{"en":"Pull the lever.","ko":"레버를 당기다."}},
  {"word":"command","level":"middle","meaning":"명령하다, 지휘하다","pronunciation":"/kəˈmænd/","parts":[{"type":"prefix","text":"com-","meaning":"강조, 완전히"},{"type":"root","text":"mand","meaning":"명령하다, 맡기다 (order)"}],"story":"윗사람이 아랫사람에게 권위를 가지고 강하게 '명령하다(mand)'.","example":{"en":"Give a command.","ko":"명령을 내리다."}},
  {"word":"demand","level":"middle","meaning":"요구하다, 수요","pronunciation":"/dɪˈmænd/","parts":[{"type":"prefix","text":"de-","meaning":"아래로, 강력하게"},{"type":"root","text":"mand","meaning":"명령하다 (order)"}],"story":"자신의 권리나 물건을 내놓으라고 '강력하게(de)' '명령하듯 요구하다(mand)'.","example":{"en":"Supply and demand.","ko":"공급과 수요."}},
  {"word":"recommend","level":"middle","meaning":"추천하다","pronunciation":"/ˌrekəˈmend/","parts":[{"type":"prefix","text":"re-","meaning":"다시, 거듭"},{"type":"prefix","text":"com-","meaning":"강조"},{"type":"root","text":"mend","meaning":"맡기다 (entrust)"}],"story":"이 사람이 훌륭하다고 '거듭(re)' 강조하며 일을 '맡기라고(mend)' 말하다 → 추천하다.","example":{"en":"I recommend this book.","ko":"나는 이 책을 추천한다."}},
  {"word":"mandatory","level":"high","meaning":"의무적인, 강제의","pronunciation":"/ˈmændətɔːri/","parts":[{"type":"root","text":"mand","meaning":"명령하다 (order)"},{"type":"suffix","text":"-atory","meaning":"형용사형"}],"story":"법이나 규정으로 '명령하여(mand)' 무조건 따라야만 하는 → 의무적인.","example":{"en":"Attendance is mandatory.","ko":"참석은 의무적이다."}},
  {"word":"commend","level":"high","meaning":"칭찬하다, 추천하다","pronunciation":"/kəˈmend/","parts":[{"type":"prefix","text":"com-","meaning":"강조"},{"type":"root","text":"mend","meaning":"맡기다 (entrust)"}],"story":"그 사람을 믿고 일을 '맡겨도(mend)' 될 만큼 훌륭하다고 좋게 말하다 → 칭찬하다.","example":{"en":"Commend his bravery.","ko":"그의 용기를 칭찬하다."}},
  {"word":"migrate","level":"high","meaning":"이동하다, 이주하다","pronunciation":"/ˈmaɪɡreɪt/","parts":[{"type":"root","text":"migr","meaning":"이동하다 (wander)"},{"type":"suffix","text":"-ate","meaning":"동사형"}],"story":"새들이 계절에 따라 살 곳을 찾아 무리 지어 '이동하다(migr)'.","example":{"en":"Birds migrate in winter.","ko":"새들은 겨울에 이동한다."}},
  {"word":"immigrate","level":"middle","meaning":"(다른 나라에서) 이민 오다","pronunciation":"/ˈɪmɪɡreɪt/","parts":[{"type":"prefix","text":"im(in)-","meaning":"안으로 (into)"},{"type":"root","text":"migr","meaning":"이동하다 (wander)"}],"story":"새로운 일자리나 삶을 찾아 우리나라 '안으로(im)' '이동해 오다(migr)'.","example":{"en":"Immigrate to America.","ko":"미국으로 이민 오다."}},
  {"word":"emigrate","level":"high","meaning":"(다른 나라로) 이민 가다","pronunciation":"/ˈemɪɡreɪt/","parts":[{"type":"prefix","text":"e(x)-","meaning":"밖으로 (out)"},{"type":"root","text":"migr","meaning":"이동하다 (wander)"}],"story":"자신이 살던 고국을 떠나 타국 '밖으로(e)' '이동해 가다(migr)'.","example":{"en":"Emigrate from Korea.","ko":"한국에서 이민을 떠나다."}},
  {"word":"immigrant","level":"middle","meaning":"이민자 (들어온 사람)","pronunciation":"/ˈɪmɪɡrənt/","parts":[{"type":"root","text":"immigrate","meaning":"이민 오다"},{"type":"suffix","text":"-ant","meaning":"사람"}],"story":"타국에서 우리나라로 '이민을 온(immigrate)' '사람(ant)'.","example":{"en":"An illegal immigrant.","ko":"불법 이민자."}},
  {"word":"migration","level":"high","meaning":"이주, 대이동","pronunciation":"/maɪˈɡreɪʃn/","parts":[{"type":"root","text":"migrate","meaning":"이동하다"},{"type":"suffix","text":"-ion","meaning":"명사형"}],"story":"사람이나 동물이 살 곳을 찾아 대규모로 '이동하는(migrate)' 현상.","example":{"en":"Mass migration.","ko":"대규모 이주."}},
  {"word":"mirror","level":"middle","meaning":"거울, 반영하다","pronunciation":"/ˈmɪrər/","parts":[{"type":"root","text":"mir","meaning":"놀라다, 보다 (wonder/look)"},{"type":"suffix","text":"-or","meaning":"사물"}],"story":"물에 비친 자신의 모습을 보고 '놀라서(mir)' 쳐다보게 만드는 물건 → 거울.","example":{"en":"Look in the mirror.","ko":"거울을 보다."}},
  {"word":"miracle","level":"middle","meaning":"기적","pronunciation":"/ˈmɪrəkl/","parts":[{"type":"root","text":"mir","meaning":"놀라다 (wonder)"},{"type":"suffix","text":"-acle","meaning":"명사형"}],"story":"상식적으로 불가능한 일이 일어나 사람들을 '놀라게(mir)' 만드는 일 → 기적.","example":{"en":"It's a miracle.","ko":"그것은 기적이다."}},
  {"word":"admire","level":"middle","meaning":"존경하다, 감탄하다","pronunciation":"/ədˈmaɪər/","parts":[{"type":"prefix","text":"ad-","meaning":"~쪽으로 (to)"},{"type":"root","text":"mir","meaning":"놀라다 (wonder)"}],"story":"누군가의 훌륭함을 보고 그를 향해(ad) '놀라움(mir)'을 금치 못하다 → 존경하다.","example":{"en":"I admire your courage.","ko":"나는 당신의 용기를 존경한다."}},
  {"word":"marvel","level":"high","meaning":"경이로움, 경탄하다","pronunciation":"/ˈmɑːrvl/","parts":[{"type":"root","text":"mar(mir)","meaning":"놀라다 (wonder)"}],"story":"너무나 훌륭하고 놀라워서 입을 다물지 못하고 '경탄하다(mar)'.","example":{"en":"Marvel at the sight.","ko":"그 광경에 경탄하다."}},
  {"word":"admirable","level":"high","meaning":"존경스러운, 감탄할 만한","pronunciation":"/ˈædmərəbl/","parts":[{"type":"root","text":"admire","meaning":"존경하다"},{"type":"suffix","text":"-able","meaning":"할 수 있는"}],"story":"훌륭한 업적을 남겨 충분히 '존경(admire)'받을 수 '있는(able)'.","example":{"en":"An admirable achievement.","ko":"감탄할 만한 업적."}},
  {"word":"note","level":"middle","meaning":"메모, 지폐, 주목하다","pronunciation":"/noʊt/","parts":[{"type":"root","text":"not","meaning":"표시하다 (mark)"}],"story":"잊지 않기 위해 글씨로 '표시해(not)' 두는 것 → 메모, 필기.","example":{"en":"Take a note.","ko":"메모를 하다."}},
  {"word":"notice","level":"middle","meaning":"알아차리다, 공지","pronunciation":"/ˈnoʊtɪs/","parts":[{"type":"root","text":"not","meaning":"표시하다 (mark)"},{"type":"suffix","text":"-ice","meaning":"명사/동사형"}],"story":"눈에 띄게 '표시(not)'를 해두어 사람들이 보게 만들다 → 공지, 알아차리다.","example":{"en":"Did you notice that?","ko":"너 그거 알아차렸어?"}},
  {"word":"notify","level":"high","meaning":"알리다, 통지하다","pronunciation":"/ˈnoʊtɪfaɪ/","parts":[{"type":"root","text":"not","meaning":"표시하다 (mark)"},{"type":"suffix","text":"-ify","meaning":"만들다"}],"story":"문서에 '표시(not)'하여 상대방이 사실을 알게 '만들다(ify)' → 통지하다.","example":{"en":"Notify the police.","ko":"경찰에 알리다."}},
  {"word":"notion","level":"high","meaning":"개념, 관념","pronunciation":"/ˈnoʊʃn/","parts":[{"type":"root","text":"not","meaning":"표시하다, 알다"},{"type":"suffix","text":"-ion","meaning":"명사형"}],"story":"머릿속에 특징을 '표시하여(not)' 저장해 둔 생각의 덩어리 → 개념.","example":{"en":"A vague notion.","ko":"모호한 개념."}},
  {"word":"notable","level":"high","meaning":"주목할 만한, 유명한","pronunciation":"/ˈnoʊtəbl/","parts":[{"type":"root","text":"not","meaning":"표시하다"},{"type":"suffix","text":"-able","meaning":"할 수 있는"}],"story":"형광펜으로 '표시를 해(not)' 둘 수 '있을(able)' 만큼 중요하고 유명한.","example":{"en":"A notable success.","ko":"주목할 만한 성공."}},
  {"word":"nurse","level":"middle","meaning":"간호사, 돌보다","pronunciation":"/nɜːrs/","parts":[{"type":"root","text":"nurs","meaning":"기르다, 젖을 먹이다 (nourish)"}],"story":"과거 아이에게 젖을 물려 '기르던(nurs)' 유모에서 유래 → 아픈 사람을 돌보는 간호사.","example":{"en":"Work as a nurse.","ko":"간호사로 일하다."}},
  {"word":"nursery","level":"middle","meaning":"보육원, 탁아소","pronunciation":"/ˈnɜːrsəri/","parts":[{"type":"root","text":"nurs","meaning":"기르다 (nourish)"},{"type":"suffix","text":"-ery","meaning":"장소"}],"story":"어린아이들을 밥을 먹이고 '기르는(nurs)' '장소(ery)' → 보육원.","example":{"en":"A day nursery.","ko":"주간 탁아소."}},
  {"word":"nourish","level":"high","meaning":"영양분을 주다, 기르다","pronunciation":"/ˈnɜːrɪʃ/","parts":[{"type":"root","text":"nour(nurs)","meaning":"기르다 (nourish)"},{"type":"suffix","text":"-ish","meaning":"동사형"}],"story":"아이와 식물이 잘 자라도록 음식과 '영양분을 주다(nour)' → 기르다.","example":{"en":"Nourish the skin.","ko":"피부에 영양을 공급하다."}},
  {"word":"nutrition","level":"high","meaning":"영양, 영양 섭취","pronunciation":"/nuˈtrɪʃn/","parts":[{"type":"root","text":"nutri","meaning":"영양, 기르다 (nourish)"},{"type":"suffix","text":"-ion","meaning":"명사형"}],"story":"생명체가 먹이를 통해 건강을 '기르는(nutri)' 과정과 그 물질 → 영양.","example":{"en":"Good nutrition.","ko":"좋은 영양."}},
  {"word":"nutrient","level":"high","meaning":"영양소, 영양분","pronunciation":"/ˈnuːtriənt/","parts":[{"type":"root","text":"nutri","meaning":"기르다 (nourish)"},{"type":"suffix","text":"-ent","meaning":"물질"}],"story":"몸을 튼튼하게 '길러주는(nutri)' 화학 '물질(ent)' → 영양소.","example":{"en":"Essential nutrients.","ko":"필수 영양소."}},
  {"word":"order","level":"middle","meaning":"명령, 순서, 질서, 주문하다","pronunciation":"/ˈɔːrdər/","parts":[{"type":"root","text":"ord","meaning":"순서 (order)"}],"story":"물건을 규칙적인 '순서(ord)'에 맞게 정리함 → 질서. 윗사람이 정한 순서대로 하라고 지시함 → 명령.","example":{"en":"Out of order.","ko":"고장난 (질서에서 벗어난)."}},
  {"word":"ordinary","level":"middle","meaning":"평범한, 보통의","pronunciation":"/ˈɔːrdneri/","parts":[{"type":"root","text":"ordin","meaning":"순서, 질서"},{"type":"suffix","text":"-ary","meaning":"형용사형"}],"story":"항상 정해진 '순서(ordin)'와 일상적인 궤도에 따라 굴러가는 → 평범한.","example":{"en":"An ordinary person.","ko":"평범한 사람."}},
  {"word":"extraordinary","level":"high","meaning":"비범한, 기이한","pronunciation":"/ɪkˈstrɔːrdəneri/","parts":[{"type":"prefix","text":"extra-","meaning":"벗어난 (outside)"},{"type":"root","text":"ordinary","meaning":"평범한"}],"story":"'평범한(ordinary)' 수준을 훌쩍 '벗어나(extra)' 뛰어난 → 비범한.","example":{"en":"Extraordinary ability.","ko":"비범한 능력."}},
  {"word":"coordinate","level":"high","meaning":"조정하다, 협력하게 하다","pronunciation":"/koʊˈɔːrdɪneɪt/","parts":[{"type":"prefix","text":"co-","meaning":"함께 (together)"},{"type":"root","text":"ordin","meaning":"순서 (order)"},{"type":"suffix","text":"-ate","meaning":"동사형"}],"story":"여러 팀을 '함께(co)' 묶어 일의 '순서(ordin)'를 맞추어 주다 → 조정하다.","example":{"en":"Coordinate the event.","ko":"행사를 조정(진행)하다."}},
  {"word":"subordinate","level":"high","meaning":"종속된, 부하","pronunciation":"/səˈbɔːrdɪnət/","parts":[{"type":"prefix","text":"sub-","meaning":"아래에 (under)"},{"type":"root","text":"ordin","meaning":"순서, 직급"},{"type":"suffix","text":"-ate","meaning":"형용사/명사형"}],"story":"조직 내에서 '순서나 직급(ordin)'이 내 '아래에(sub)' 있는 사람 → 부하.","example":{"en":"A subordinate officer.","ko":"부하 장교."}},
  {"word":"origin","level":"middle","meaning":"기원, 출신","pronunciation":"/ˈɔːrɪdʒɪn/","parts":[{"type":"root","text":"ori","meaning":"오르다, 시작하다 (rise)"}],"story":"태양이 처음 떠'오르며(ori)' 하루가 시작되듯, 사물이 '시작된' 곳 → 기원.","example":{"en":"The origin of life.","ko":"생명의 기원."}},
  {"word":"original","level":"middle","meaning":"원래의, 독창적인","pronunciation":"/əˈrɪdʒənl/","parts":[{"type":"root","text":"origin","meaning":"기원"},{"type":"suffix","text":"-al","meaning":"형용사형"}],"story":"사본이 아닌 '처음 시작될(origin)' 때 만들어진 진짜의 → 원래의, 독창적인.","example":{"en":"An original idea.","ko":"독창적인 아이디어."}},
  {"word":"originate","level":"high","meaning":"비롯되다, 유래하다","pronunciation":"/əˈrɪdʒɪneɪt/","parts":[{"type":"root","text":"origin","meaning":"기원"},{"type":"suffix","text":"-ate","meaning":"동사형"}],"story":"어떤 장소나 상황에서 처음으로 '시작되다(origin)'.","example":{"en":"The disease originated in birds.","ko":"그 질병은 새에서 유래했다."}},
  {"word":"orient","level":"high","meaning":"동양, 지향하게 하다","pronunciation":"/ˈɔːrient/","parts":[{"type":"root","text":"ori","meaning":"오르다 (rise)"}],"story":"태양이 '떠오르는(ori)' 방향인 동쪽 → 동양. 동쪽을 기준으로 방향을 잡다 → 지향하게 하다.","example":{"en":"Orient yourself.","ko":"자신의 방향(위치)을 파악하다."}},
  {"word":"oriental","level":"high","meaning":"동양의, 동양적인","pronunciation":"/ˌɔːriˈentl/","parts":[{"type":"root","text":"orient","meaning":"동양"},{"type":"suffix","text":"-al","meaning":"형용사형"}],"story":"태양이 떠오르는 지역인 '동양(orient)'의 문화와 관련된.","example":{"en":"Oriental medicine.","ko":"한의학 (동양 의학)."}},
  {"word":"private","level":"middle","meaning":"사적인, 개인의","pronunciation":"/ˈpraɪvət/","parts":[{"type":"root","text":"priv","meaning":"떼어놓은, 개별적인 (separate)"},{"type":"suffix","text":"-ate","meaning":"형용사형"}],"story":"공공의 것에서 '떼어내어(priv)' 한 개인만 쓰게 한 → 사적인.","example":{"en":"A private school.","ko":"사립 학교."}},
  {"word":"privacy","level":"middle","meaning":"사생활","pronunciation":"/ˈpraɪvəsi/","parts":[{"type":"root","text":"priv","meaning":"개별적인"},{"type":"suffix","text":"-acy","meaning":"명사형"}],"story":"남들에게 공개되지 않고 혼자 '떼어져(priv)' 있는 사적인 상태 → 사생활.","example":{"en":"Invasion of privacy.","ko":"사생활 침해."}},
  {"word":"deprive","level":"high","meaning":"빼앗다, 박탈하다","pronunciation":"/dɪˈpraɪv/","parts":[{"type":"prefix","text":"de-","meaning":"완전히 (completely)"},{"type":"root","text":"prive(priv)","meaning":"떼어놓다 (separate)"}],"story":"어떤 사람이 가진 권리나 물건을 '완전히(de)' '떼어내어(prive)' 가져가다 → 박탈하다.","example":{"en":"Deprive him of his rights.","ko":"그의 권리를 박탈하다."}},
  {"word":"privation","level":"high","meaning":"궁핍, 박탈","pronunciation":"/praɪˈveɪʃn/","parts":[{"type":"root","text":"priv","meaning":"빼앗다, 떼어놓다"},{"type":"suffix","text":"-ation","meaning":"명사형"}],"story":"살아가는 데 필요한 돈이나 식량을 '빼앗겨서(priv)' 가지지 못한 상태 → 궁핍.","example":{"en":"Suffer from privation.","ko":"궁핍에 시달리다."}},
  {"word":"privilege","level":"high","meaning":"특권 (이전에 다룸 - 심화 복습)","pronunciation":"/ˈprɪvəlɪdʒ/","parts":[{"type":"root","text":"privi","meaning":"개별적인 (private)"},{"type":"root","text":"lege","meaning":"법 (law)"}],"story":"특정 '개인(priv)'만을 위해 특별히 적용되는 혜택과 '법(lege)' → 특권.","example":{"en":"A special privilege.","ko":"특별한 특권."}},
  {"word":"prove","level":"middle","meaning":"증명하다, 판명되다","pronunciation":"/pruːv/","parts":[{"type":"root","text":"prove(prob)","meaning":"시험하다, 좋은 (test/good)"}],"story":"그것이 '좋은지(prove)' 아니면 가짜인지 직접 시험하여 보여주다 → 증명하다.","example":{"en":"Prove your innocence.","ko":"너의 결백을 증명해라."}},
  {"word":"approve","level":"middle","meaning":"찬성하다, 승인하다","pronunciation":"/əˈpruːv/","parts":[{"type":"prefix","text":"ap(ad)-","meaning":"~쪽으로 (to)"},{"type":"root","text":"prove","meaning":"좋은 (good)"}],"story":"어떤 계획을 보고 그것이 '좋다(prove)'고 고개를 끄덕여 주다 → 찬성하다.","example":{"en":"Approve a plan.","ko":"계획을 승인하다."}},
  {"word":"probability","level":"high","meaning":"확률, 개연성","pronunciation":"/ˌprɑːbəˈbɪləti/","parts":[{"type":"root","text":"prob","meaning":"시험하다 (test)"},{"type":"suffix","text":"-ability","meaning":"가능성"}],"story":"'시험해(prob)' 보았을 때 그 결과가 진실로 일어날 '가능성(ability)' → 확률.","example":{"en":"A high probability.","ko":"높은 확률."}},
  {"word":"probable","level":"high","meaning":"그럴듯한, 유력한","pronunciation":"/ˈprɑːbəbl/","parts":[{"type":"root","text":"prob","meaning":"시험하다"},{"type":"suffix","text":"-able","meaning":"할 수 있는"}],"story":"사실인지 '시험해(prob)' 볼 수 '있을(able)' 만큼 가능성이 높은 → 그럴듯한.","example":{"en":"The probable cause.","ko":"유력한 원인."}},
  {"word":"probe","level":"high","meaning":"조사하다, 우주 탐사선","pronunciation":"/proʊb/","parts":[{"type":"root","text":"probe(prob)","meaning":"시험하다 (test)"}],"story":"진실을 찾기 위해 우주나 깊은 곳을 찌르며 '시험하고(probe)' 조사하는 기구 → 탐사선.","example":{"en":"A space probe.","ko":"우주 탐사선."}},
  {"word":"doctor","level":"middle","meaning":"의사, 박사","pronunciation":"/ˈdɑːktər/","parts":[{"type":"root","text":"doct","meaning":"가르치다 (teach)"},{"type":"suffix","text":"-or","meaning":"사람"}],"story":"과거에는 의학이나 신학을 전문적으로 '가르칠(doct)' 만큼 학식이 뛰어난 '사람(or)'을 뜻함 → 박사, 의사.","example":{"en":"See a doctor.","ko":"진찰을 받다."}},
  {"word":"document","level":"middle","meaning":"문서, 기록하다","pronunciation":"/ˈdɑːkjumənt/","parts":[{"type":"root","text":"docu","meaning":"가르치다 (teach)"},{"type":"suffix","text":"-ment","meaning":"결과물"}],"story":"후대 사람들을 '가르치기(docu)' 위해 지식을 적어놓은 결과물 → 문서.","example":{"en":"A legal document.","ko":"법적 문서."}},
  {"word":"docile","level":"high","meaning":"유순한, 다루기 쉬운","pronunciation":"/ˈdɑːsl/","parts":[{"type":"root","text":"doc","meaning":"가르치다 (teach)"},{"type":"suffix","text":"-ile","meaning":"~하기 쉬운"}],"story":"말귀를 잘 알아들어 '가르치기(doc)'가 매우 '쉬운(ile)' 성격의 → 유순한.","example":{"en":"A docile pet.","ko":"온순한 애완동물."}},
  {"word":"doctrine","level":"high","meaning":"교리, 신조","pronunciation":"/ˈdɑːktrɪn/","parts":[{"type":"root","text":"doctr","meaning":"가르치다 (teach)"},{"type":"suffix","text":"-ine","meaning":"명사형"}],"story":"종교 집단이나 국가가 사람들에게 이것이 진리라고 굳게 '가르치는(doctr)' 원칙 → 교리.","example":{"en":"The Truman Doctrine.","ko":"트루먼 독트린."}},
