[
  {"word":"remain","level":"middle","meaning":"남다, 머무르다","pronunciation":"/rɪˈmeɪn/","parts":[{"type":"prefix","text":"re-","meaning":"뒤에, 계속 (back)"},{"type":"root","text":"main","meaning":"머무르다 (stay)"}],"story":"다른 것들이 다 떠나도 '계속해서(re)' 그 자리에 '머무르다(main)'.","example":{"en":"Remain silent.","ko":"침묵을 지키다 (조용히 남아있다)."}},
  {"word":"remainder","level":"middle","meaning":"나머지","pronunciation":"/rɪˈmeɪndər/","parts":[{"type":"root","text":"remain","meaning":"남다"},{"type":"suffix","text":"-der","meaning":"명사형"}],"story":"쓰고 남아서 계속 그 자리에 '머물러 있는(remain)' 것 → 나머지.","example":{"en":"The remainder of the day.","ko":"그날의 남은 시간."}},
  {"word":"permanent","level":"middle","meaning":"영구적인, 영원한","pronunciation":"/ˈpɜːrmənənt/","parts":[{"type":"prefix","text":"per-","meaning":"끝까지, 완전히 (through)"},{"type":"root","text":"man","meaning":"머무르다 (stay)"},{"type":"suffix","text":"-ent","meaning":"형용사형"}],"story":"시간이 지나도 '끝까지(per)' 그 상태로 '머무르는(man)' → 영구적인.","example":{"en":"A permanent job.","ko":"영구적인 직업 (정규직)."}},
  {"word":"mansion","level":"middle","meaning":"대저택","pronunciation":"/ˈmænʃn/","parts":[{"type":"root","text":"man","meaning":"머무르다 (stay)"},{"type":"suffix","text":"-sion","meaning":"장소"}],"story":"영주나 귀족이 크고 웅장하게 지어놓고 '머무르는(man)' 장소 → 대저택.","example":{"en":"Live in a mansion.","ko":"대저택에 살다."}},
  {"word":"manor","level":"high","meaning":"영지, 장원","pronunciation":"/ˈmænər/","parts":[{"type":"root","text":"man","meaning":"머무르다 (stay)"},{"type":"suffix","text":"-or","meaning":"장소"}],"story":"중세 시대 영주가 '머무르며(man)' 다스리던 거대한 토지와 저택.","example":{"en":"The lord of the manor.","ko":"장원의 영주."}},
  {"word":"common","level":"middle","meaning":"흔한, 공통의","pronunciation":"/ˈkɑːmən/","parts":[{"type":"prefix","text":"com-","meaning":"함께 (together)"},{"type":"root","text":"mon(mun)","meaning":"의무, 선물 (duty)"}],"story":"사회의 구성원들이 '함께(com)' 나누어 갖는 '의무나 선물(mon)' → 공통의, 흔한.","example":{"en":"A common goal.","ko":"공통의 목표."}},
  {"word":"uncommon","level":"middle","meaning":"드문, 흔치 않은","pronunciation":"/ʌnˈkɑːmən/","parts":[{"type":"prefix","text":"un-","meaning":"아닌 (not)"},{"type":"root","text":"common","meaning":"흔한"}],"story":"누구나 다 가지고 있는 '공통적인(common)' 것이 '아닌(un)' → 흔치 않은.","example":{"en":"An uncommon bird.","ko":"흔치 않은 새."}},
  {"word":"communicate","level":"middle","meaning":"의사소통하다, 전달하다","pronunciation":"/kəˈmjuːnɪkeɪt/","parts":[{"type":"root","text":"commun(common)","meaning":"공통의"},{"type":"suffix","text":"-icate","meaning":"만들다"}],"story":"내 생각과 네 생각을 '공통된(commun)' 것으로 '만들다(icate)' → 의사소통하다.","example":{"en":"Communicate with others.","ko":"다른 사람들과 소통하다."}},
  {"word":"community","level":"middle","meaning":"지역사회, 공동체","pronunciation":"/kəˈmjuːnəti/","parts":[{"type":"root","text":"commun","meaning":"공통의"},{"type":"suffix","text":"-ity","meaning":"명사형"}],"story":"의무와 생활을 '공통으로(commun)' 나누는 사람들의 집단 → 공동체.","example":{"en":"The local community.","ko":"지역 사회."}},
  {"word":"immune","level":"high","meaning":"면역의, 면제된","pronunciation":"/ɪˈmjuːn/","parts":[{"type":"prefix","text":"im(in)-","meaning":"없는 (not)"},{"type":"root","text":"mune(mun)","meaning":"의무 (duty)"}],"story":"세금을 내야 할 '의무(mune)'가 '없는(im)'. 질병의 영향을 받지 않는 → 면역의.","example":{"en":"The immune system.","ko":"면역 체계."}},
  {"word":"prepare","level":"middle","meaning":"준비하다","pronunciation":"/prɪˈper/","parts":[{"type":"prefix","text":"pre-","meaning":"미리 (before)"},{"type":"root","text":"pare","meaning":"준비하다 (ready)"}],"story":"어떤 일이 일어나기 '전에(pre)' 미리 '준비하여(pare)' 갖추다.","example":{"en":"Prepare for the exam.","ko":"시험을 준비하다."}},
  {"word":"preparation","level":"middle","meaning":"준비, 대비","pronunciation":"/ˌprepəˈreɪʃn/","parts":[{"type":"root","text":"prepare","meaning":"준비하다"},{"type":"suffix","text":"-ation","meaning":"명사형"}],"story":"미리 갖추어 놓고 대기하는 행동이나 상태 → 준비.","example":{"en":"In preparation for winter.","ko":"겨울에 대비하여."}},
  {"word":"repair","level":"middle","meaning":"수리하다, 고치다","pronunciation":"/rɪˈper/","parts":[{"type":"prefix","text":"re-","meaning":"다시 (again)"},{"type":"root","text":"pair(pare)","meaning":"준비하다 (ready)"}],"story":"망가진 것을 '다시(re)' 쓸 수 있게 '준비시키다(pair)' → 고치다.","example":{"en":"Repair a broken car.","ko":"고장난 차를 고치다."}},
  {"word":"apparatus","level":"high","meaning":"기구, 장치, 기관","pronunciation":"/ˌæpəˈrætəs/","parts":[{"type":"prefix","text":"ap(ad)-","meaning":"~을 위해 (for)"},{"type":"root","text":"para","meaning":"준비하다 (ready)"},{"type":"suffix","text":"-tus","meaning":"사물"}],"story":"특정 목적을 위해 미리 '준비해(para)' 놓은 도구 세트나 장치.","example":{"en":"Breathing apparatus.","ko":"호흡 기구."}},
  {"word":"separate","level":"middle","meaning":"분리하다, 떨어진","pronunciation":"/ˈsepəreɪt/","parts":[{"type":"prefix","text":"se-","meaning":"떨어져서 (apart)"},{"type":"root","text":"par","meaning":"준비하다, 마련하다"},{"type":"suffix","text":"-ate","meaning":"동사/형용사형"}],"story":"함께 있던 것을 '떨어뜨려(se)' 각자 자기 자리를 '마련하다(par)' → 분리하다.","example":{"en":"Separate the trash.","ko":"쓰레기를 분리하다."}},
  {"word":"penalty","level":"middle","meaning":"형벌, 벌금","pronunciation":"/ˈpenəlti/","parts":[{"type":"root","text":"pen","meaning":"벌 (punish)"},{"type":"suffix","text":"-alty","meaning":"명사형"}],"story":"규칙을 어겼을 때 주어지는 '벌(pen)'이나 불이익 → 형벌, 벌금.","example":{"en":"Pay a penalty.","ko":"벌금을 내다."}},
  {"word":"penalize","level":"high","meaning":"벌을 주다, 불리하게 하다","pronunciation":"/ˈpiːnəlaɪz/","parts":[{"type":"root","text":"penal","meaning":"벌의 (punish)"},{"type":"suffix","text":"-ize","meaning":"동사형"}],"story":"잘못에 대해 공식적으로 '벌을(penal)' '주다(ize)'.","example":{"en":"Penalize late payments.","ko":"지각 납부에 벌금을 물리다."}},
  {"word":"punish","level":"middle","meaning":"처벌하다","pronunciation":"/ˈpʌnɪʃ/","parts":[{"type":"root","text":"pun","meaning":"벌 (punish)"},{"type":"suffix","text":"-ish","meaning":"동사형"}],"story":"잘못된 행동에 대해 육체적/정신적인 '벌을(pun)' 가하다.","example":{"en":"Punish a crime.","ko":"범죄를 처벌하다."}},
  {"word":"punishment","level":"middle","meaning":"처벌, 형벌","pronunciation":"/ˈpʌnɪʃmənt/","parts":[{"type":"root","text":"punish","meaning":"처벌하다"},{"type":"suffix","text":"-ment","meaning":"명사형"}],"story":"잘못을 저지른 대가로 받는 고통이나 벌.","example":{"en":"Capital punishment.","ko":"사형 (최고 형벌)."}},
  {"word":"repent","level":"high","meaning":"후회하다, 뉘우치다","pronunciation":"/rɪˈpent/","parts":[{"type":"prefix","text":"re-","meaning":"다시, 몹시"},{"type":"root","text":"pent(pen)","meaning":"벌 (punish)"}],"story":"과거의 잘못 때문에 마음속으로 몹시 스스로에게 '벌을 주다(pent)' → 후회하다.","example":{"en":"Repent of one's sins.","ko":"자신의 죄를 뉘우치다."}},
  {"word":"price","level":"middle","meaning":"가격, 대가","pronunciation":"/praɪs/","parts":[{"type":"root","text":"price(preci)","meaning":"가치 (value)"}],"story":"물건이 지니고 있는 '가치(price)'를 돈으로 매긴 것 → 가격.","example":{"en":"A high price.","ko":"높은 가격."}},
  {"word":"precious","level":"middle","meaning":"귀중한, 값비싼","pronunciation":"/ˈpreʃəs/","parts":[{"type":"root","text":"preci","meaning":"가치 (value)"},{"type":"suffix","text":"-ous","meaning":"가득한"}],"story":"매길 수 없을 만큼 '가치(preci)'가 '가득한(ous)' → 귀중한.","example":{"en":"A precious stone.","ko":"보석 (귀중한 돌)."}},
  {"word":"appreciate","level":"middle","meaning":"감사하다, 진가를 알아보다","pronunciation":"/əˈpriːʃieɪt/","parts":[{"type":"prefix","text":"ap(ad)-","meaning":"~에게 (to)"},{"type":"root","text":"preci","meaning":"가치 (value)"},{"type":"suffix","text":"-ate","meaning":"동사형"}],"story":"그 사물이나 행동이 가진 진짜 '가치(preci)'를 제대로 알아보고 인정해주다 → 감사하다, 높이 평가하다.","example":{"en":"I appreciate your help.","ko":"당신의 도움에 감사드립니다."}},
  {"word":"depreciate","level":"high","meaning":"가치가 떨어지다, 평가절하하다","pronunciation":"/dɪˈpriːʃieɪt/","parts":[{"type":"prefix","text":"de-","meaning":"아래로, 떨어뜨려 (down)"},{"type":"root","text":"preci","meaning":"가치 (value)"},{"type":"suffix","text":"-ate","meaning":"동사형"}],"story":"물건이나 돈의 '가치(preci)'를 원래보다 '아래로(de)' 깎아내리다 → 가치가 떨어지다.","example":{"en":"Cars depreciate in value.","ko":"자동차는 가치가 떨어진다."}},
  {"word":"praise","level":"middle","meaning":"칭찬하다, 칭송","pronunciation":"/preɪz/","parts":[{"type":"root","text":"prais(preci)","meaning":"가치 (value)"}],"story":"그 사람의 '가치(prais)'를 높게 평가하며 훌륭하다고 말해주다 → 칭찬하다.","example":{"en":"Praise a child.","ko":"아이를 칭찬하다."}},
  {"word":"rotate","level":"middle","meaning":"회전하다, 교대하다","pronunciation":"/ˈroʊteɪt/","parts":[{"type":"root","text":"rot","meaning":"바퀴, 구르다 (wheel)"},{"type":"suffix","text":"-ate","meaning":"동사형"}],"story":"바퀴가 축을 중심으로 둥글게 '구르다(rot)' → 회전하다.","example":{"en":"Rotate the tires.","ko":"타이어를 교체(회전)하다."}},
  {"word":"rotation","level":"middle","meaning":"회전, 자전, 교대","pronunciation":"/roʊˈteɪʃn/","parts":[{"type":"root","text":"rotate","meaning":"회전하다"},{"type":"suffix","text":"-ion","meaning":"명사형"}],"story":"바퀴가 둥글게 돌아가는 현상이나 순서가 돌아가는 것 → 회전, 교대.","example":{"en":"Earth's rotation.","ko":"지구의 자전."}},
  {"word":"rotary","level":"high","meaning":"회전하는, 로터리 (교차로)","pronunciation":"/ˈroʊtəri/","parts":[{"type":"root","text":"rot","meaning":"구르다"},{"type":"suffix","text":"-ary","meaning":"형용사/사물"}],"story":"차들이 빙글빙글 '원형으로 도는(rot)' 길 → 로터리 교차로.","example":{"en":"A rotary engine.","ko":"회전 엔진."}},
  {"word":"enroll","level":"middle","meaning":"등록하다, 입학하다","pronunciation":"/ɪnˈroʊl/","parts":[{"type":"prefix","text":"en-","meaning":"안으로 (into)"},{"type":"root","text":"roll(rot)","meaning":"두루마리, 명부"}],"story":"이름을 둥글게 말아놓은 '명부(roll)' '안으로(en)' 집어넣다 → 등록하다.","example":{"en":"Enroll in a class.","ko":"수업에 등록하다."}},
  {"word":"scroll","level":"middle","meaning":"두루마리, 스크롤하다","pronunciation":"/skroʊl/","parts":[{"type":"root","text":"scroll(roll)","meaning":"둘둘 말다"}],"story":"둥글게 '말아(roll)' 놓은 종이. 화면을 위아래로 움직여서 보는 것 → 스크롤.","example":{"en":"Scroll down the page.","ko":"페이지를 아래로 스크롤하다."}},
  {"word":"satisfy","level":"middle","meaning":"만족시키다, 충족시키다","pronunciation":"/ˈsætɪsfaɪ/","parts":[{"type":"root","text":"satis","meaning":"충분한 (enough)"},{"type":"suffix","text":"-fy","meaning":"만들다"}],"story":"사람의 욕구나 조건을 '충분하게(satis)' '만들어(fy)' 주다 → 만족시키다.","example":{"en":"Satisfy the customers.","ko":"고객들을 만족시키다."}},
  {"word":"satisfaction","level":"middle","meaning":"만족(감)","pronunciation":"/ˌsætɪsˈfækʃn/","parts":[{"type":"root","text":"satis","meaning":"충분한"},{"type":"root","text":"fact","meaning":"만들어진"},{"type":"suffix","text":"-ion","meaning":"명사형"}],"story":"욕구가 충분히 채워져서 마음이 흐뭇해진 상태.","example":{"en":"Customer satisfaction.","ko":"고객 만족."}},
  {"word":"satisfactory","level":"high","meaning":"만족스러운, 충분한","pronunciation":"/ˌsætɪsˈfæktəri/","parts":[{"type":"root","text":"satisfact(ion)","meaning":"만족"},{"type":"suffix","text":"-ory","meaning":"형용사형"}],"story":"기대나 요구를 충분히 채워주어 마음에 드는 → 만족스러운.","example":{"en":"A satisfactory result.","ko":"만족스러운 결과."}},
  {"word":"saturate","level":"high","meaning":"흠뻑 적시다, 포화시키다","pronunciation":"/ˈsætʃəreɪt/","parts":[{"type":"root","text":"satur(sat)","meaning":"충분한 (enough)"},{"type":"suffix","text":"-ate","meaning":"동사형"}],"story":"물이나 어떤 성분이 더 이상 들어갈 수 없을 만큼 '충분하게(satur)' 꽉 채우다 → 포화시키다.","example":{"en":"Saturate the market.","ko":"시장을 포화 상태로 만들다."}},
  {"word":"asset","level":"high","meaning":"자산, 재산","pronunciation":"/ˈæset/","parts":[{"type":"prefix","text":"as(ad)-","meaning":"충분히 (to)"},{"type":"root","text":"set(sat)","meaning":"충분한 (enough)"}],"story":"살아가기에 '충분할(sat)' 만큼 넉넉하게 모아둔 돈이나 가치 있는 것 → 자산.","example":{"en":"A valuable asset.","ko":"가치 있는 자산."}},
  {"word":"seminar","level":"middle","meaning":"세미나, 연구회","pronunciation":"/ˈsemɪnɑːr/","parts":[{"type":"root","text":"semin","meaning":"씨앗 (seed)"},{"type":"suffix","text":"-ar","meaning":"장소"}],"story":"지식의 '씨앗(semin)'을 뿌리고 사람들의 머릿속에서 생각을 기르는 모임 → 세미나.","example":{"en":"Attend a seminar.","ko":"세미나에 참석하다."}},
  {"word":"seminary","level":"high","meaning":"신학 대학, 사범학교","pronunciation":"/ˈsemɪneri/","parts":[{"type":"root","text":"semin","meaning":"씨앗 (seed)"},{"type":"suffix","text":"-ary","meaning":"장소"}],"story":"종교적 믿음이나 가르침의 '씨앗(semin)'을 밭에 뿌리듯 사람을 길러내는 학교.","example":{"en":"A Catholic seminary.","ko":"가톨릭 신학 대학."}},
  {"word":"seminal","level":"high","meaning":"중대한, 영항력이 큰","pronunciation":"/ˈsemɪnl/","parts":[{"type":"root","text":"semin","meaning":"씨앗 (seed)"},{"type":"suffix","text":"-al","meaning":"형용사형"}],"story":"새로운 사상이나 분야의 '씨앗(semin)'이 되어 이후에 엄청난 영향을 미친 → 중대한.","example":{"en":"A seminal work of art.","ko":"아주 중요한(씨앗이 된) 예술 작품."}},
  {"word":"disseminate","level":"high","meaning":"퍼뜨리다, 전파하다","pronunciation":"/dɪˈsemɪneɪt/","parts":[{"type":"prefix","text":"dis-","meaning":"널리 (apart)"},{"type":"root","text":"semin","meaning":"씨앗 (seed)"},{"type":"suffix","text":"-ate","meaning":"동사형"}],"story":"농부가 '씨앗(semin)'을 사방으로 '널리(dis)' 흩뿌리다 → 정보나 소문을 퍼뜨리다.","example":{"en":"Disseminate information.","ko":"정보를 널리 퍼뜨리다."}},
  {"word":"inseminate","level":"high","meaning":"수정시키다, 잉태시키다","pronunciation":"/ɪnˈsemɪneɪt/","parts":[{"type":"prefix","text":"in-","meaning":"안으로 (into)"},{"type":"root","text":"semin","meaning":"씨앗 (seed)"},{"type":"suffix","text":"-ate","meaning":"동사형"}],"story":"생명의 '씨앗(semin)'(정자)을 자궁 '안으로(in)' 집어넣다 → 인공 수정시키다.","example":{"en":"Artificially inseminated.","ko":"인공적으로 수정된."}},
  {"word":"sponsor","level":"middle","meaning":"후원자, 보증인","pronunciation":"/ˈspɑːnsər/","parts":[{"type":"root","text":"spons","meaning":"약속하다 (promise)"},{"type":"suffix","text":"-or","meaning":"사람"}],"story":"행사나 사람에게 돈을 대주겠다고 공식적으로 '약속한(spons)' '사람(or)' → 후원자.","example":{"en":"A corporate sponsor.","ko":"기업 후원자."}},
  {"word":"respond","level":"middle","meaning":"대답하다, 반응하다","pronunciation":"/rɪˈspɑːnd/","parts":[{"type":"prefix","text":"re-","meaning":"다시, 마주하여 (back)"},{"type":"root","text":"spond","meaning":"약속하다, 말하다"}],"story":"상대방이 한 말이나 자극에 '마주하여(re)' 내 의견을 '말하다(spond)' → 대답하다.","example":{"en":"Respond to a question.","ko":"질문에 대답하다."}},
  {"word":"response","level":"middle","meaning":"대답, 반응","pronunciation":"/rɪˈspɑːns/","parts":[{"type":"prefix","text":"re-","meaning":"다시, 마주하여"},{"type":"root","text":"sponse","meaning":"말하다"}],"story":"질문이나 자극에 마주하여 내뱉은 말이나 행동 → 대답, 반응.","example":{"en":"A positive response.","ko":"긍정적인 반응."}},
  {"word":"responsible","level":"middle","meaning":"책임감 있는, 책임이 있는","pronunciation":"/rɪˈspɑːnsəbl/","parts":[{"type":"root","text":"respons(e)","meaning":"대답, 반응"},{"type":"suffix","text":"-ible","meaning":"할 수 있는"}],"story":"어떤 일의 결과에 대해 제대로 '대답하고 반응(respons)'할 수 '있는(ible)' → 책임지는.","example":{"en":"Who is responsible?","ko":"누가 책임자인가?"}},
  {"word":"correspond","level":"high","meaning":"일치하다, 서신을 주고받다","pronunciation":"/ˌkɔːrəˈspɑːnd/","parts":[{"type":"prefix","text":"cor(com)-","meaning":"함께 (together)"},{"type":"prefix","text":"re-","meaning":"마주하여"},{"type":"root","text":"spond","meaning":"말하다"}],"story":"두 사람이 '함께(cor)' 마주 앉아 '대답을 맞추다(respond)' → 일치하다, 서로 편지를 주고받다.","example":{"en":"The facts correspond.","ko":"사실들이 일치한다."}},
  {"word":"sting","level":"middle","meaning":"찌르다, 쏘다, 쏘인 상처","pronunciation":"/stɪŋ/","parts":[{"type":"root","text":"sting","meaning":"뾰족한 것으로 찌르다"}],"story":"벌이나 가시 같은 뾰족한 것으로 따갑게 '찌르다'.","example":{"en":"A bee sting.","ko":"벌에 쏘인 상처."}},
  {"word":"instinct","level":"middle","meaning":"본능, 본성","pronunciation":"/ˈɪnstɪŋkt/","parts":[{"type":"prefix","text":"in-","meaning":"안에서 (in)"},{"type":"root","text":"stinct(sting)","meaning":"찌르다 (prick)"}],"story":"생명체의 몸 '안에서(in)' 무언가 하라고 자꾸 '찌르고(stinct)' 자극하는 힘 → 본능.","example":{"en":"Animal instinct.","ko":"동물의 본능."}},
  {"word":"distinct","level":"middle","meaning":"뚜렷한, 구별되는","pronunciation":"/dɪˈstɪŋkt/","parts":[{"type":"prefix","text":"dis-","meaning":"따로 (apart)"},{"type":"root","text":"stinct","meaning":"찌르다 (prick)"}],"story":"다른 것들과 섞이지 않게 '따로(dis)' 점을 '찍어(stinct)' 놓은 것처럼 확연히 눈에 띄는 → 뚜렷한.","example":{"en":"A distinct flavor.","ko":"뚜렷한(독특한) 맛."}},
  {"word":"distinguish","level":"high","meaning":"구별하다, 식별하다","pronunciation":"/dɪˈstɪŋɡwɪʃ/","parts":[{"type":"prefix","text":"dis-","meaning":"따로"},{"type":"root","text":"stingu","meaning":"찌르다, 점 찍다"},{"type":"suffix","text":"-ish","meaning":"동사형"}],"story":"이것과 저것이 다름을 알기 위해 '따로(dis)' 점을 '찍어서(stingu)' 알아보다 → 구별하다.","example":{"en":"Distinguish right from wrong.","ko":"옳고 그름을 구별하다."}},
  {"word":"extinguish","level":"high","meaning":"(불을) 끄다, 소멸시키다","pronunciation":"/ɪkˈstɪŋɡwɪʃ/","parts":[{"type":"prefix","text":"ex-","meaning":"밖으로 (out)"},{"type":"root","text":"stingu","meaning":"찌르다 (prick)"},{"type":"suffix","text":"-ish","meaning":"동사형"}],"story":"뜨거운 불씨를 꼬챙이로 '찔러서(stingu)' 쳐내어 '없애다(ex)' → 불을 끄다.","example":{"en":"Extinguish the fire.","ko":"불을 끄다."}}
