[
  {"word":"strict","level":"middle","meaning":"엄격한","pronunciation":"/strɪkt/","parts":[{"type":"root","text":"strict","meaning":"묶다 (draw tight)"}],"story":"규칙으로 사람들의 행동을 꽉 '묶어서(strict)' 제한하는 → 엄격한.","example":{"en":"A strict teacher.","ko":"엄격한 선생님."}},
  {"word":"restrict","level":"middle","meaning":"제한하다","pronunciation":"/rɪˈstrɪkt/","parts":[{"type":"prefix","text":"re-","meaning":"뒤로 (back)"},{"type":"root","text":"strict","meaning":"묶다 (draw tight)"}],"story":"어떤 선을 넘지 못하게 '뒤로(re)' 꽉 '묶어두다(strict)' → 제한하다.","example":{"en":"Restrict speed.","ko":"속도를 제한하다."}},
  {"word":"district","level":"middle","meaning":"구역","pronunciation":"/ˈdɪstrɪkt/","parts":[{"type":"prefix","text":"dis-","meaning":"따로 (apart)"},{"type":"root","text":"strict","meaning":"묶다 (draw tight)"}],"story":"관리를 편하게 하기 위해 '따로(dis)' 선을 그어 '묶어놓은(strict)' 곳.","example":{"en":"A business district.","ko":"상업 구역."}},
  {"word":"strain","level":"high","meaning":"부담, 긴장","pronunciation":"/streɪn/","parts":[{"type":"root","text":"strain","meaning":"팽팽하게 하다"}],"story":"근육이나 마음을 끊어질 듯 팽팽하게 '잡아당기다(strain)' → 긴장.","example":{"en":"Eye strain.","ko":"눈의 피로."}},
  {"word":"constrain","level":"high","meaning":"강제하다, 억제하다","pronunciation":"/kənˈstreɪn/","parts":[{"type":"prefix","text":"con-","meaning":"함께 (together)"},{"type":"root","text":"strain","meaning":"묶다 (draw tight)"}],"story":"두 손을 '함께(con)' 꽉 '묶다(strain)' → 강요하다.","example":{"en":"Constrained by budget.","ko":"예산에 의해 제약받다."}},
  {"word":"vacant","level":"middle","meaning":"비어 있는","pronunciation":"/ˈveɪkənt/","parts":[{"type":"root","text":"vac","meaning":"비어있는 (empty)"},{"type":"suffix","text":"-ant","meaning":"형용사형"}],"story":"어떤 공간이나 자리가 '텅 비어(vac)' 있는 상태.","example":{"en":"A vacant seat.","ko":"빈 자리."}},
  {"word":"vacuum","level":"middle","meaning":"진공, 청소기","pronunciation":"/ˈvækjuəm/","parts":[{"type":"root","text":"vac","meaning":"비어있는 (empty)"},{"type":"suffix","text":"-uum","meaning":"명사형"}],"story":"공기조차 없이 '텅 빈(vac)' 공간 → 진공.","example":{"en":"A vacuum cleaner.","ko":"진공 청소기."}},
  {"word":"evacuate","level":"high","meaning":"대피시키다","pronunciation":"/ɪˈvækjuːeɪt/","parts":[{"type":"prefix","text":"e-","meaning":"밖으로 (out)"},{"type":"root","text":"vacu","meaning":"비우다 (empty)"}],"story":"사람들을 '밖으로(e)' 빼내어 공간을 '비우다(vacu)' → 대피시키다.","example":{"en":"Evacuate the building.","ko":"건물에서 대피하다."}},
  {"word":"vanish","level":"high","meaning":"사라지다","pronunciation":"/ˈvænɪʃ/","parts":[{"type":"root","text":"van","meaning":"빈 (empty)"},{"type":"suffix","text":"-ish","meaning":"동사형"}],"story":"있던 자리가 연기처럼 '텅 비게(van)' 되다 → 사라지다.","example":{"en":"Vanish into thin air.","ko":"허공으로 사라지다."}},
  {"word":"vain","level":"high","meaning":"헛된","pronunciation":"/veɪn/","parts":[{"type":"root","text":"vain","meaning":"빈 (empty)"}],"story":"노력의 결과나 마음 속이 '텅 비어있는(vain)' → 헛수고의.","example":{"en":"In vain.","ko":"헛되이."}},
