[
  {"word":"art","level":"middle","meaning":"예술, 미술, 기술","pronunciation":"/ɑːrt/","parts":[{"type":"root","text":"art","meaning":"인공, 기술 (skill)"}],"story":"자연 그대로가 아니라 인간의 '기술(art)'이 들어가 만들어진 것 → 예술, 인공.","example":{"en":"Modern art.","ko":"현대 미술."}},
  {"word":"artist","level":"middle","meaning":"예술가, 화가","pronunciation":"/ˈɑːrtɪst/","parts":[{"type":"root","text":"art","meaning":"예술"},{"type":"suffix","text":"-ist","meaning":"사람"}],"story":"'예술(art)' 작품을 창조해 내는 '사람(ist)'.","example":{"en":"A famous artist.","ko":"유명한 예술가."}},
  {"word":"artificial","level":"middle","meaning":"인공의, 인조의","pronunciation":"/ˌɑːrtɪˈfɪʃl/","parts":[{"type":"root","text":"arti(art)","meaning":"인공의 (skill)"},{"type":"root","text":"fic","meaning":"만들다 (make)"}],"story":"자연적인 것이 아니라 사람의 기술로 '인공적으로(arti)' '만들어진(fic)' → 인공의.","example":{"en":"Artificial intelligence.","ko":"인공 지능 (AI)."}},
  {"word":"artisan","level":"high","meaning":"장인, 수공업자","pronunciation":"/ˈɑːrtəzn/","parts":[{"type":"root","text":"art","meaning":"기술 (skill)"},{"type":"suffix","text":"-isan","meaning":"사람"}],"story":"뛰어난 손'기술(art)'을 가지고 물건을 만들어내는 사람 → 장인.","example":{"en":"Artisan bread.","ko":"장인이 만든 빵."}},
  {"word":"artifact","level":"high","meaning":"인공물, 유물","pronunciation":"/ˈɑːrtɪfækt/","parts":[{"type":"root","text":"arti","meaning":"인공의 (skill)"},{"type":"root","text":"fact","meaning":"만들다 (make)"}],"story":"옛날 사람들이 자연물이 아닌 자신의 기술로 '직접 만들어낸(fact)' 물건 → 유물.","example":{"en":"Historical artifacts.","ko":"역사적 유물들."}},
  {"word":"bat","level":"middle","meaning":"방망이, 박쥐, 치다","pronunciation":"/bæt/","parts":[{"type":"root","text":"bat","meaning":"치다 (strike)"}],"story":"공을 세게 '치는(bat)' 도구 → 방망이.","example":{"en":"A baseball bat.","ko":"야구 방망이."}},
  {"word":"battle","level":"middle","meaning":"전투, 싸움","pronunciation":"/ˈbætl/","parts":[{"type":"root","text":"bat","meaning":"치다 (strike)"},{"type":"suffix","text":"-le","meaning":"명사형"}],"story":"무기를 들고 서로 치고받으며(bat) 싸우는 행위 → 전투.","example":{"en":"Lose the battle.","ko":"전투에서 패배하다."}},
  {"word":"combat","level":"high","meaning":"전투, 싸우다","pronunciation":"/ˈkɑːmbæt/","parts":[{"type":"prefix","text":"com-","meaning":"함께 (together)"},{"type":"root","text":"bat","meaning":"치다 (strike)"}],"story":"적과 '함께(com)' 격렬하게 서로 '치고받다(bat)' → 전투, 싸우다.","example":{"en":"Combat boots.","ko":"전투화."}},
  {"word":"debate","level":"middle","meaning":"토론, 논쟁하다","pronunciation":"/dɪˈbeɪt/","parts":[{"type":"prefix","text":"de-","meaning":"아래로, 완전히"},{"type":"root","text":"bate(bat)","meaning":"치다 (strike)"}],"story":"말로 상대방의 주장을 완전히 '때려눕혀서(bate)' 이기려는 과정 → 토론, 논쟁.","example":{"en":"A heated debate.","ko":"열띤 토론."}},
  {"word":"battery","level":"middle","meaning":"건전지, 포대, 구타","pronunciation":"/ˈbætəri/","parts":[{"type":"root","text":"bat","meaning":"치다 (strike)"},{"type":"suffix","text":"-ery","meaning":"집합"}],"story":"원래는 적을 '치는(bat)' 대포의 무리를 뜻함 → 힘을 모아두는 '배터리'.","example":{"en":"Charge the battery.","ko":"배터리를 충전하다."}},
  {"word":"camp","level":"middle","meaning":"야영지, 진영","pronunciation":"/kæmp/","parts":[{"type":"root","text":"camp","meaning":"들판 (field)"}],"story":"군인들이나 여행객이 텐트를 치고 머무는 넓은 '들판(camp)'.","example":{"en":"Set up a camp.","ko":"야영지를 세우다."}},
  {"word":"campus","level":"middle","meaning":"대학 구내, 캠퍼스","pronunciation":"/ˈkæmpəs/","parts":[{"type":"root","text":"camp","meaning":"들판 (field)"},{"type":"suffix","text":"-us","meaning":"장소"}],"story":"대학의 건물들이 모여있는 넓은 '들판(camp)' → 대학 캠퍼스.","example":{"en":"On campus.","ko":"캠퍼스 내에."}},
  {"word":"campaign","level":"middle","meaning":"캠페인, 군사 작전","pronunciation":"/kæmˈpeɪn/","parts":[{"type":"root","text":"camp","meaning":"들판 (field)"},{"type":"suffix","text":"-aign","meaning":"명사형"}],"story":"군대가 '들판(camp)'으로 나가 작전을 펼치던 것에서 유래 → 사회적 캠페인.","example":{"en":"An ad campaign.","ko":"광고 캠페인."}},
  {"word":"champion","level":"middle","meaning":"챔피언, 옹호하다","pronunciation":"/ˈtʃæmpiən/","parts":[{"type":"root","text":"champ(camp)","meaning":"들판, 전쟁터"},{"type":"suffix","text":"-ion","meaning":"사람"}],"story":"'전쟁터(들판)'에 나가서 끝까지 싸워 이긴 '사람(ion)' → 챔피언.","example":{"en":"The world champion.","ko":"세계 챔피언."}},
  {"word":"championship","level":"middle","meaning":"선수권 대회, 우승","pronunciation":"/ˈtʃæmpiənʃɪp/","parts":[{"type":"root","text":"champion","meaning":"챔피언"},{"type":"suffix","text":"-ship","meaning":"자격, 지위"}],"story":"챔피언이 될 자격을 겨루는 대회 → 선수권 대회.","example":{"en":"Win the championship.","ko":"선수권 대회에서 우승하다."}},
  {"word":"cast","level":"middle","meaning":"던지다, 깁스, 출연진","pronunciation":"/kæst/","parts":[{"type":"root","text":"cast","meaning":"던지다 (throw)"}],"story":"1. 그물이나 낚싯줄을 '던지다'. 2. 배우들에게 배역을 던져주다 → 캐스팅.","example":{"en":"Cast a shadow.","ko":"그림자를 드리우다(던지다)."}},
  {"word":"broadcast","level":"middle","meaning":"방송하다, 널리 알리다","pronunciation":"/ˈbrɔːdkæst/","parts":[{"type":"prefix","text":"broad-","meaning":"넓은 (wide)"},{"type":"root","text":"cast","meaning":"던지다 (throw)"}],"story":"전파나 씨앗을 '넓은(broad)' 지역으로 '던져서(cast)' 퍼뜨리다 → 방송하다.","example":{"en":"A live broadcast.","ko":"생방송."}},
  {"word":"forecast","level":"middle","meaning":"예측하다, 예보","pronunciation":"/ˈfɔːrkæst/","parts":[{"type":"prefix","text":"fore-","meaning":"미리, 앞에 (before)"},{"type":"root","text":"cast","meaning":"던지다 (throw)"}],"story":"미래에 일어날 일을 '미리(fore)' 짐작하여 말을 '던지다(cast)' → 날씨를 예보하다.","example":{"en":"Weather forecast.","ko":"일기 예보."}},
  {"word":"outcast","level":"high","meaning":"추방당한 사람, 왕따","pronunciation":"/ˈaʊtkæst/","parts":[{"type":"prefix","text":"out-","meaning":"밖으로 (out)"},{"type":"root","text":"cast","meaning":"던지다 (throw)"}],"story":"사회의 테두리 '밖으로(out)' '던져진(cast)' 사람 → 따돌림받는 사람.","example":{"en":"Social outcast.","ko":"사회적 왕따."}},
  {"word":"overcast","level":"high","meaning":"구름이 뒤덮인, 흐린","pronunciation":"/ˌoʊvərˈkæst/","parts":[{"type":"prefix","text":"over-","meaning":"위로, 덮어서"},{"type":"root","text":"cast","meaning":"던지다 (throw)"}],"story":"하늘 '위로(over)' 먹구름이 쫙 '던져져(cast)' 덮인 상태 → 흐린.","example":{"en":"An overcast sky.","ko":"흐린 하늘."}},
  {"word":"crime","level":"middle","meaning":"범죄","pronunciation":"/kraɪm/","parts":[{"type":"root","text":"cri","meaning":"판단하다, 체질하다"}],"story":"법에 따라 옳고 그름을 '판단(cri)'하여 처벌해야 하는 행위 → 범죄.","example":{"en":"Commit a crime.","ko":"범죄를 저지르다."}},
  {"word":"criminal","level":"middle","meaning":"범죄자, 범죄의","pronunciation":"/ˈkrɪmɪnl/","parts":[{"type":"root","text":"crime","meaning":"범죄"},{"type":"suffix","text":"-al","meaning":"사람/형용사"}],"story":"범죄 행위와 관련되어 심판(cri)을 받아야 하는 사람 → 범죄자.","example":{"en":"A wanted criminal.","ko":"수배 중인 범죄자."}},
  {"word":"crisis","level":"high","meaning":"위기, 고비","pronunciation":"/ˈkraɪsɪs/","parts":[{"type":"root","text":"cri","meaning":"판단하다 (decide)"},{"type":"suffix","text":"-sis","meaning":"명사형"}],"story":"환자가 살지 죽을지를 '판단(cri)'해야 하는 가장 중요한 순간 → 위기, 고비.","example":{"en":"An economic crisis.","ko":"경제 위기."}},
  {"word":"criticize","level":"middle","meaning":"비판하다, 비평하다","pronunciation":"/ˈkrɪtɪsaɪz/","parts":[{"type":"root","text":"crit","meaning":"판단하다"},{"type":"suffix","text":"-ize","meaning":"동사형"}],"story":"어떤 대상의 옳고 그름, 좋고 나쁨을 까다롭게 '판단하다(crit)' → 비판하다.","example":{"en":"Criticize the government.","ko":"정부를 비판하다."}},
  {"word":"discriminate","level":"high","meaning":"차별하다, 식별하다","pronunciation":"/dɪˈskrɪmɪneɪt/","parts":[{"type":"prefix","text":"dis-","meaning":"떨어져, 따로"},{"type":"root","text":"crim","meaning":"구별하다"},{"type":"suffix","text":"-ate","meaning":"동사형"}],"story":"사람들을 '따로(dis)' '구별지어(crim)' 불공평하게 대우하다 → 차별하다.","example":{"en":"Discriminate against women.","ko":"여성을 차별하다."}},
  {"word":"certain","level":"middle","meaning":"확실한, 어떤","pronunciation":"/ˈsɜːrtn/","parts":[{"type":"root","text":"cert","meaning":"확실한, 결정된"}],"story":"의심할 여지 없이 '확실하게(cert)' 정해진.","example":{"en":"I am certain.","ko":"나는 확신한다."}},
  {"word":"certainty","level":"middle","meaning":"확실성, 필연성","pronunciation":"/ˈsɜːrtnti/","parts":[{"type":"root","text":"certain","meaning":"확실한"},{"type":"suffix","text":"-ty","meaning":"명사형"}],"story":"의심할 여지 없이 아주 확실한 상태나 특징.","example":{"en":"With absolute certainty.","ko":"절대적인 확신을 가지고."}},
  {"word":"certify","level":"high","meaning":"증명하다, 인증하다","pronunciation":"/ˈsɜːrtɪfaɪ/","parts":[{"type":"root","text":"cert","meaning":"확실한"},{"type":"suffix","text":"-ify","meaning":"만들다"}],"story":"이것이 진짜라고 '확실하게(cert)' '만들어주다(ify)' → 증명서를 발급하다.","example":{"en":"Certify a document.","ko":"문서를 인증하다."}},
  {"word":"certificate","level":"high","meaning":"증명서, 자격증","pronunciation":"/sərˈtɪfɪkət/","parts":[{"type":"root","text":"certify","meaning":"증명하다"},{"type":"suffix","text":"-cate","meaning":"명사형"}],"story":"사실임을 확실하게 증명해 주기 위해 발급하는 종이 → 자격증.","example":{"en":"A birth certificate.","ko":"출생 증명서."}},
  {"word":"ascertain","level":"high","meaning":"알아내다, 확인하다","pronunciation":"/ˌæsərˈteɪn/","parts":[{"type":"prefix","text":"as(ad)-","meaning":"~쪽으로"},{"type":"root","text":"certain","meaning":"확실한"}],"story":"진실을 향해 다가가서 '확실하게(certain)' 만들다 → 사실을 알아내다.","example":{"en":"Ascertain the truth.","ko":"진실을 알아내다."}},
  {"word":"face","level":"middle","meaning":"얼굴, 직면하다","pronunciation":"/feɪs/","parts":[{"type":"root","text":"fac","meaning":"얼굴, 표면 (face)"}],"story":"1. 사람의 겉모습인 얼굴. 2. 얼굴을 똑바로 마주하다 → 직면하다.","example":{"en":"Face the problem.","ko":"문제에 직면하다."}},
  {"word":"surface","level":"middle","meaning":"표면, 수면","pronunciation":"/ˈsɜːrfɪs/","parts":[{"type":"prefix","text":"sur-","meaning":"위로 (above)"},{"type":"root","text":"face","meaning":"얼굴, 표면"}],"story":"어떤 물체나 액체의 가장 '위쪽(sur)'에 있는 '얼굴(face)' 부분 → 표면.","example":{"en":"The surface of the moon.","ko":"달의 표면."}},
  {"word":"confront","level":"high","meaning":"직면하다, 맞서다","pronunciation":"/kənˈfrʌnt/","parts":[{"type":"prefix","text":"con-","meaning":"함께, 마주하여"},{"type":"root","text":"front","meaning":"이마, 얼굴"}],"story":"서로 얼굴(front)을 '마주 대하고(con)' 똑바로 서서 싸우다 → 직면하다.","example":{"en":"Confront a difficulty.","ko":"어려움에 직면하다."}},
  {"word":"frontier","level":"high","meaning":"국경, 개척지","pronunciation":"/frʌnˈtɪr/","parts":[{"type":"root","text":"front","meaning":"앞, 얼굴"},{"type":"suffix","text":"-ier","meaning":"장소"}],"story":"국가가 얼굴(front)을 내밀고 다른 나라와 맞닿아 있는 가장 앞쪽 지역 → 국경.","example":{"en":"The western frontier.","ko":"서부 개척지."}},
  {"word":"upfront","level":"high","meaning":"선불의, 솔직한","pronunciation":"/ˌʌpˈfrʌnt/","parts":[{"type":"prefix","text":"up-","meaning":"위로, 앞에"},{"type":"root","text":"front","meaning":"얼굴, 앞"}],"story":"숨기지 않고 '얼굴 앞에(upfront)' 다 내놓는 → 솔직한, 돈을 먼저 내는(선불).","example":{"en":"An upfront payment.","ko":"선불 결제."}},
  {"word":"defend","level":"middle","meaning":"방어하다, 변호하다","pronunciation":"/dɪˈfend/","parts":[{"type":"prefix","text":"de-","meaning":"아래로, 떨어뜨려"},{"type":"root","text":"fend","meaning":"치다 (strike)"}],"story":"적의 공격을 '쳐서(fend)' 내 몸에서 '떨어뜨리다(de)' → 방어하다.","example":{"en":"Defend the country.","ko":"나라를 방어하다."}},
  {"word":"defense","level":"middle","meaning":"방어, 수비","pronunciation":"/dɪˈfens/","parts":[{"type":"prefix","text":"de-","meaning":"아래로"},{"type":"root","text":"fens","meaning":"치다 (strike)"}],"story":"공격을 쳐서 막아내는 행위 (defend의 명사형) → 수비, 방어.","example":{"en":"Self-defense.","ko":"정당방위, 자기방어."}},
  {"word":"offend","level":"high","meaning":"불쾌하게 하다, 범죄를 저지르다","pronunciation":"/əˈfend/","parts":[{"type":"prefix","text":"of(ob)-","meaning":"~에 맞서 (against)"},{"type":"root","text":"fend","meaning":"치다 (strike)"}],"story":"상대방의 마음이나 법에 '맞서서(of)' 무례하게 '치다(fend)' → 불쾌하게 하다.","example":{"en":"Offend someone's feelings.","ko":"누군가의 기분을 상하게 하다."}},
  {"word":"offense","level":"high","meaning":"공격, 위반, 불쾌감","pronunciation":"/əˈfens/","parts":[{"type":"prefix","text":"of-","meaning":"~에 맞서"},{"type":"root","text":"fens","meaning":"치다"}],"story":"상대방을 향해 먼저 치고 들어가는 것 → 공격, 규칙 위반.","example":{"en":"A criminal offense.","ko":"범죄 행위."}},
  {"word":"defender","level":"middle","meaning":"방어자, 수비수","pronunciation":"/dɪˈfendər/","parts":[{"type":"root","text":"defend","meaning":"방어하다"},{"type":"suffix","text":"-er","meaning":"사람"}],"story":"적의 공격을 '막아내는(defend)' 역할을 하는 '사람(er)'.","example":{"en":"A great defender.","ko":"훌륭한 수비수."}},
  {"word":"inflate","level":"high","meaning":"부풀리다, 인플레이션을 일으키다","pronunciation":"/ɪnˈfleɪt/","parts":[{"type":"prefix","text":"in-","meaning":"안으로 (into)"},{"type":"root","text":"flate","meaning":"불다 (blow)"}],"story":"풍선이나 물가 '안으로(in)' 바람을 불어넣어(flate) 커지게 하다.","example":{"en":"Inflate a balloon.","ko":"풍선을 부풀리다."}},
  {"word":"deflate","level":"high","meaning":"공기를 빼다, 기를 꺾다","pronunciation":"/dɪˈfleɪt/","parts":[{"type":"prefix","text":"de-","meaning":"아래로, 빼내다"},{"type":"root","text":"flate","meaning":"불다 (blow)"}],"story":"부풀었던 곳에서 바람(flate)을 '빼내다(de)' → 수축시키다, 기를 꺾다.","example":{"en":"Deflate the tire.","ko":"타이어의 바람을 빼다."}},
  {"word":"inflation","level":"middle","meaning":"인플레이션, 물가 상승","pronunciation":"/ɪnˈfleɪʃn/","parts":[{"type":"root","text":"inflate","meaning":"부풀리다"},{"type":"suffix","text":"-ion","meaning":"명사형"}],"story":"경제에 거품(바람)이 들어가서 물가가 지속적으로 '부풀어 오르는' 현상.","example":{"en":"High inflation rate.","ko":"높은 물가 상승률."}},
  {"word":"deflation","level":"high","meaning":"디플레이션, 물가 하락","pronunciation":"/dɪˈfleɪʃn/","parts":[{"type":"root","text":"deflate","meaning":"바람을 빼다"},{"type":"suffix","text":"-ion","meaning":"명사형"}],"story":"경제에 바람이 빠지면서 물가가 지속적으로 떨어지는 현상.","example":{"en":"Economic deflation.","ko":"경제적 물가 하락."}},
  {"word":"flatter","level":"high","meaning":"아부하다, 알랑거리다","pronunciation":"/ˈflætər/","parts":[{"type":"root","text":"flat","meaning":"불다 (blow)"},{"type":"suffix","text":"-er","meaning":"동사/사람"}],"story":"누군가의 귓가에 듣기 좋은 바람(flatter)을 살살 불어넣다 → 아부하다.","example":{"en":"Flatter the boss.","ko":"상사에게 아부하다."}},
  {"word":"afflict","level":"high","meaning":"괴롭히다, 피해를 입히다","pronunciation":"/əˈflɪkt/","parts":[{"type":"prefix","text":"af(ad)-","meaning":"~에게 (to)"},{"type":"root","text":"flict","meaning":"치다 (strike)"}],"story":"질병이나 고통이 사람'에게(af)' 다가가 강하게 '치다(flict)' → 괴롭히다.","example":{"en":"Afflicted with a disease.","ko":"질병으로 고통받는."}},
  {"word":"conflict","level":"middle","meaning":"갈등, 충돌하다","pronunciation":"/ˈkɑːnflɪkt/","parts":[{"type":"prefix","text":"con-","meaning":"함께 (together)"},{"type":"root","text":"flict","meaning":"치다 (strike)"}],"story":"두 가지 의견이나 세력이 '함께(con)' 맞서서 '치고받다(flict)' → 갈등, 충돌.","example":{"en":"Resolve a conflict.","ko":"갈등을 해결하다."}},
