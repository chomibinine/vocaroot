[
  {"word":"mental","level":"middle","meaning":"정신의, 마음의","pronunciation":"/ˈmentl/","parts":[{"type":"root","text":"ment","meaning":"마음 (mind)"},{"type":"suffix","text":"-al","meaning":"형용사형"}],"story":"육체가 아니라 '마음(ment)'이나 생각과 관련된.","example":{"en":"Mental health.","ko":"정신 건강."}},
  {"word":"mention","level":"middle","meaning":"언급하다, 말하다","pronunciation":"/ˈmenʃn/","parts":[{"type":"root","text":"ment","meaning":"마음에 두다, 생각"},{"type":"suffix","text":"-ion","meaning":"명사/동사형"}],"story":"'마음(ment)'속에 있던 생각을 밖으로 꺼내어 말하다 → 언급하다.","example":{"en":"Don't mention it.","ko":"별말씀을요. (언급하지 마세요)"}},
  {"word":"comment","level":"middle","meaning":"논평, 언급, 의견","pronunciation":"/ˈkɑːment/","parts":[{"type":"prefix","text":"com-","meaning":"함께 (together)"},{"type":"root","text":"ment","meaning":"마음, 생각 (mind)"}],"story":"어떤 주제에 대해 사람들과 '함께(com)' '생각(ment)'을 나누는 글이나 말 → 논평.","example":{"en":"Leave a comment.","ko":"의견을 남기다."}},
  {"word":"monitor","level":"middle","meaning":"화면, 감시하다","pronunciation":"/ˈmɑːnɪtər/","parts":[{"type":"root","text":"mon(ment)","meaning":"경고하다, 생각하다"},{"type":"suffix","text":"-or","meaning":"도구, 사람"}],"story":"어떤 상태인지 주의 깊게 생각하고 '경고해 주는(mon)' 기계 → 모니터, 감시하다.","example":{"en":"Monitor the situation.","ko":"상황을 감시하다."}},
  {"word":"summon","level":"high","meaning":"소환하다, 부르다","pronunciation":"/ˈsʌmən/","parts":[{"type":"prefix","text":"sum(sub)-","meaning":"아래로, 은밀히"},{"type":"root","text":"mon","meaning":"경고하다, 부르다"}],"story":"은밀하게 다가가 '경고(mon)'하며 법정이나 회의로 나오라고 부르다 → 소환하다.","example":{"en":"Summon a witness.","ko":"증인을 소환하다."}},
  {"word":"commerce","level":"high","meaning":"상업, 무역","pronunciation":"/ˈkɑːmɜːrs/","parts":[{"type":"prefix","text":"com-","meaning":"함께 (together)"},{"type":"root","text":"merce","meaning":"장사하다, 보상 (trade)"}],"story":"사람들이 '함께(com)' 물건을 사고팔며 '장사하는(merce)' 행위 → 상업.","example":{"en":"E-commerce.","ko":"전자 상거래."}},
  {"word":"commercial","level":"middle","meaning":"상업의, 광고","pronunciation":"/kəˈmɜːrʃl/","parts":[{"type":"root","text":"commerce","meaning":"상업"},{"type":"suffix","text":"-ial","meaning":"형용사형"}],"story":"이익을 내기 위한 '상업(commerce)'과 관련된, 또는 물건을 팔기 위한 방송 → 광고.","example":{"en":"A TV commercial.","ko":"TV 광고."}},
  {"word":"merchant","level":"middle","meaning":"상인, 무역상","pronunciation":"/ˈmɜːrtʃənt/","parts":[{"type":"root","text":"merch","meaning":"장사하다 (trade)"},{"type":"suffix","text":"-ant","meaning":"사람"}],"story":"시장에서 물건을 '사고파는(merch)' '사람(ant)' → 상인.","example":{"en":"A wealthy merchant.","ko":"부유한 상인."}},
  {"word":"merchandise","level":"high","meaning":"상품, 제품","pronunciation":"/ˈmɜːrtʃəndaɪs/","parts":[{"type":"root","text":"merch","meaning":"장사 (trade)"},{"type":"suffix","text":"-andise","meaning":"물건"}],"story":"상인들이 장사(merch)를 하기 위해 내놓은 물건들 → 상품.","example":{"en":"Display the merchandise.","ko":"상품을 전시하다."}},
  {"word":"mercy","level":"middle","meaning":"자비, 용서","pronunciation":"/ˈmɜːrsi/","parts":[{"type":"root","text":"merc","meaning":"보상, 몸값 (reward)"},{"type":"suffix","text":"-y","meaning":"명사형"}],"story":"과거 포로에게 '몸값(merc)'을 받고 풀어주던 행위에서 유래 → 자비를 베풀다.","example":{"en":"Beg for mercy.","ko":"자비를 구하다."}},
  {"word":"merge","level":"high","meaning":"합병하다, 합치다","pronunciation":"/mɜːrdʒ/","parts":[{"type":"root","text":"merg","meaning":"물에 빠지다 (dip/plunge)"}],"story":"서로 다른 강물이 하나로 '빠져들어(merg)' 섞이다 → (회사가) 합병하다.","example":{"en":"Merge two companies.","ko":"두 회사를 합병하다."}},
  {"word":"emerge","level":"high","meaning":"나타나다, 떠오르다","pronunciation":"/ɪˈmɜːrdʒ/","parts":[{"type":"prefix","text":"e(x)-","meaning":"밖으로 (out)"},{"type":"root","text":"merge","meaning":"빠지다 (plunge)"}],"story":"물속에 '빠져있던(merge)' 것이 수면 '밖으로(e)' 올라오다 → 나타나다.","example":{"en":"Emerge from the dark.","ko":"어둠 속에서 나타나다."}},
  {"word":"submerge","level":"high","meaning":"잠수하다, 물속에 잠기다","pronunciation":"/səbˈmɜːrdʒ/","parts":[{"type":"prefix","text":"sub-","meaning":"아래로 (under)"},{"type":"root","text":"merge","meaning":"빠지다 (plunge)"}],"story":"물 '아래로(sub)' 푹 '빠지다(merge)' → 잠수하다.","example":{"en":"The submarine submerged.","ko":"잠수함이 잠수했다."}},
  {"word":"emergency","level":"middle","meaning":"비상사태, 응급","pronunciation":"/ɪˈmɜːrdʒənsi/","parts":[{"type":"root","text":"emerge","meaning":"나타나다"},{"type":"suffix","text":"-ency","meaning":"명사형"}],"story":"숨겨져 있던 위험한 상황이 갑자기 물 밖으로 '튀어나온(emerge)' 상태 → 비상사태.","example":{"en":"An emergency exit.","ko":"비상구."}},
  {"word":"immerse","level":"high","meaning":"담그다, 몰두하게 하다","pronunciation":"/ɪˈmɜːrs/","parts":[{"type":"prefix","text":"im(in)-","meaning":"안에 (into)"},{"type":"root","text":"mers(merg)","meaning":"빠지다 (plunge)"}],"story":"물이나 어떤 일 '속으로(im)' 푹 '빠지게(mers)' 하다 → 몰두하다.","example":{"en":"Immerse yourself in study.","ko":"공부에 몰두해라."}},
  {"word":"name","level":"middle","meaning":"이름, 지명하다","pronunciation":"/neɪm/","parts":[{"type":"root","text":"name(nom)","meaning":"이름 (name)"}],"story":"사물이나 사람을 부르는 '이름'.","example":{"en":"My name is John.","ko":"내 이름은 존이다."}},
  {"word":"nominate","level":"high","meaning":"지명하다, 추천하다","pronunciation":"/ˈnɑːmɪneɪt/","parts":[{"type":"root","text":"nomin","meaning":"이름 (name)"},{"type":"suffix","text":"-ate","meaning":"동사형"}],"story":"선거 후보나 수상자의 '이름(nomin)'을 호명하여 올리다 → 지명하다.","example":{"en":"Nominate him for president.","ko":"그를 회장 후보로 지명하다."}},
  {"word":"anonymous","level":"high","meaning":"익명의","pronunciation":"/əˈnɑːnɪməs/","parts":[{"type":"prefix","text":"an-","meaning":"없는 (without)"},{"type":"root","text":"onym","meaning":"이름 (name)"},{"type":"suffix","text":"-ous","meaning":"형용사형"}],"story":"글이나 기부금에 '이름(onym)'이 '적혀있지 않은(an)' → 익명의.","example":{"en":"An anonymous donor.","ko":"익명의 기부자."}},
  {"word":"synonym","level":"high","meaning":"동의어","pronunciation":"/ˈsɪnənɪm/","parts":[{"type":"prefix","text":"syn-","meaning":"같은 (same)"},{"type":"root","text":"onym","meaning":"이름 (name)"}],"story":"'같은(syn)' 뜻을 가진 다른 '이름(onym)' → 동의어.","example":{"en":"'Fast' is a synonym of 'quick'.","ko":"'Fast'는 'quick'의 동의어이다."}},
  {"word":"antonym","level":"high","meaning":"반의어","pronunciation":"/ˈæntənɪm/","parts":[{"type":"prefix","text":"ant-","meaning":"반대의 (opposite)"},{"type":"root","text":"onym","meaning":"이름 (name)"}],"story":"'반대되는(ant)' 뜻을 가진 '이름(onym)' → 반의어.","example":{"en":"An antonym for 'hot' is 'cold'.","ko":"'hot'의 반의어는 'cold'이다."}},
  {"word":"option","level":"middle","meaning":"선택권, 옵션","pronunciation":"/ˈɑːpʃn/","parts":[{"type":"root","text":"opt","meaning":"선택하다 (choose)"},{"type":"suffix","text":"-ion","meaning":"명사형"}],"story":"여러 가지 중에서 마음에 드는 것을 '고르는(opt)' 것 → 선택권.","example":{"en":"You have no other option.","ko":"너는 다른 선택의 여지가 없다."}},
  {"word":"adopt","level":"middle","meaning":"입양하다, 채택하다","pronunciation":"/əˈdɑːpt/","parts":[{"type":"prefix","text":"ad-","meaning":"~쪽으로 (to)"},{"type":"root","text":"opt","meaning":"선택하다 (choose)"}],"story":"내 마음에 들어 내 아이나 내 의견으로 '선택해(opt)' 데려오다 → 입양/채택하다.","example":{"en":"Adopt a child.","ko":"아이를 입양하다."}},
  {"word":"optimal","level":"high","meaning":"최적의, 최선의","pronunciation":"/ˈɑːptɪml/","parts":[{"type":"root","text":"opt","meaning":"최고의 (best)"},{"type":"suffix","text":"-mal","meaning":"형용사형"}],"story":"가장 '좋은(opt)' 상태를 나타내는 → 최적의.","example":{"en":"Optimal conditions.","ko":"최적의 조건들."}},
  {"word":"optimist","level":"high","meaning":"낙천주의자","pronunciation":"/ˈɑːptɪmɪst/","parts":[{"type":"root","text":"optim","meaning":"최고의 (best)"},{"type":"suffix","text":"-ist","meaning":"사람"}],"story":"세상이 항상 '최고(optim)'로 좋게 풀릴 거라고 믿는 '사람(ist)'.","example":{"en":"She is a true optimist.","ko":"그녀는 진정한 낙천주의자이다."}},
  {"word":"optical","level":"high","meaning":"시각의, 광학의","pronunciation":"/ˈɑːptɪkl/","parts":[{"type":"root","text":"opt","meaning":"눈 (eye)"},{"type":"suffix","text":"-ical","meaning":"관련된"}],"story":"안경이나 렌즈처럼 사물을 보는 '눈(opt)'과 관련된.","example":{"en":"An optical illusion.","ko":"착시 현상."}},
  {"word":"radish","level":"middle","meaning":"무 (채소)","pronunciation":"/ˈrædɪʃ/","parts":[{"type":"root","text":"rad","meaning":"뿌리 (root)"},{"type":"suffix","text":"-ish","meaning":"명사형"}],"story":"식물의 '뿌리(rad)' 부분을 먹는 둥근 채소 → 무.","example":{"en":"Slice the radish.","ko":"무를 썰어라."}},
  {"word":"radical","level":"high","meaning":"근본적인, 급진적인","pronunciation":"/ˈrædɪkl/","parts":[{"type":"root","text":"radic","meaning":"뿌리 (root)"},{"type":"suffix","text":"-al","meaning":"형용사형"}],"story":"'뿌리(radic)'까지 파고드는 → 근본적인. 뿌리째 뽑으려는 → 급진적인.","example":{"en":"Radical changes.","ko":"급진적인 변화."}},
  {"word":"eradicate","level":"high","meaning":"근절하다, 뿌리뽑다","pronunciation":"/ɪˈrædɪkeɪt/","parts":[{"type":"prefix","text":"e(x)-","meaning":"밖으로 (out)"},{"type":"root","text":"radic","meaning":"뿌리 (root)"},{"type":"suffix","text":"-ate","meaning":"동사형"}],"story":"잡초의 '뿌리(radic)'를 잡고 땅 '밖으로(e)' 뽑아버리다 → 근절하다.","example":{"en":"Eradicate the disease.","ko":"질병을 근절하다."}},
  {"word":"radius","level":"high","meaning":"반지름, 반경","pronunciation":"/ˈreɪdiəs/","parts":[{"type":"root","text":"rad","meaning":"바큇살 (ray/root)"},{"type":"suffix","text":"-ius","meaning":"명사형"}],"story":"원의 중심에서 바깥으로 뻗어나간 선(바큇살) → 반지름.","example":{"en":"A radius of 5 meters.","ko":"반경 5미터."}},
  {"word":"radiate","level":"high","meaning":"내뿜다, 방사하다","pronunciation":"/ˈreɪdieɪt/","parts":[{"type":"root","text":"rad","meaning":"빛, 광선 (ray)"},{"type":"suffix","text":"-ate","meaning":"동사형"}],"story":"중심에서 사방으로 빛이나 열이 뿌리처럼 뻗어나가다 → 방사하다.","example":{"en":"Radiate heat.","ko":"열을 내뿜다."}},
  {"word":"sacred","level":"middle","meaning":"신성한, 종교적인","pronunciation":"/ˈseɪkrɪd/","parts":[{"type":"root","text":"sacr","meaning":"신성한 (holy)"},{"type":"suffix","text":"-ed","meaning":"형용사형"}],"story":"신과 관련되어 함부로 대할 수 없는 '신성한(sacr)' 성질.","example":{"en":"A sacred cow.","ko":"신성한 소 (절대 건드릴 수 없는 것)."}},
  {"word":"sacrifice","level":"middle","meaning":"희생하다, 제물","pronunciation":"/ˈsækrɪfaɪs/","parts":[{"type":"root","text":"sacri","meaning":"신성한 (holy)"},{"type":"root","text":"fic","meaning":"만들다 (make)"}],"story":"신에게 바치기 위해 동물을 '신성하게(sacri)' '만들어(fic)' 제단에 올리다 → 희생.","example":{"en":"Sacrifice my weekend.","ko":"내 주말을 희생하다."}},
  {"word":"sanctuary","level":"high","meaning":"성소, 피난처","pronunciation":"/ˈsæŋktʃueri/","parts":[{"type":"root","text":"sanct","meaning":"신성한 (holy)"},{"type":"suffix","text":"-uary","meaning":"장소"}],"story":"'신성한(sanct)' 신을 모시는 '장소(uary)'. 범죄자도 숨을 수 있었던 피난처.","example":{"en":"An animal sanctuary.","ko":"동물 보호 구역."}},
  {"word":"sanction","level":"high","meaning":"제재, 허가","pronunciation":"/ˈsæŋkʃn/","parts":[{"type":"root","text":"sanct","meaning":"신성한 (holy)"},{"type":"suffix","text":"-ion","meaning":"명사형"}],"story":"법률을 '신성하게(sanct)' 만들어 어기는 자에게 내리는 벌 → 제재.","example":{"en":"Economic sanctions.","ko":"경제 제재."}},
  {"word":"saint","level":"middle","meaning":"성인, 성자","pronunciation":"/seɪnt/","parts":[{"type":"root","text":"saint(sanct)","meaning":"신성한 (holy)"}],"story":"종교적으로 매우 '신성하고(saint)' 덕이 높은 사람.","example":{"en":"Saint Peter.","ko":"성 베드로."}},
  {"word":"salmon","level":"middle","meaning":"연어","pronunciation":"/ˈsæmən/","parts":[{"type":"root","text":"salm(sal)","meaning":"뛰어오르다 (leap)"}],"story":"알을 낳으려고 폭포를 향해 '뛰어오르는(sal)' 물고기 → 연어.","example":{"en":"Smoked salmon.","ko":"훈제 연어."}},
  {"word":"insult","level":"middle","meaning":"모욕하다, 모욕","pronunciation":"/ɪnˈsʌlt/","parts":[{"type":"prefix","text":"in-","meaning":"안으로, 향해서"},{"type":"root","text":"sult(sal)","meaning":"뛰다 (leap)"}],"story":"다른 사람을 깎아내리려고 그 사람을 향해(in) 거칠게 '뛰어오르다(sult)' → 모욕하다.","example":{"en":"An insult to my intelligence.","ko":"내 지능에 대한 모욕."}},
  {"word":"result","level":"middle","meaning":"결과, 발생하다","pronunciation":"/rɪˈzʌlt/","parts":[{"type":"prefix","text":"re-","meaning":"뒤로, 돌아와 (back)"},{"type":"root","text":"sult","meaning":"뛰다 (leap)"}],"story":"어떤 행동이 끝난 후 다시 '뒤로(re)' '뛰어(sult)' 내게 돌아오는 것 → 결과.","example":{"en":"The result of the test.","ko":"시험 결과."}},
  {"word":"assault","level":"high","meaning":"폭행하다, 맹공","pronunciation":"/əˈsɔːlt/","parts":[{"type":"prefix","text":"as(ad)-","meaning":"~를 향해 (toward)"},{"type":"root","text":"sault(sal)","meaning":"뛰다 (leap)"}],"story":"적이나 사람을 '향해(as)' 갑자기 덮치듯 '뛰어오르다(sault)' → 폭행하다.","example":{"en":"Sexual assault.","ko":"성폭행."}},
  {"word":"exult","level":"high","meaning":"기뻐 날뛰다, 환호하다","pronunciation":"/ɪɡˈzʌlt/","parts":[{"type":"prefix","text":"ex-","meaning":"밖으로 (out)"},{"type":"root","text":"sult","meaning":"뛰다 (leap)"}],"story":"기쁨이 너무 커서 몸 '밖으로(ex)' 펄쩍펄쩍 '뛰어오르다(sult)'.","example":{"en":"Exult in a victory.","ko":"승리에 환호하다."}},
  {"word":"serve","level":"middle","meaning":"제공하다, 섬기다, 복무하다","pronunciation":"/sɜːrv/","parts":[{"type":"root","text":"serv","meaning":"노예, 섬기다 (serve)"}],"story":"주인을 위해 시중을 들거나, 손님에게 음식을 내놓다 → 제공하다, 섬기다.","example":{"en":"Serve food.","ko":"음식을 제공하다."}},
  {"word":"preserve","level":"middle","meaning":"보존하다, 보호하다","pronunciation":"/prɪˈzɜːrv/","parts":[{"type":"prefix","text":"pre-","meaning":"미리 (before)"},{"type":"root","text":"serv","meaning":"지키다 (keep)"}],"story":"망가지기 전에 '미리(pre)' 온전하게 '지키다(serv)' → 보존하다.","example":{"en":"Preserve nature.","ko":"자연을 보존하다."}},
  {"word":"reserve","level":"middle","meaning":"예약하다, 남겨두다","pronunciation":"/rɪˈzɜːrv/","parts":[{"type":"prefix","text":"re-","meaning":"뒤에 (back)"},{"type":"root","text":"serv","meaning":"지키다 (keep)"}],"story":"지금 쓰지 않고 나중을 위해 '뒤에(re)' 따로 '지켜두다(serv)' → 예약하다.","example":{"en":"Reserve a table.","ko":"테이블을 예약하다."}},
  {"word":"deserve","level":"high","meaning":"~할 가치가 있다, 마땅하다","pronunciation":"/dɪˈzɜːrv/","parts":[{"type":"prefix","text":"de-","meaning":"완전히"},{"type":"root","text":"serve","meaning":"섬기다"}],"story":"'완전히(de)' 땀 흘려 '섬겼으므로(serve)' 그만한 대가를 받을 자격이 있다.","example":{"en":"You deserve it.","ko":"넌 그럴 자격이 있어."}},
  {"word":"observe","level":"middle","meaning":"관찰하다, 준수하다","pronunciation":"/əbˈzɜːrv/","parts":[{"type":"prefix","text":"ob-","meaning":"~을 향해"},{"type":"root","text":"serve","meaning":"지키다 (keep)"}],"story":"대상을 향해 시선을 '지키고' 있다(관찰하다). 법을 '지키다'(준수하다).","example":{"en":"Observe the stars.","ko":"별을 관찰하다."}},
  {"word":"torture","level":"high","meaning":"고문(하다)","pronunciation":"/ˈtɔːrtʃər/","parts":[{"type":"root","text":"tort","meaning":"비틀다 (twist)"},{"type":"suffix","text":"-ure","meaning":"명사형"}],"story":"사람의 몸이나 팔다리를 '비틀어서(tort)' 고통을 주는 잔인한 행위.","example":{"en":"Endure physical torture.","ko":"육체적 고문을 견디다."}},
  {"word":"distort","level":"high","meaning":"왜곡하다, 비틀다","pronunciation":"/dɪˈstɔːrt/","parts":[{"type":"prefix","text":"dis-","meaning":"완전히, 멀리"},{"type":"root","text":"tort","meaning":"비틀다 (twist)"}],"story":"사실이나 원래의 모양을 '완전히(dis)' '비틀어버리다(tort)' → 왜곡하다.","example":{"en":"Distort the truth.","ko":"진실을 왜곡하다."}},
