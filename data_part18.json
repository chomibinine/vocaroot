[
  {"word":"altitude","level":"high","meaning":"고도, 높이","pronunciation":"/ˈæltɪtuːd/","parts":[{"type":"root","text":"alt","meaning":"높은 (high)"},{"type":"suffix","text":"-itude","meaning":"명사형"}],"story":"땅이나 바다에서부터 위로 얼마나 '높은(alt)' 곳에 있는지를 나타내는 수치 → 고도.","example":{"en":"At high altitudes.","ko":"높은 고도에서."}},
  {"word":"exalt","level":"high","meaning":"칭송하다, (지위를) 높이다","pronunciation":"/ɪɡˈzɔːlt/","parts":[{"type":"prefix","text":"ex-","meaning":"위로 (out/up)"},{"type":"root","text":"alt","meaning":"높은 (high)"}],"story":"어떤 사람의 업적이나 이름을 가장 '높은(alt)' 곳으로 '끌어올려(ex)' 찬양하다 → 칭송하다.","example":{"en":"Exalt a hero.","ko":"영웅을 칭송하다."}},
  {"word":"altar","level":"high","meaning":"제단","pronunciation":"/ˈɔːltər/","parts":[{"type":"root","text":"alt","meaning":"높은 (high)"},{"type":"suffix","text":"-ar","meaning":"장소"}],"story":"신에게 제물을 바치기 위해 땅보다 '높게(alt)' 쌓아 올린 장소 → 제단.","example":{"en":"Pray at the altar.","ko":"제단에서 기도하다."}},
  {"word":"alto","level":"middle","meaning":"알토 (여성 저음/남성 최고음)","pronunciation":"/ˈæltoʊ/","parts":[{"type":"root","text":"alt","meaning":"높은 (high)"}],"story":"남성 성부 중에서는 가장 '높은(alt)' 음역대에서 유래한 음악 용어 → 알토.","example":{"en":"Sing in alto.","ko":"알토로 노래하다."}},
  {"word":"altimeter","level":"high","meaning":"고도계","pronunciation":"/ælˈtɪmɪtər/","parts":[{"type":"root","text":"alti","meaning":"높은 (high)"},{"type":"root","text":"meter","meaning":"측정기"}],"story":"비행기 등이 얼마나 '높은지(alti)' 그 고도를 '측정하는 장치(meter)'.","example":{"en":"Check the altimeter.","ko":"고도계를 확인하다."}},
  {"word":"amateur","level":"middle","meaning":"아마추어, 비전문가","pronunciation":"/ˈæmətər/","parts":[{"type":"root","text":"amat(am)","meaning":"사랑하다 (love)"},{"type":"suffix","text":"-eur","meaning":"사람"}],"story":"돈을 위해서가 아니라, 단지 그 일을 '사랑해서(amat)' 하는 사람 → 아마추어.","example":{"en":"An amateur photographer.","ko":"아마추어 사진작가."}},
  {"word":"amiable","level":"high","meaning":"상냥한, 정감 있는","pronunciation":"/ˈeɪmiəbl/","parts":[{"type":"root","text":"ami","meaning":"친구 (friend)"},{"type":"suffix","text":"-able","meaning":"할 수 있는"}],"story":"누구와도 '친구(ami)'가 될 수 '있을(able)' 만큼 성격이 좋고 부드러운 → 상냥한.","example":{"en":"An amiable smile.","ko":"상냥한 미소."}},
  {"word":"amorous","level":"high","meaning":"호색적인, 사랑의","pronunciation":"/ˈæmərəs/","parts":[{"type":"root","text":"amor","meaning":"사랑 (love)"},{"type":"suffix","text":"-ous","meaning":"가득한"}],"story":"이성에 대한 '사랑(amor)'과 욕망이 '가득한(ous)' → 호색적인.","example":{"en":"Amorous adventures.","ko":"호색적인 연애 행각."}},
  {"word":"enemy","level":"middle","meaning":"적, 원수","pronunciation":"/ˈenəmi/","parts":[{"type":"prefix","text":"en(in)-","meaning":"아닌 (not)"},{"type":"root","text":"emy(ami)","meaning":"친구 (friend)"}],"story":"나의 편이나 '친구(emy)'가 '아닌(en)' 사람 → 적.","example":{"en":"A bitter enemy.","ko":"철천지원수."}},
  {"word":"enmity","level":"high","meaning":"적대감, 원한","pronunciation":"/ˈenməti/","parts":[{"type":"prefix","text":"en(in)-","meaning":"아닌 (not)"},{"type":"root","text":"mit(ami)","meaning":"친구 (friend)"},{"type":"suffix","text":"-ty","meaning":"명사형"}],"story":"서로 '친구(mit)'가 '아니라서(en)' 마음속에 품게 되는 미움의 감정 → 적대감.","example":{"en":"Deep-rooted enmity.","ko":"뿌리 깊은 적대감."}},
  {"word":"cross","level":"middle","meaning":"십자가, 교차하다","pronunciation":"/krɔːs/","parts":[{"type":"root","text":"cross(cruc)","meaning":"십자가 (cross)"}],"story":"가로와 세로가 '십자가(cruc)' 모양으로 겹쳐지는 것 → 교차하다.","example":{"en":"Cross the street.","ko":"길을 건너다(교차하다)."}},
  {"word":"crucial","level":"high","meaning":"중대한, 결정적인","pronunciation":"/ˈkruːʃl/","parts":[{"type":"root","text":"cruc","meaning":"십자가 (cross)"},{"type":"suffix","text":"-ial","meaning":"형용사형"}],"story":"어느 길로 갈지 선택해야 하는 '십자(cruc)' 형태의 갈림길에 선 것처럼 → 결정적인.","example":{"en":"A crucial decision.","ko":"결정적인 판단."}},
  {"word":"cruise","level":"middle","meaning":"유람선, 순항하다","pronunciation":"/kruːz/","parts":[{"type":"root","text":"cruis(cruc)","meaning":"교차하다 (cross)"}],"story":"바다 위를 십자가 모양으로 여기저기 '교차하며(cruis)' 돌아다니는 배 → 유람선.","example":{"en":"A luxury cruise.","ko":"호화 유람선 여행."}},
  {"word":"cruiser","level":"middle","meaning":"순양함, 경찰차","pronunciation":"/ˈkruːzər/","parts":[{"type":"root","text":"cruis","meaning":"교차하며 맴돌다"},{"type":"suffix","text":"-er","meaning":"사물"}],"story":"바다나 거리를 교차하듯 돌아다니며 순찰하는 배나 차 → 순양함, 순찰차.","example":{"en":"A police cruiser.","ko":"경찰 순찰차."}},
  {"word":"crusade","level":"high","meaning":"십자군, (옳은 것을 위한) 운동","pronunciation":"/kruːˈseɪd/","parts":[{"type":"root","text":"crus(cruc)","meaning":"십자가 (cross)"},{"type":"suffix","text":"-ade","meaning":"집단, 행동"}],"story":"가슴에 '십자가(crus)' 모양을 새기고 전쟁에 나섰던 무리 → 십자군.","example":{"en":"A crusade against crime.","ko":"범죄 퇴치 운동."}},
  {"word":"debt","level":"middle","meaning":"빚, 부채","pronunciation":"/det/","parts":[{"type":"root","text":"deb","meaning":"빚지다, 갚아야 할 의무"}],"story":"남에게 돈을 빌려 마땅히 갚아야 할 의무가 있는 것 → 빚. (b는 묵음)","example":{"en":"Pay off a debt.","ko":"빚을 다 갚다."}},
  {"word":"debtor","level":"middle","meaning":"채무자 (빚진 사람)","pronunciation":"/ˈdetər/","parts":[{"type":"root","text":"debt","meaning":"빚"},{"type":"suffix","text":"-or","meaning":"사람"}],"story":"남에게 '빚(debt)'을 지고 갚아야 할 책임이 있는 '사람(or)'.","example":{"en":"Creditor and debtor.","ko":"채권자와 채무자."}},
  {"word":"due","level":"middle","meaning":"~할 예정인, 마땅한","pronunciation":"/duː/","parts":[{"type":"root","text":"du","meaning":"마땅히 줘야 할 (owe)"}],"story":"날짜나 조건이 되어 마땅히 치러야 하거나 주어야 하는 상태 → 만기의, ~할 예정인.","example":{"en":"The assignment is due tomorrow.","ko":"과제는 내일까지(가 기한)이다."}},
  {"word":"duty","level":"middle","meaning":"의무, 세금","pronunciation":"/ˈduːti/","parts":[{"type":"root","text":"du","meaning":"마땅한"},{"type":"suffix","text":"-ty","meaning":"명사형"}],"story":"국민이나 시민으로서 '마땅히(du)' 다해야 하는 행동 → 의무, 세금.","example":{"en":"Do your duty.","ko":"너의 의무를 다해라."}},
  {"word":"duty-free","level":"middle","meaning":"면세의","pronunciation":"/ˌduːti ˈfriː/","parts":[{"type":"root","text":"duty","meaning":"세금"},{"type":"root","text":"free","meaning":"없는"}],"story":"국가에 내야 하는 '세금(duty)'이 면제되어 '없는(free)' → 면세의.","example":{"en":"A duty-free shop.","ko":"면세점."}},
  {"word":"horror","level":"middle","meaning":"공포, 두려움","pronunciation":"/ˈhɔːrər/","parts":[{"type":"root","text":"horr","meaning":"떨다 (shudder)"},{"type":"suffix","text":"-or","meaning":"명사형"}],"story":"너무 무서워서 몸의 털이 쭈뼛 서고 부들부들 '떨리는(horr)' 감정 → 공포.","example":{"en":"A horror movie.","ko":"공포 영화."}},
  {"word":"horrible","level":"middle","meaning":"끔찍한, 무서운","pronunciation":"/ˈhɔːrəbl/","parts":[{"type":"root","text":"horr","meaning":"떨다 (shudder)"},{"type":"suffix","text":"-ible","meaning":"형용사형"}],"story":"쳐다만 봐도 몸이 '떨릴(horr)' 정도로 무섭고 불쾌한 → 끔찍한.","example":{"en":"A horrible accident.","ko":"끔찍한 사고."}},
  {"word":"horrify","level":"high","meaning":"소름 끼치게 하다","pronunciation":"/ˈhɔːrɪfaɪ/","parts":[{"type":"root","text":"horr","meaning":"떨다"},{"type":"suffix","text":"-ify","meaning":"만들다"}],"story":"사람을 공포에 질려 '떨게(horr)' '만들다(ify)' → 소름 끼치게 하다.","example":{"en":"The news horrified us.","ko":"그 뉴스는 우리를 소름 끼치게 했다."}},
  {"word":"horrific","level":"high","meaning":"무시무시한, 끔찍한","pronunciation":"/həˈrɪfɪk/","parts":[{"type":"root","text":"horr","meaning":"떨다"},{"type":"suffix","text":"-ific","meaning":"형용사형"}],"story":"말로 다 할 수 없을 만큼 사람을 심하게 '떨게(horr)' 하는.","example":{"en":"A horrific crime.","ko":"무시무시한 범죄."}},
  {"word":"abhor","level":"high","meaning":"혐오하다, 몹시 싫어하다","pronunciation":"/əbˈhɔːr/","parts":[{"type":"prefix","text":"ab-","meaning":"멀리 (away)"},{"type":"root","text":"hor","meaning":"떨다 (shudder)"}],"story":"무언가가 너무 싫고 끔찍해서 소름이 '돋아(hor)' '멀리(ab)'하고 싶어지다 → 혐오하다.","example":{"en":"I abhor violence.","ko":"나는 폭력을 혐오한다."}},
  {"word":"host","level":"middle","meaning":"주인, 주최하다","pronunciation":"/hoʊst/","parts":[{"type":"root","text":"host","meaning":"손님을 맞이하는 자"}],"story":"자신의 집이나 파티에 낯선 사람이나 손님을 초대해 환영하는 자 → 주인.","example":{"en":"Host a party.","ko":"파티를 주최하다."}},
  {"word":"hostage","level":"middle","meaning":"인질","pronunciation":"/ˈhɑːstɪdʒ/","parts":[{"type":"root","text":"host","meaning":"이방인, 적 (stranger)"},{"type":"suffix","text":"-age","meaning":"상태"}],"story":"상대방을 협박하기 위해 낯선 '적(host)'의 손에 넘겨진 사람 → 인질.","example":{"en":"Hold someone hostage.","ko":"누군가를 인질로 잡다."}},
  {"word":"hostile","level":"high","meaning":"적대적인","pronunciation":"/ˈhɑːstl/","parts":[{"type":"root","text":"host","meaning":"적 (enemy)"},{"type":"suffix","text":"-ile","meaning":"형용사형"}],"story":"상대방을 손님이 아니라 '적(host)'으로 여겨 공격하려는 태도의 → 적대적인.","example":{"en":"A hostile environment.","ko":"적대적인 환경."}},
  {"word":"hospital","level":"middle","meaning":"병원","pronunciation":"/ˈhɑːspɪtl/","parts":[{"type":"root","text":"hospit(host)","meaning":"손님, 환자"},{"type":"suffix","text":"-al","meaning":"장소"}],"story":"아프고 지친 '손님(hospit)'들을 따뜻하게 맞이하고 치료해 주는 장소 → 병원.","example":{"en":"Go to the hospital.","ko":"병원에 가다."}},
  {"word":"hospitality","level":"high","meaning":"환대, 후대","pronunciation":"/ˌhɑːspɪˈtæləti/","parts":[{"type":"root","text":"hospit","meaning":"손님"},{"type":"suffix","text":"-ality","meaning":"명사형"}],"story":"찾아온 '손님(hospit)'을 따뜻하게 대접하고 보살피는 마음과 행동 → 환대.","example":{"en":"Thank you for your hospitality.","ko":"환대해 주셔서 감사합니다."}},
  {"word":"island","level":"middle","meaning":"섬","pronunciation":"/ˈaɪlənd/","parts":[{"type":"root","text":"is(insul)","meaning":"섬 (island)"},{"type":"root","text":"land","meaning":"땅 (land)"}],"story":"사방이 바다로 둘러싸여 홀로 떨어져 있는 땅 → 섬. (s는 묵음)","example":{"en":"A tropical island.","ko":"열대의 섬."}},
  {"word":"peninsula","level":"high","meaning":"반도","pronunciation":"/pəˈnɪnsələ/","parts":[{"type":"prefix","text":"pen-","meaning":"거의 (almost)"},{"type":"root","text":"insula","meaning":"섬 (island)"}],"story":"3면이 바다로 둘러싸여 육지에 붙어있기 때문에 '거의(pen)' '섬(insula)'과 다름없는 지형 → 반도.","example":{"en":"The Korean peninsula.","ko":"한반도."}},
  {"word":"insulate","level":"high","meaning":"단열하다, 절연하다","pronunciation":"/ˈɪnsəleɪt/","parts":[{"type":"root","text":"insul","meaning":"섬 (island)"},{"type":"suffix","text":"-ate","meaning":"만들다"}],"story":"열이나 전기가 통하지 않게 사물을 바다 한가운데의 '섬(insul)'처럼 고립시켜 '만들다(ate)'.","example":{"en":"Insulate the house.","ko":"집을 단열하다."}},
  {"word":"insulation","level":"high","meaning":"단열재, 절연","pronunciation":"/ˌɪnsəˈleɪʃn/","parts":[{"type":"root","text":"insulate","meaning":"단열하다"},{"type":"suffix","text":"-ion","meaning":"사물"}],"story":"열이 새어나가지 않게 막아주어 공간을 섬처럼 만들어주는 물건 → 단열재.","example":{"en":"Foam insulation.","ko":"폼 단열재."}},
  {"word":"insulator","level":"high","meaning":"절연체, 단열재","pronunciation":"/ˈɪnsəleɪtər/","parts":[{"type":"root","text":"insulate","meaning":"단열하다"},{"type":"suffix","text":"-or","meaning":"물체"}],"story":"전기나 열의 이동을 막아 '고립시키는(insulate)' 역할을 하는 '물체(or)'.","example":{"en":"Rubber is a good insulator.","ko":"고무는 좋은 절연체이다."}},
  {"word":"patient","level":"middle","meaning":"환자, 참을성 있는","pronunciation":"/ˈpeɪʃnt/","parts":[{"type":"root","text":"pati","meaning":"고통받다, 견디다"},{"type":"suffix","text":"-ent","meaning":"사람/형용사형"}],"story":"병의 고통을 묵묵히 '견뎌내는(pati)' '사람(ent)' → 환자. 잘 견디는 → 참을성 있는.","example":{"en":"Be patient.","ko":"참을성을 가져라."}},
  {"word":"patience","level":"middle","meaning":"인내, 참을성","pronunciation":"/ˈpeɪʃns/","parts":[{"type":"root","text":"pati","meaning":"견디다"},{"type":"suffix","text":"-ence","meaning":"명사형"}],"story":"힘들거나 짜증 나는 상황을 꾹 '견뎌내는(pati)' 마음의 상태 → 인내.","example":{"en":"Lose one's patience.","ko":"인내심을 잃다."}},
  {"word":"impatient","level":"middle","meaning":"참을성 없는, 성급한","pronunciation":"/ɪmˈpeɪʃnt/","parts":[{"type":"prefix","text":"im-","meaning":"아닌 (not)"},{"type":"root","text":"patient","meaning":"참을성 있는"}],"story":"시간이 지체되는 것을 '견디지(pati)' '못하는(im)' → 조바심 내는, 성급한.","example":{"en":"Don't be so impatient.","ko":"너무 성급하게 굴지 마."}},
  {"word":"compassion","level":"high","meaning":"연민, 동정","pronunciation":"/kəmˈpæʃn/","parts":[{"type":"prefix","text":"com-","meaning":"함께 (together)"},{"type":"root","text":"pass(pati)","meaning":"고통받다"},{"type":"suffix","text":"-ion","meaning":"명사형"}],"story":"타인의 아픔을 보고 나의 일처럼 '함께(com)' '고통을 느끼는(pass)' 감정 → 연민.","example":{"en":"Feel compassion for the poor.","ko":"가난한 사람들에게 연민을 느끼다."}},
  {"word":"compatible","level":"high","meaning":"호환되는, 마음이 맞는","pronunciation":"/kəmˈpætəbl/","parts":[{"type":"prefix","text":"com-","meaning":"함께 (together)"},{"type":"root","text":"pati","meaning":"견디다, 겪다"},{"type":"suffix","text":"-ible","meaning":"할 수 있는"}],"story":"두 사람이 '함께(com)' 어려움을 '견뎌낼(pati)' 수 있을 만큼 기계나 성격이 딱 맞는 → 호환되는.","example":{"en":"Compatible devices.","ko":"호환되는 기기들."}},
  {"word":"applaud","level":"high","meaning":"박수갈채를 보내다","pronunciation":"/əˈplɔːd/","parts":[{"type":"prefix","text":"ap(ad)-","meaning":"~에게 (to)"},{"type":"root","text":"plaud","meaning":"박수치다 (clap)"}],"story":"멋진 공연을 한 사람'에게(ap)' 큰 소리로 '박수를 쳐주다(plaud)'.","example":{"en":"The audience applauded.","ko":"관객들이 박수갈채를 보냈다."}},
  {"word":"applause","level":"middle","meaning":"박수","pronunciation":"/əˈplɔːz/","parts":[{"type":"prefix","text":"ap-","meaning":"~에게"},{"type":"root","text":"plaus","meaning":"박수치다"}],"story":"누군가에게 칭찬의 의미로 손바닥을 마주 '치는(plaus)' 행위.","example":{"en":"A big round of applause.","ko":"큰 박수."}},
  {"word":"explode","level":"middle","meaning":"폭발하다, 터지다","pronunciation":"/ɪkˈsploʊd/","parts":[{"type":"prefix","text":"ex-","meaning":"밖으로 (out)"},{"type":"root","text":"plode(plaud)","meaning":"치다 (strike)"}],"story":"과거 연극이 끝날 때 관객이 배우를 '밖으로(ex)' 쫓아내며 손뼉을 '치던(plode)' 것에서 유래 → 쾅 터지다.","example":{"en":"The bomb exploded.","ko":"폭탄이 폭발했다."}},
  {"word":"explosion","level":"middle","meaning":"폭발, 급증","pronunciation":"/ɪkˈsploʊʒn/","parts":[{"type":"root","text":"explode","meaning":"폭발하다"},{"type":"suffix","text":"-sion","meaning":"명사형"}],"story":"에너지가 밖으로 거칠게 쳐 나오면서 쾅 하고 터지는 현상.","example":{"en":"A gas explosion.","ko":"가스 폭발."}},
  {"word":"explosive","level":"high","meaning":"폭발성의, 폭약","pronunciation":"/ɪkˈsploʊsɪv/","parts":[{"type":"root","text":"explo(de)","meaning":"폭발하다"},{"type":"suffix","text":"-sive","meaning":"형용사/명사형"}],"story":"언제든 쾅 하고 '폭발할(explo)' 수 있는 성질을 가진 물질.","example":{"en":"Explosive materials.","ko":"폭발성 물질."}},
