[
  {"word":"tribute","level":"high","meaning":"헌사, 찬사, 공물","pronunciation":"/ˈtrɪbjuːt/","parts":[{"type":"root","text":"trib","meaning":"주다, 할당하다 (give)"},{"type":"suffix","text":"-ute","meaning":"명사형"}],"story":"존경하는 마음을 담아 바치거나(주거나) 부족의 추장에게 '주던(trib)' 것 → 헌사, 공물.","example":{"en":"Pay tribute to the victims.","ko":"희생자들에게 헌사를 바치다."}},
  {"word":"attribute","level":"middle","meaning":"~의 탓으로 돌리다, 속성","pronunciation":"/əˈtrɪbjuːt/","parts":[{"type":"prefix","text":"at(ad)-","meaning":"~에게 (to)"},{"type":"root","text":"trib","meaning":"주다 (give)"}],"story":"어떤 결과의 원인을 특정 대상'에게(at)' '주다(돌리다)'. 태어날 때 주어진 성질 → 속성.","example":{"en":"Attribute success to hard work.","ko":"성공을 노력 덕분으로 돌리다."}},
  {"word":"contribute","level":"middle","meaning":"기부하다, 기여하다","pronunciation":"/kənˈtrɪbjuːt/","parts":[{"type":"prefix","text":"con-","meaning":"함께 (together)"},{"type":"root","text":"trib","meaning":"주다 (give)"}],"story":"좋은 목표를 위해 여러 사람이 '함께(con)' 돈이나 노력을 보태어 '주다(trib)' → 기여하다.","example":{"en":"Contribute money to charity.","ko":"자선 단체에 돈을 기부하다."}},
  {"word":"distribute","level":"middle","meaning":"분배하다, 나누어 주다","pronunciation":"/dɪˈstrɪbjuːt/","parts":[{"type":"prefix","text":"dis-","meaning":"따로따로 (apart)"},{"type":"root","text":"trib","meaning":"주다 (give)"}],"story":"물건이나 돈을 모인 사람들에게 '각각 따로따로(dis)' '나누어 주다(trib)' → 분배하다.","example":{"en":"Distribute the flyers.","ko":"전단지를 나누어 주다."}},
  {"word":"tribe","level":"middle","meaning":"부족, 종족","pronunciation":"/traɪb/","parts":[{"type":"root","text":"trib","meaning":"나누다, 할당하다"}],"story":"고대 로마에서 영토를 '나누어' 다스리던 3개의 큰 집단에서 유래 → 부족.","example":{"en":"An indigenous tribe.","ko":"원주민 부족."}},
  {"word":"thrust","level":"middle","meaning":"밀치다, 찌르다","pronunciation":"/θrʌst/","parts":[{"type":"root","text":"thrus(trus)","meaning":"강하게 밀다 (push)"}],"story":"상대방을 향해 무기나 몸을 갑작스럽고 강하게 '밀어붙이다(thrus)' → 찌르다.","example":{"en":"Thrust a spear.","ko":"창을 찌르다."}},
  {"word":"intrude","level":"high","meaning":"침입하다, 방해하다","pronunciation":"/ɪnˈtruːd/","parts":[{"type":"prefix","text":"in-","meaning":"안으로 (into)"},{"type":"root","text":"trud","meaning":"밀다 (thrust)"}],"story":"허락 없이 남의 영역이나 대화 '안으로(in)' 거칠게 '밀고(trud)' 들어오다 → 방해하다.","example":{"en":"Intrude on someone's privacy.","ko":"누군가의 사생활을 침해하다."}},
  {"word":"extrude","level":"high","meaning":"밀어내다, 짜내다","pronunciation":"/ɪkˈstruːd/","parts":[{"type":"prefix","text":"ex-","meaning":"밖으로 (out)"},{"type":"root","text":"trud","meaning":"밀다 (thrust)"}],"story":"치약이나 튜브에 든 것을 '밖으로(ex)' 꾹 눌러서 '밀어내다(trud)'.","example":{"en":"Extrude toothpaste.","ko":"치약을 짜내다."}},
  {"word":"protrude","level":"high","meaning":"튀어나오다, 돌출되다","pronunciation":"/proʊˈtruːd/","parts":[{"type":"prefix","text":"pro-","meaning":"앞으로 (forward)"},{"type":"root","text":"trud","meaning":"밀다 (thrust)"}],"story":"어떤 물체의 표면이 남들보다 '앞으로(pro)' 쑥 '밀고(trud)' 나와 있다 → 튀어나오다.","example":{"en":"Protruding teeth.","ko":"튀어나온 치아 (뻐드렁니)."}},
  {"word":"obtrusive","level":"high","meaning":"눈에 띄는, 참견하는","pronunciation":"/əbˈtruːsɪv/","parts":[{"type":"prefix","text":"ob-","meaning":"~쪽으로, 맞서서"},{"type":"root","text":"trus","meaning":"밀다 (push)"},{"type":"suffix","text":"-ive","meaning":"형용사형"}],"story":"자기 자신을 남의 시선 '쪽으로(ob)' 무리하게 '밀어붙여서(trus)' 꼴불견인 → 참견하는.","example":{"en":"An obtrusive color.","ko":"눈에 거슬리게 튀는 색상."}},
  {"word":"disturb","level":"middle","meaning":"방해하다, 어지럽히다","pronunciation":"/dɪˈstɜːrb/","parts":[{"type":"prefix","text":"dis-","meaning":"완전히"},{"type":"root","text":"turb","meaning":"어지럽히다 (disorder)"}],"story":"잔잔한 호수나 조용한 상태를 '완전히(dis)' 휘저어 '어지럽히다(turb)' → 방해하다.","example":{"en":"Do not disturb.","ko":"방해하지 마시오."}},
  {"word":"perturb","level":"high","meaning":"동요하게 하다, 불안하게 하다","pronunciation":"/pərˈtɜːrb/","parts":[{"type":"prefix","text":"per-","meaning":"철저히 (thoroughly)"},{"type":"root","text":"turb","meaning":"어지럽히다 (disorder)"}],"story":"마음속을 '철저하게(per)' 흔들어서 평정심을 '어지럽히다(turb)' → 불안하게 하다.","example":{"en":"He was unperturbed by the news.","ko":"그는 그 뉴스에도 동요하지 않았다."}},
  {"word":"turbulent","level":"high","meaning":"난기류의, 격동의","pronunciation":"/ˈtɜːrbjələnt/","parts":[{"type":"root","text":"turb","meaning":"어지럽히다 (disorder)"},{"type":"suffix","text":"-ulent","meaning":"가득한"}],"story":"바람이나 사회의 상태가 극도로 '어지럽고(turb)' 요동치는 상태로 가득한 → 격동의.","example":{"en":"A turbulent flight.","ko":"난기류가 심한 비행."}},
  {"word":"turbine","level":"high","meaning":"터빈 (회전기기)","pronunciation":"/ˈtɜːrbaɪn/","parts":[{"type":"root","text":"turb","meaning":"소용돌이 (whirl)"},{"type":"suffix","text":"-ine","meaning":"기계"}],"story":"물이나 가스를 강하게 뿜어내어 '소용돌이치며(turb)' 돌아가는 기계 → 발전용 터빈.","example":{"en":"A wind turbine.","ko":"풍력 터빈."}},
  {"word":"trouble","level":"middle","meaning":"문제, 곤란, 괴롭히다","pronunciation":"/ˈtrʌbl/","parts":[{"type":"root","text":"troub(turb)","meaning":"어지럽히다 (disorder)"},{"type":"suffix","text":"-le","meaning":"명사형"}],"story":"우리의 평온한 일상을 휘저어 '어지럽히는(troub)' 골치 아픈 사건 → 문제.","example":{"en":"I am in trouble.","ko":"난 곤란한 상황에 처했어."}},
  {"word":"use","level":"middle","meaning":"사용하다, 용도","pronunciation":"/juːz/","parts":[{"type":"root","text":"use","meaning":"사용하다 (utilize)"}],"story":"어떤 목적을 위해 도구나 물건을 다루다.","example":{"en":"Use a computer.","ko":"컴퓨터를 사용하다."}},
  {"word":"useful","level":"middle","meaning":"유용한, 쓸모 있는","pronunciation":"/ˈjuːsfl/","parts":[{"type":"root","text":"use","meaning":"사용하다"},{"type":"suffix","text":"-ful","meaning":"가득한"}],"story":"생활 속에서 '사용할(use)' 수 있는 곳이 '많은(ful)' → 쓸모 있는.","example":{"en":"A useful tool.","ko":"유용한 도구."}},
  {"word":"utility","level":"middle","meaning":"유용성, 공익사업 (전기/수도)","pronunciation":"/juːˈtɪləti/","parts":[{"type":"root","text":"util(use)","meaning":"사용하다"},{"type":"suffix","text":"-ity","meaning":"명사형"}],"story":"사람들이 널리 '사용할(util)' 수 있는 국가의 인프라(가스, 전기 등) → 공익사업.","example":{"en":"Pay the utility bills.","ko":"공과금을 내다."}},
  {"word":"utilize","level":"high","meaning":"활용하다, 이용하다","pronunciation":"/ˈjuːtəlaɪz/","parts":[{"type":"root","text":"util","meaning":"사용하다"},{"type":"suffix","text":"-ize","meaning":"동사형"}],"story":"주어진 자원이나 기회를 버리지 않고 최대한 효율적으로 '사용하다(util)'.","example":{"en":"Utilize solar energy.","ko":"태양 에너지를 활용하다."}},
  {"word":"abuse","level":"middle","meaning":"남용하다, 학대하다","pronunciation":"/əˈbjuːs/","parts":[{"type":"prefix","text":"ab-","meaning":"잘못되게 (away/wrong)"},{"type":"root","text":"use","meaning":"사용하다"}],"story":"권력이나 약자를 올바르지 않게 '잘못(ab)' '사용하다(use)' → 학대하다, 남용하다.","example":{"en":"Child abuse.","ko":"아동 학대."}},
  {"word":"develop","level":"middle","meaning":"개발하다, 발달하다","pronunciation":"/dɪˈveləp/","parts":[{"type":"prefix","text":"de-","meaning":"반대로, 풀다 (un-)"},{"type":"root","text":"velop","meaning":"싸다, 덮다 (wrap)"}],"story":"무언가를 겹겹이 '싸고(velop)' 있던 껍질을 '풀어헤쳐서(de)' 세상에 내놓다 → 개발하다.","example":{"en":"Develop a new software.","ko":"새로운 소프트웨어를 개발하다."}},
  {"word":"envelop","level":"high","meaning":"감싸다, 뒤덮다","pronunciation":"/ɪnˈveləp/","parts":[{"type":"prefix","text":"en-","meaning":"안에 (in)"},{"type":"root","text":"velop","meaning":"싸다 (wrap)"}],"story":"어떤 것을 내 품 '안으로(en)' 보이지 않게 완전히 '싸버리다(velop)' → 감싸다.","example":{"en":"Enveloped in fog.","ko":"안개에 뒤덮인."}},
  {"word":"envelope","level":"middle","meaning":"봉투","pronunciation":"/ˈenvəloʊp/","parts":[{"type":"prefix","text":"en-","meaning":"안으로"},{"type":"root","text":"velop","meaning":"싸다"},{"type":"suffix","text":"-e","meaning":"명사형"}],"story":"중요한 편지나 서류를 '안으로(en)' 넣고 '포장하는(velop)' 종이 → 편지 봉투.","example":{"en":"Put a letter in an envelope.","ko":"편지를 봉투에 넣다."}},
  {"word":"development","level":"middle","meaning":"발달, 성장, 개발","pronunciation":"/dɪˈveləpmənt/","parts":[{"type":"root","text":"develop","meaning":"개발하다"},{"type":"suffix","text":"-ment","meaning":"명사형"}],"story":"감춰져 있던 잠재력이 세상 밖으로 드러나 자라나는 상태.","example":{"en":"Economic development.","ko":"경제 발전."}},
  {"word":"developer","level":"middle","meaning":"개발자","pronunciation":"/dɪˈveləpər/","parts":[{"type":"root","text":"develop","meaning":"개발하다"},{"type":"suffix","text":"-er","meaning":"사람"}],"story":"새로운 소프트웨어나 부동산(토지)을 '개발하는(develop)' '사람(er)'.","example":{"en":"A software developer.","ko":"소프트웨어 개발자."}},
  {"word":"verge","level":"high","meaning":"가장자리, 직전","pronunciation":"/vɜːrdʒ/","parts":[{"type":"root","text":"verg","meaning":"기울다 (bend/turn)"}],"story":"평평한 땅이 낭떠러지로 '기울어지기(verg)' 시작하는 끝부분 → 가장자리, 폭발 직전.","example":{"en":"On the verge of tears.","ko":"울기 직전인."}},
  {"word":"converge","level":"high","meaning":"모이다, 수렴하다","pronunciation":"/kənˈvɜːrdʒ/","parts":[{"type":"prefix","text":"con-","meaning":"함께 (together)"},{"type":"root","text":"verg","meaning":"기울다 (bend)"}],"story":"여러 갈래의 선이나 의견이 한 점을 향해 '함께(con)' '기울어지다(verg)' → 모이다.","example":{"en":"The roads converge here.","ko":"그 길들은 여기서 모인다."}},
  {"word":"diverge","level":"high","meaning":"갈라지다, (의견이) 나뉘다","pronunciation":"/daɪˈvɜːrdʒ/","parts":[{"type":"prefix","text":"di-","meaning":"두 갈래로 (apart)"},{"type":"root","text":"verg","meaning":"기울다 (bend)"}],"story":"한 점에서 출발한 길이나 생각이 '두 갈래로(di)' 찢어져서 '기울다(verg)' → 나뉘다.","example":{"en":"Our paths diverged.","ko":"우리의 길은 갈라졌다."}},
  {"word":"convergence","level":"high","meaning":"수렴, 융합","pronunciation":"/kənˈvɜːrdʒəns/","parts":[{"type":"root","text":"converge","meaning":"모이다"},{"type":"suffix","text":"-ence","meaning":"명사형"}],"story":"다양한 기술이나 정보가 한곳으로 모여 합쳐지는 현상 → 디지털 융합.","example":{"en":"Media convergence.","ko":"미디어 융합."}},
  {"word":"divergent","level":"high","meaning":"분기하는, 서로 다른","pronunciation":"/daɪˈvɜːrdʒənt/","parts":[{"type":"root","text":"diverge","meaning":"갈라지다"},{"type":"suffix","text":"-ent","meaning":"형용사형"}],"story":"생각이나 형태가 한 점에 머물지 않고 여러 갈래로 뻗어나가는 → 서로 다른.","example":{"en":"Divergent opinions.","ko":"서로 엇갈리는(다른) 의견들."}},
  {"word":"vest","level":"middle","meaning":"조끼, 권리를 부여하다","pronunciation":"/vest/","parts":[{"type":"root","text":"vest","meaning":"옷을 입다 (clothe)"}],"story":"1. 몸에 입는 겉옷(조끼). 2. 과거 성직자에게 권위의 상징으로 특별한 '옷을 입혀주던' 것에서 유래 → 권리를 주다.","example":{"en":"A bulletproof vest.","ko":"방탄조끼."}},
  {"word":"invest","level":"middle","meaning":"투자하다","pronunciation":"/ɪnˈvest/","parts":[{"type":"prefix","text":"in-","meaning":"안에 (in)"},{"type":"root","text":"vest","meaning":"옷을 입히다 (clothe)"}],"story":"새로운 사업에 내 자본이라는 든든한 '옷(vest)'을 '입혀주다(in)' → 투자하다.","example":{"en":"Invest money in stocks.","ko":"주식에 돈을 투자하다."}},
  {"word":"investment","level":"middle","meaning":"투자, 투자금","pronunciation":"/ɪnˈvestmənt/","parts":[{"type":"root","text":"invest","meaning":"투자하다"},{"type":"suffix","text":"-ment","meaning":"명사형"}],"story":"미래의 이익을 위해 자본이나 시간을 투입하는 행위.","example":{"en":"A profitable investment.","ko":"수익성 있는 투자."}},
  {"word":"divest","level":"high","meaning":"벗기다, 박탈하다","pronunciation":"/daɪˈvest/","parts":[{"type":"prefix","text":"di(s)-","meaning":"분리하여, 멀리"},{"type":"root","text":"vest","meaning":"옷 (clothe)"}],"story":"입고 있던 옷이나 권력을 몸에서 '분리하여(di)' 강제로 '벗기다(vest)' → 빼앗다.","example":{"en":"Divest him of his power.","ko":"그에게서 권력을 박탈하다."}},
  {"word":"travesty","level":"high","meaning":"희화화, 조롱","pronunciation":"/ˈtrævəsti/","parts":[{"type":"prefix","text":"trans-","meaning":"바꾸어 (across)"},{"type":"root","text":"vest","meaning":"옷을 입다 (clothe)"},{"type":"suffix","text":"-y","meaning":"명사형"}],"story":"남자를 여자처럼 웃기게 옷을 '바꿔(trans)' '입혀서(vest)' 놀리는 연극 → 조롱.","example":{"en":"A travesty of justice.","ko":"정의에 대한 조롱 (우스꽝스러운 재판)."}},
  {"word":"voluntary","level":"middle","meaning":"자발적인, 자원봉사의","pronunciation":"/ˈvɑːlənteri/","parts":[{"type":"root","text":"volunt","meaning":"자유 의지 (will)"},{"type":"suffix","text":"-ary","meaning":"형용사형"}],"story":"누가 시켜서가 아니라 나 자신의 '의지(volunt)'로 하는 → 자발적인.","example":{"en":"Voluntary work.","ko":"자원 봉사."}},
  {"word":"volunteer","level":"middle","meaning":"자원봉사자, 자원하다","pronunciation":"/ˌvɑːlənˈtɪr/","parts":[{"type":"root","text":"volunt","meaning":"의지 (will)"},{"type":"suffix","text":"-eer","meaning":"사람"}],"story":"스스로의 '의지(volunt)'를 가지고 나서서 돕는 '사람(eer)' → 자원봉사자.","example":{"en":"Volunteer for the event.","ko":"행사에 자원하다."}},
  {"word":"benevolent","level":"high","meaning":"자비로운, 친절한","pronunciation":"/bəˈnevələnt/","parts":[{"type":"prefix","text":"bene-","meaning":"좋은 (good)"},{"type":"root","text":"vol","meaning":"의지 (will)"},{"type":"suffix","text":"-ent","meaning":"형용사형"}],"story":"타인을 돕고 싶어 하는 '선하고(bene)' '좋은 의지(vol)'를 가진 → 자비로운.","example":{"en":"A benevolent smile.","ko":"자애로운 미소."}},
  {"word":"malevolent","level":"high","meaning":"악의적인, 사악한","pronunciation":"/məˈlevələnt/","parts":[{"type":"prefix","text":"male-","meaning":"나쁜 (bad)"},{"type":"root","text":"vol","meaning":"의지 (will)"},{"type":"suffix","text":"-ent","meaning":"형용사형"}],"story":"남이 잘못되기를 바라는 '나쁘고(male)' 사악한 '의지(vol)'를 품은 → 악의적인.","example":{"en":"A malevolent look.","ko":"악의에 찬 눈빛."}},
  {"word":"volition","level":"high","meaning":"자유 의지, 결단력","pronunciation":"/voʊˈlɪʃn/","parts":[{"type":"root","text":"vol","meaning":"의지 (will)"},{"type":"suffix","text":"-ition","meaning":"명사형"}],"story":"스스로 생각하고 결정할 수 있는 마음의 힘 → 자유 의지.","example":{"en":"Of his own volition.","ko":"그 자신의 의지로 (자발적으로)."}},
  {"word":"devour","level":"high","meaning":"게걸스럽게 먹다, 집어삼키다","pronunciation":"/dɪˈvaʊər/","parts":[{"type":"prefix","text":"de-","meaning":"완전히 (completely)"},{"type":"root","text":"vour(vor)","meaning":"먹다 (eat)"}],"story":"배가 고파서 눈앞의 음식을 '완전히(de)' 마구 '먹어치우다(vour)'.","example":{"en":"Devour a whole pizza.","ko":"피자 한 판을 게걸스럽게 먹어치우다."}},
  {"word":"carnivore","level":"high","meaning":"육식 동물","pronunciation":"/ˈkɑːrnɪvɔːr/","parts":[{"type":"root","text":"carni","meaning":"고기 (flesh)"},{"type":"root","text":"vore","meaning":"먹는 것 (eat)"}],"story":"풀 대신 사냥을 해서 '고기(carni)'만 '먹는(vore)' 동물 → 육식 동물.","example":{"en":"Lions are carnivores.","ko":"사자는 육식 동물이다."}},
  {"word":"herbivore","level":"high","meaning":"초식 동물","pronunciation":"/ˈhɜːrbɪvɔːr/","parts":[{"type":"root","text":"herbi","meaning":"풀, 허브 (plant)"},{"type":"root","text":"vore","meaning":"먹는 것 (eat)"}],"story":"다른 동물을 죽이지 않고 오직 '풀(herbi)'만 뜯어 '먹는(vore)' 동물 → 초식 동물.","example":{"en":"Cows are herbivores.","ko":"소는 초식 동물이다."}},
  {"word":"omnivore","level":"high","meaning":"잡식 동물","pronunciation":"/ˈɑːmnɪvɔːr/","parts":[{"type":"prefix","text":"omni-","meaning":"모든 (all)"},{"type":"root","text":"vore","meaning":"먹다 (eat)"}],"story":"풀과 고기를 가리지 않고 '모든(omni)' 것을 다 '먹어치우는(vore)' 존재 → 잡식 동물.","example":{"en":"Humans are omnivores.","ko":"인간은 잡식 동물이다."}},
  {"word":"voracious","level":"high","meaning":"식욕이 왕성한, 탐욕스러운","pronunciation":"/vəˈreɪʃəs/","parts":[{"type":"root","text":"vor","meaning":"먹다 (eat)"},{"type":"suffix","text":"-acious","meaning":"가득한"}],"story":"배가 채워지지 않아 무언가를 '먹으려는(vor)' 욕구가 '가득한(acious)'.","example":{"en":"A voracious reader.","ko":"엄청난 독서광 (책을 게걸스럽게 읽는 사람)."}},
  {"word":"zoo","level":"middle","meaning":"동물원","pronunciation":"/zuː/","parts":[{"type":"root","text":"zoo","meaning":"동물 (animal)"}],"story":"세계 각지에서 데려온 '동물(zoo)'들을 한곳에 모아둔 장소.","example":{"en":"Visit the zoo.","ko":"동물원에 가다."}},
  {"word":"zoology","level":"high","meaning":"동물학","pronunciation":"/zoʊˈɑːlədʒi/","parts":[{"type":"root","text":"zoo","meaning":"동물 (animal)"},{"type":"suffix","text":"-logy","meaning":"학문"}],"story":"다양한 '동물(zoo)'의 생태와 진화를 전문적으로 연구하는 '학문(logy)'.","example":{"en":"Study zoology.","ko":"동물학을 공부하다."}},
  {"word":"zodiac","level":"high","meaning":"황도십이궁 (별자리)","pronunciation":"/ˈzoʊdiæk/","parts":[{"type":"root","text":"zodi(zoo)","meaning":"동물 (animal)"},{"type":"suffix","text":"-ac","meaning":"관련된 것"}],"story":"별자리들 중 12개가 사자, 게, 황소 등 '동물(zodi)' 모양을 하고 있는 것에서 유래.","example":{"en":"Zodiac signs.","ko":"별자리 (황도십이궁)."}},
  {"word":"zoologist","level":"high","meaning":"동물학자","pronunciation":"/zoʊˈɑːlədʒɪst/","parts":[{"type":"root","text":"zoology","meaning":"동물학"},{"type":"suffix","text":"-ist","meaning":"전문가"}],"story":"동물학(zoology)을 평생에 걸쳐 연구하는 '사람(ist)'.","example":{"en":"A famous zoologist.","ko":"유명한 동물학자."}},
  {"word":"protozoa","level":"high","meaning":"원생동물 (아메바 등)","pronunciation":"/ˌproʊtəˈzoʊə/","parts":[{"type":"prefix","text":"proto-","meaning":"최초의 (first)"},{"type":"root","text":"zoa","meaning":"동물 (animal)"}],"story":"지구상에 '가장 처음(proto)'으로 태어난 아주 단순한 세포 형태의 '동물(zoa)'.","example":{"en":"Microscopic protozoa.","ko":"현미경으로 보이는 원생동물."}}
