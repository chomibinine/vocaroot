[
  {"word":"respect","level":"middle","meaning":"존경하다, 존중","pronunciation":"/rɪˈspekt/","parts":[{"type":"prefix","text":"re-","meaning":"다시 (again)"},{"type":"root","text":"spect","meaning":"보다 (look)"}],"story":"누군가를 '다시(re)' 돌아보게 될 만큼 훌륭하다고 여겨 계속 '보다(spect)' → 존경하다.","example":{"en":"We should respect our elders.","ko":"우리는 어른들을 존경해야 한다."}},
  {"word":"inspect","level":"middle","meaning":"검사하다","pronunciation":"/ɪnˈspekt/","parts":[{"type":"prefix","text":"in-","meaning":"안으로 (into)"},{"type":"root","text":"spect","meaning":"보다 (look)"}],"story":"어떤 것의 '안(in)'을 자세히 들여다 '보다(spect)' → 검사하다.","example":{"en":"The officials will inspect the building.","ko":"관계자들이 건물을 검사할 것이다."}},
  {"word":"expect","level":"middle","meaning":"기대하다, 예상하다","pronunciation":"/ɪkˈspekt/","parts":[{"type":"prefix","text":"ex-","meaning":"밖으로 (out)"},{"type":"root","text":"spect","meaning":"보다 (look)"}],"story":"일이 일어나기를 '밖(ex)'을 내다 '보며(spect)' 기다리다 → 기대하다.","example":{"en":"I expect to see you again.","ko":"너를 다시 보기를 기대해."}},
  {"word":"prospect","level":"high","meaning":"전망, 가능성","pronunciation":"/ˈprɑːspekt/","parts":[{"type":"prefix","text":"pro-","meaning":"앞으로 (forward)"},{"type":"root","text":"spect","meaning":"보다 (look)"}],"story":"'앞(pro)'의 미래 상황을 내다 '보는(spect)' 것 → 전망.","example":{"en":"There is no prospect of success.","ko":"성공할 전망이 없다."}},
  {"word":"suspect","level":"high","meaning":"의심하다, 용의자","pronunciation":"/səˈspekt/","parts":[{"type":"prefix","text":"sus-","meaning":"아래에서 (under)"},{"type":"root","text":"spect","meaning":"보다 (look)"}],"story":"겉으로 드러나지 않게 '아래에서(sus)' 몰래 훔쳐 '보다(spect)' → 의심하다.","example":{"en":"The police suspect him of murder.","ko":"경찰은 그를 살인 혐의로 의심하고 있다."}},
  {"word":"perspective","level":"high","meaning":"관점, 원근법","pronunciation":"/pərˈspektɪv/","parts":[{"type":"prefix","text":"per-","meaning":"꿰뚫어 (through)"},{"type":"root","text":"spect","meaning":"보다 (look)"}],"story":"사물의 본질을 '꿰뚫어(per)' '보는(spect)' 방식 → 관점.","example":{"en":"We need a new perspective.","ko":"우리는 새로운 관점이 필요하다."}},
  {"word":"reject","level":"middle","meaning":"거절하다","pronunciation":"/rɪˈdʒekt/","parts":[{"type":"prefix","text":"re-","meaning":"뒤로 (back)"},{"type":"root","text":"ject","meaning":"던지다 (throw)"}],"story":"받은 것을 다시 '뒤로(re)' '던져버리다(ject)' → 거절하다.","example":{"en":"He rejected their offer.","ko":"그는 그들의 제안을 거절했다."}},
  {"word":"project","level":"middle","meaning":"계획, 투사하다","pronunciation":"/ˈprɑːdʒekt/","parts":[{"type":"prefix","text":"pro-","meaning":"앞으로 (forward)"},{"type":"root","text":"ject","meaning":"던지다 (throw)"}],"story":"생각이나 빛을 '앞으로(pro)' '던지다(ject)' → 계획하다.","example":{"en":"The project was a great success.","ko":"그 프로젝트는 큰 성공이었다."}},
  {"word":"subject","level":"middle","meaning":"주제, 과목","pronunciation":"/ˈsʌbdʒɪkt/","parts":[{"type":"prefix","text":"sub-","meaning":"아래에 (under)"},{"type":"root","text":"ject","meaning":"던지다 (throw)"}],"story":"논의의 '아래로(sub)' '던져진(ject)' 것 → 주제, 과목.","example":{"en":"Math is my favorite subject.","ko":"수학은 내가 가장 좋아하는 과목이다."}},
  {"word":"inject","level":"high","meaning":"주입하다, 주사하다","pronunciation":"/ɪnˈdʒekt/","parts":[{"type":"prefix","text":"in-","meaning":"안으로 (into)"},{"type":"root","text":"ject","meaning":"던지다 (throw)"}],"story":"약물을 몸 '안으로(in)' '던져 넣다(ject)' → 주사하다.","example":{"en":"The doctor will inject the medicine.","ko":"의사가 약을 주사할 것이다."}},
  {"word":"object","level":"high","meaning":"반대하다, 목적","pronunciation":"/əbˈdʒekt/","parts":[{"type":"prefix","text":"ob-","meaning":"~에 맞서 (against)"},{"type":"root","text":"ject","meaning":"던지다 (throw)"}],"story":"의견에 '맞서서(ob)' 이의를 '던지다(ject)' → 반대하다.","example":{"en":"I object to your plan.","ko":"나는 너의 계획에 반대한다."}},
  {"word":"predict","level":"middle","meaning":"예측하다","pronunciation":"/prɪˈdɪkt/","parts":[{"type":"prefix","text":"pre-","meaning":"미리 (before)"},{"type":"root","text":"dict","meaning":"말하다 (say)"}],"story":"일어나지 않은 일을 '미리(pre)' '말하다(dict)' → 예측하다.","example":{"en":"It is hard to predict the future.","ko":"미래를 예측하는 것은 어렵다."}},
  {"word":"dictionary","level":"middle","meaning":"사전","pronunciation":"/ˈdɪkʃəneri/","parts":[{"type":"root","text":"dict","meaning":"말하다 (say)"},{"type":"suffix","text":"-ary","meaning":"장소"}],"story":"'말(dict)'이나 단어들을 모아둔 장소 → 사전.","example":{"en":"Look it up in the dictionary.","ko":"사전에서 찾아봐."}},
  {"word":"dictate","level":"high","meaning":"지시하다, 받아쓰게 하다","pronunciation":"/ˈdɪkteɪt/","parts":[{"type":"root","text":"dict","meaning":"말하다 (say)"},{"type":"suffix","text":"-ate","meaning":"동사형"}],"story":"다른 사람이 쓰도록 큰 소리로 '말하다(dict)' → 지시하다.","example":{"en":"The teacher dictated the words.","ko":"선생님이 단어들을 불러주셨다."}},
  {"word":"contradict","level":"high","meaning":"반박하다","pronunciation":"/ˌkɑːntrəˈdɪkt/","parts":[{"type":"prefix","text":"contra-","meaning":"반대로 (against)"},{"type":"root","text":"dict","meaning":"말하다 (say)"}],"story":"상대방의 의견에 '반대하여(contra)' '말하다(dict)' → 반박하다.","example":{"en":"His actions contradict his words.","ko":"그의 행동은 그의 말과 모순된다."}},
  {"word":"addict","level":"high","meaning":"중독자","pronunciation":"/ˈædɪkt/","parts":[{"type":"prefix","text":"ad-","meaning":"~에게 (to)"},{"type":"root","text":"dict","meaning":"말하다 (say)"}],"story":"무언가에 넘어가겠다고 '선언(말)하다(dict)' → 중독되다.","example":{"en":"He is a smartphone addict.","ko":"그는 스마트폰 중독자이다."}},
  {"word":"attract","level":"middle","meaning":"끌어당기다, 매혹하다","pronunciation":"/əˈtrækt/","parts":[{"type":"prefix","text":"at-","meaning":"~쪽으로 (to)"},{"type":"root","text":"tract","meaning":"끌다 (pull)"}],"story":"사람들의 관심이나 마음을 자기 '쪽으로(at)' '끌어당기다(tract)' → 매혹하다.","example":{"en":"Magnets attract iron.","ko":"자석은 철을 끌어당긴다."}},
  {"word":"contract","level":"middle","meaning":"계약, 수축하다","pronunciation":"/ˈkɑːntrækt/","parts":[{"type":"prefix","text":"con-","meaning":"함께 (together)"},{"type":"root","text":"tract","meaning":"끌다 (pull)"}],"story":"서로의 의견을 '함께(con)' '끌어와서(tract)' 맺는 것 → 계약.","example":{"en":"They signed a contract.","ko":"그들은 계약서에 서명했다."}},
  {"word":"distract","level":"high","meaning":"산만하게 하다","pronunciation":"/dɪˈstrækt/","parts":[{"type":"prefix","text":"dis-","meaning":"멀리 (away)"},{"type":"root","text":"tract","meaning":"끌다 (pull)"}],"story":"정신을 '멀리(dis)' 다른 곳으로 '끌고 가다(tract)' → 산만하게 하다.","example":{"en":"Don't distract me.","ko":"내 주의를 분산시키지 마."}},
  {"word":"extract","level":"high","meaning":"추출하다","pronunciation":"/ɪkˈstrækt/","parts":[{"type":"prefix","text":"ex-","meaning":"밖으로 (out)"},{"type":"root","text":"tract","meaning":"끌다 (pull)"}],"story":"안에 있는 것을 '밖으로(ex)' '끌어내다(tract)' → 추출하다.","example":{"en":"They extract oil.","ko":"그들은 석유를 추출한다."}},
  {"word":"abstract","level":"high","meaning":"추상적인","pronunciation":"/ˈæbstrækt/","parts":[{"type":"prefix","text":"abs-","meaning":"떨어져서 (away)"},{"type":"root","text":"tract","meaning":"끌다 (pull)"}],"story":"핵심 요소만 '따로 떼어내어(abs)' '끌어낸(tract)' 것 → 추상적인.","example":{"en":"Abstract art is hard.","ko":"추상미술은 어렵다."}},
  {"word":"transport","level":"middle","meaning":"운송하다","pronunciation":"/trænsˈpɔːrt/","parts":[{"type":"prefix","text":"trans-","meaning":"가로질러 (across)"},{"type":"root","text":"port","meaning":"나르다 (carry)"}],"story":"지역을 '가로질러(trans)' 물건을 '나르다(port)' → 수송하다.","example":{"en":"Goods are transported.","ko":"상품들은 운송된다."}},
  {"word":"export","level":"middle","meaning":"수출하다","pronunciation":"/ˈekspɔːrt/","parts":[{"type":"prefix","text":"ex-","meaning":"밖으로 (out)"},{"type":"root","text":"port","meaning":"나르다 (carry)"}],"story":"물건을 나라 '밖으로(ex)' '나르다(port)' → 수출하다.","example":{"en":"We export rice.","ko":"우리는 쌀을 수출한다."}},
  {"word":"import","level":"middle","meaning":"수입하다","pronunciation":"/ˈɪmpɔːrt/","parts":[{"type":"prefix","text":"im-","meaning":"안으로 (in)"},{"type":"root","text":"port","meaning":"나르다 (carry)"}],"story":"물건을 나라 '안으로(im)' '나르다(port)' → 수입하다.","example":{"en":"The country imports oil.","ko":"그 나라는 석유를 수입한다."}},
  {"word":"support","level":"middle","meaning":"지지하다","pronunciation":"/səˈpɔːrt/","parts":[{"type":"prefix","text":"sup-","meaning":"아래에서 (under)"},{"type":"root","text":"port","meaning":"나르다 (carry)"}],"story":"무거운 짐을 '아래에서(sup)' 받쳐서 '나르다(port)' → 지지하다.","example":{"en":"My family supports me.","ko":"내 가족은 나를 지지한다."}},
  {"word":"portable","level":"high","meaning":"휴대용의","pronunciation":"/ˈpɔːrtəbl/","parts":[{"type":"root","text":"port","meaning":"나르다 (carry)"},{"type":"suffix","text":"-able","meaning":"할 수 있는"}],"story":"'운반(port)' '할 수 있는(able)' → 휴대용의.","example":{"en":"I bought a portable charger.","ko":"나는 휴대용 충전기를 샀다."}},
  {"word":"prefer","level":"middle","meaning":"선호하다","pronunciation":"/prɪˈfɜːr/","parts":[{"type":"prefix","text":"pre-","meaning":"미리, 앞에 (before)"},{"type":"root","text":"fer","meaning":"나르다 (carry)"}],"story":"여러 선택지 중 하나를 내 '앞으로(pre)' '가져오다(fer)' → 선호하다.","example":{"en":"I prefer tea to coffee.","ko":"나는 커피보다 차를 선호한다."}},
  {"word":"suffer","level":"middle","meaning":"고통받다","pronunciation":"/ˈsʌfər/","parts":[{"type":"prefix","text":"suf-","meaning":"아래에서 (under)"},{"type":"root","text":"fer","meaning":"나르다 (bear)"}],"story":"무거운 짐을 '아래에서(suf)' 짊어지고 '견디다(fer)' → 고통받다.","example":{"en":"He suffers from a cold.","ko":"그는 감기로 고통받고 있다."}},
  {"word":"refer","level":"high","meaning":"언급하다, 참조하다","pronunciation":"/rɪˈfɜːr/","parts":[{"type":"prefix","text":"re-","meaning":"다시 (back)"},{"type":"root","text":"fer","meaning":"나르다 (carry)"}],"story":"관심을 책 '쪽으로(re)' 다시 '가져가게 하다(fer)' → 참조하다.","example":{"en":"Please refer to page 10.","ko":"10페이지를 참조하세요."}},
  {"word":"transfer","level":"high","meaning":"이동하다, 환승하다","pronunciation":"/trænsˈfɜːr/","parts":[{"type":"prefix","text":"trans-","meaning":"가로질러 (across)"},{"type":"root","text":"fer","meaning":"나르다 (carry)"}],"story":"이곳에서 저곳으로 '가로질러(trans)' 몸을 '나르다(fer)' → 환승하다.","example":{"en":"I have to transfer here.","ko":"나는 여기서 환승해야 한다."}},
  {"word":"confer","level":"high","meaning":"협의하다, 수여하다","pronunciation":"/kənˈfɜːr/","parts":[{"type":"prefix","text":"con-","meaning":"함께 (together)"},{"type":"root","text":"fer","meaning":"가져오다 (bring)"}],"story":"사람들이 '함께(con)' 의견을 '가져와서(fer)' 나누다 → 협의하다.","example":{"en":"They conferred about it.","ko":"그들은 그것에 대해 협의했다."}},
  {"word":"form","level":"middle","meaning":"형태, 형성하다","pronunciation":"/fɔːrm/","parts":[{"type":"root","text":"form","meaning":"형태 (shape)"}],"story":"어떤 것의 '형태(form)'를 만들다 → 형성하다.","example":{"en":"Ice forms at 0 degrees.","ko":"얼음은 0도에서 형성된다."}},
  {"word":"inform","level":"middle","meaning":"알리다","pronunciation":"/ɪnˈfɔːrm/","parts":[{"type":"prefix","text":"in-","meaning":"안에 (into)"},{"type":"root","text":"form","meaning":"형태 (shape)"}],"story":"머릿'속에(in)' 사실의 '형태(form)'를 만들어주다 → 알리다.","example":{"en":"Please inform me.","ko":"내게 알려주세요."}},
  {"word":"transform","level":"high","meaning":"변형시키다","pronunciation":"/trænsˈfɔːrm/","parts":[{"type":"prefix","text":"trans-","meaning":"넘어서 (across)"},{"type":"root","text":"form","meaning":"형태 (shape)"}],"story":"기존의 '형태(form)'를 '넘어서(trans)' 바꾸다 → 변형시키다.","example":{"en":"It transformed into a butterfly.","ko":"나비로 변했다."}},
  {"word":"reform","level":"high","meaning":"개혁하다","pronunciation":"/rɪˈfɔːrm/","parts":[{"type":"prefix","text":"re-","meaning":"다시 (again)"},{"type":"root","text":"form","meaning":"형태 (shape)"}],"story":"잘못된 것을 '다시(re)' 올바른 '형태(form)'로 만들다 → 개혁하다.","example":{"en":"The system needs to be reformed.","ko":"시스템이 개혁되어야 한다."}},
  {"word":"conform","level":"high","meaning":"순응하다","pronunciation":"/kənˈfɔːrm/","parts":[{"type":"prefix","text":"con-","meaning":"같이 (together)"},{"type":"root","text":"form","meaning":"형태 (shape)"}],"story":"생각을 주변과 '같은(con)' '형태(form)'로 맞추다 → 순응하다.","example":{"en":"Conform to the rules.","ko":"규칙에 순응해라."}},
  {"word":"vision","level":"middle","meaning":"시력, 비전","pronunciation":"/ˈvɪʒn/","parts":[{"type":"root","text":"vis","meaning":"보다 (see)"},{"type":"suffix","text":"-ion","meaning":"명사형"}],"story":"눈이나 마음으로 '보는(vis)' 것 → 시력, 비전.","example":{"en":"She has good vision.","ko":"그녀는 시력이 좋다."}},
  {"word":"visible","level":"middle","meaning":"보이는","pronunciation":"/ˈvɪzəbl/","parts":[{"type":"root","text":"vis","meaning":"보다 (see)"},{"type":"suffix","text":"-ible","meaning":"할 수 있는"}],"story":"눈으로 '볼(vis)' 수 '있는(ible)' → 눈에 보이는.","example":{"en":"The stars are visible.","ko":"별들이 보인다."}},
  {"word":"provide","level":"middle","meaning":"제공하다","pronunciation":"/prəˈvaɪd/","parts":[{"type":"prefix","text":"pro-","meaning":"미리 (before)"},{"type":"root","text":"vid","meaning":"보다 (see)"}],"story":"필요한 것을 '미리(pro)' '보고(vid)' 챙겨주다 → 제공하다.","example":{"en":"Trees provide oxygen.","ko":"나무는 산소를 제공한다."}},
  {"word":"evidence","level":"high","meaning":"증거","pronunciation":"/ˈevɪdəns/","parts":[{"type":"prefix","text":"e-","meaning":"밖으로 (out)"},{"type":"root","text":"vid","meaning":"보다 (see)"}],"story":"숨겨진 것이 '밖으로(e)' 드러나 누구나 '볼(vid)' 수 있는 것 → 증거.","example":{"en":"There is no evidence.","ko":"증거가 없다."}},
  {"word":"revise","level":"high","meaning":"수정하다","pronunciation":"/rɪˈvaɪz/","parts":[{"type":"prefix","text":"re-","meaning":"다시 (again)"},{"type":"root","text":"vis","meaning":"보다 (see)"}],"story":"글을 처음부터 '다시(re)' '보면서(vis)' 고치다 → 수정하다.","example":{"en":"I need to revise my essay.","ko":"에세이를 수정해야 한다."}},
  {"word":"accept","level":"middle","meaning":"수락하다","pronunciation":"/əkˈsept/","parts":[{"type":"prefix","text":"ac-","meaning":"~향해 (to)"},{"type":"root","text":"cept","meaning":"잡다 (take)"}],"story":"누가 주는 것을 내 '쪽으로(ac)' '잡다(cept)' → 받아들이다.","example":{"en":"She accepted it.","ko":"그녀는 그것을 수락했다."}},
  {"word":"except","level":"middle","meaning":"~을 제외하고","pronunciation":"/ɪkˈsept/","parts":[{"type":"prefix","text":"ex-","meaning":"밖으로 (out)"},{"type":"root","text":"cept","meaning":"잡다 (take)"}],"story":"전체에서 하나만 '밖으로(ex)' 빼내어 '잡다(cept)' → 제외하고.","example":{"en":"Everyone except him.","ko":"그를 제외한 모두."}},
  {"word":"capture","level":"middle","meaning":"포획하다","pronunciation":"/ˈkæptʃər/","parts":[{"type":"root","text":"cap","meaning":"잡다 (take)"},{"type":"suffix","text":"-ture","meaning":"명사형"}],"story":"도망가는 무언가를 꽉 '잡는(cap)' 행위 → 포획하다.","example":{"en":"They captured the spy.","ko":"그들은 스파이를 잡았다."}},
  {"word":"concept","level":"high","meaning":"개념","pronunciation":"/ˈkɑːnsept/","parts":[{"type":"prefix","text":"con-","meaning":"함께 (together)"},{"type":"root","text":"cept","meaning":"잡다 (take)"}],"story":"아이디어를 '하나로(con)' '잡아낸(cept)' 생각 → 개념.","example":{"en":"It is a difficult concept.","ko":"그것은 어려운 개념이다."}},
  {"word":"receive","level":"middle","meaning":"받다","pronunciation":"/rɪˈsiːv/","parts":[{"type":"prefix","text":"re-","meaning":"다시 (back)"},{"type":"root","text":"ceive","meaning":"잡다 (take)"}],"story":"내게 오는 것을 '다시(re)' 내 손으로 '잡다(ceive)' → 받다.","example":{"en":"I received a letter.","ko":"편지를 받았다."}},
  {"word":"progress","level":"middle","meaning":"진보하다, 전진","pronunciation":"/ˈprɑːɡres/","parts":[{"type":"prefix","text":"pro-","meaning":"앞으로 (forward)"},{"type":"root","text":"gress","meaning":"가다 (go)"}],"story":"'앞으로(pro)' 나아'가다(gress)' → 발전하다.","example":{"en":"He made great progress.","ko":"그는 큰 진전을 보였다."}},
  {"word":"grade","level":"middle","meaning":"등급, 성적","pronunciation":"/ɡreɪd/","parts":[{"type":"root","text":"grad","meaning":"단계 (step)"}],"story":"실력이 나아가는 한 '단계(grad)' → 성적, 등급.","example":{"en":"She got good grades.","ko":"좋은 성적을 받았다."}},
  {"word":"aggressive","level":"high","meaning":"공격적인","pronunciation":"/əˈɡresɪv/","parts":[{"type":"prefix","text":"ag-","meaning":"~를 향해 (toward)"},{"type":"root","text":"gress","meaning":"가다 (go)"}],"story":"상대를 '향해(ag)' 돌진해 '가는(gress)' 성향 → 공격적인.","example":{"en":"He is aggressive.","ko":"그는 공격적이다."}},
  {"word":"congress","level":"high","meaning":"의회, 회의","pronunciation":"/ˈkɑːŋɡrəs/","parts":[{"type":"prefix","text":"con-","meaning":"함께 (together)"},{"type":"root","text":"gress","meaning":"가다 (go)"}],"story":"대표들이 '함께(con)' '걸어 들어가는(gress)' 모임 → 의회.","example":{"en":"The Congress passed it.","ko":"의회가 그것을 통과시켰다."}},
  {"word":"regress","level":"high","meaning":"퇴보하다","pronunciation":"/rɪˈɡres/","parts":[{"type":"prefix","text":"re-","meaning":"뒤로 (back)"},{"type":"root","text":"gress","meaning":"가다 (go)"}],"story":"나아가지 못하고 '뒤로(re)' '가다(gress)' → 퇴보하다.","example":{"en":"His skills began to regress.","ko":"그의 기술이 퇴보했다."}},
  {"word":"admit","level":"middle","meaning":"인정하다, 허락하다","pronunciation":"/ədˈmɪt/","parts":[{"type":"prefix","text":"ad-","meaning":"~로 (to)"},{"type":"root","text":"mit","meaning":"보내다 (send)"}],"story":"안'쪽으로(ad)' '보내주다(mit)' → 허락하다, 인정하다.","example":{"en":"He admitted his mistake.","ko":"실수를 인정했다."}},
  {"word":"submit","level":"middle","meaning":"제출하다, 복종하다","pronunciation":"/səbˈmɪt/","parts":[{"type":"prefix","text":"sub-","meaning":"아래로 (under)"},{"type":"root","text":"mit","meaning":"보내다 (send)"}],"story":"권리나 서류를 '아래로(sub)' '보내다(mit)' → 제출하다, 복종하다.","example":{"en":"Submit your report.","ko":"보고서를 제출해라."}},
  {"word":"mission","level":"middle","meaning":"임무, 사절단","pronunciation":"/ˈmɪʃn/","parts":[{"type":"root","text":"miss","meaning":"보내다 (send)"},{"type":"suffix","text":"-ion","meaning":"명사형"}],"story":"특별한 목적을 위해 '보내진(miss)' 일이나 사람 → 임무.","example":{"en":"Mission accomplished.","ko":"임무 완수."}},
  {"word":"transmit","level":"high","meaning":"전송하다","pronunciation":"/trænsˈmɪt/","parts":[{"type":"prefix","text":"trans-","meaning":"가로질러 (across)"},{"type":"root","text":"mit","meaning":"보내다 (send)"}],"story":"공간을 '가로질러(trans)' 신호를 '보내다(mit)' → 전송하다.","example":{"en":"Transmit the signal.","ko":"신호를 전송해라."}},
  {"word":"emit","level":"high","meaning":"내뿜다, 방출하다","pronunciation":"/ɪˈmɪt/","parts":[{"type":"prefix","text":"e-","meaning":"밖으로 (out)"},{"type":"root","text":"mit","meaning":"보내다 (send)"}],"story":"빛, 가스 등을 '밖으로(e)' '보내다(mit)' → 내뿜다.","example":{"en":"The machine emits smoke.","ko":"그 기계는 연기를 내뿜는다."}},
  {"word":"apply","level":"middle","meaning":"지원하다, 적용하다","pronunciation":"/əˈplaɪ/","parts":[{"type":"prefix","text":"ap-","meaning":"~에 (to)"},{"type":"root","text":"ply","meaning":"접다 (fold)"}],"story":"내 이력서를 서류 '속으로(ap)' '접어넣다(ply)' → 지원하다.","example":{"en":"Apply for the job.","ko":"그 일자리에 지원해라."}},
  {"word":"reply","level":"middle","meaning":"대답하다","pronunciation":"/rɪˈplaɪ/","parts":[{"type":"prefix","text":"re-","meaning":"다시 (back)"},{"type":"root","text":"ply","meaning":"접다 (fold)"}],"story":"받은 편지를 읽고 '다시(re)' '접어서(ply)' 돌려보내다 → 답장하다.","example":{"en":"He didn't reply.","ko":"그는 대답하지 않았다."}},
  {"word":"complex","level":"middle","meaning":"복잡한","pronunciation":"/kəmˈpleks/","parts":[{"type":"prefix","text":"com-","meaning":"함께 (together)"},{"type":"root","text":"plex","meaning":"꼬다 (fold/weave)"}],"story":"여러 개가 '함께(com)' 얽히고 '꼬여있는(plex)' 상태 → 복잡한.","example":{"en":"A complex problem.","ko":"복잡한 문제."}},
  {"word":"imply","level":"high","meaning":"암시하다","pronunciation":"/ɪmˈplaɪ/","parts":[{"type":"prefix","text":"im-","meaning":"안에 (in)"},{"type":"root","text":"ply","meaning":"접다 (fold)"}],"story":"진짜 의미를 말 '안에(im)' '접어(ply)' 숨겨두다 → 암시하다.","example":{"en":"What does this imply?","ko":"이것은 무엇을 암시하나요?"}},
  {"word":"multiply","level":"high","meaning":"곱하다","pronunciation":"/ˈmʌltɪplaɪ/","parts":[{"type":"prefix","text":"multi-","meaning":"많은 (many)"},{"type":"root","text":"ply","meaning":"접다 (fold)"}],"story":"종이를 '여러 번(multi)' '접으면(ply)' 두께가 확 커지듯 → 곱하다.","example":{"en":"Multiply 3 by 4.","ko":"3에 4를 곱해라."}},
  {"word":"maintain","level":"middle","meaning":"유지하다","pronunciation":"/meɪnˈteɪn/","parts":[{"type":"prefix","text":"main-","meaning":"손 (hand)"},{"type":"root","text":"tain","meaning":"잡다 (hold)"}],"story":"'손(main)'으로 꽉 '잡고(tain)' 놓지 않다 → 유지하다.","example":{"en":"Maintain your weight.","ko":"몸무게를 유지해라."}},
  {"word":"contain","level":"middle","meaning":"포함하다","pronunciation":"/kənˈteɪn/","parts":[{"type":"prefix","text":"con-","meaning":"함께 (together)"},{"type":"root","text":"tain","meaning":"잡다 (hold)"}],"story":"여러 개를 '함께(con)' 테두리 안에 '잡아두다(tain)' → 포함하다.","example":{"en":"The box contains books.","ko":"상자는 책을 포함한다."}},
  {"word":"obtain","level":"middle","meaning":"얻다","pronunciation":"/əbˈteɪn/","parts":[{"type":"prefix","text":"ob-","meaning":"~를 향해 (toward)"},{"type":"root","text":"tain","meaning":"잡다 (hold)"}],"story":"원하는 것을 향해 다가가 결국 '잡다(tain)' → 얻다.","example":{"en":"Obtain a license.","ko":"자격증을 얻다."}},
  {"word":"sustain","level":"high","meaning":"지탱하다","pronunciation":"/səˈsteɪn/","parts":[{"type":"prefix","text":"sus-","meaning":"아래에서 (under)"},{"type":"root","text":"tain","meaning":"잡다 (hold)"}],"story":"무너지지 않게 '아래에서(sus)' 꽉 '잡아주다(tain)' → 지탱하다.","example":{"en":"Food sustains life.","ko":"음식은 생명을 유지시킨다."}},
  {"word":"retain","level":"high","meaning":"보유하다","pronunciation":"/rɪˈteɪn/","parts":[{"type":"prefix","text":"re-","meaning":"뒤에 (back)"},{"type":"root","text":"tain","meaning":"잡다 (hold)"}],"story":"잃어버리지 않게 '뒤에(re)' 계속 '잡아두다(tain)' → 보유하다.","example":{"en":"Retain your receipt.","ko":"영수증을 보관하세요."}},
  {"word":"depend","level":"middle","meaning":"의지하다","pronunciation":"/dɪˈpend/","parts":[{"type":"prefix","text":"de-","meaning":"아래로 (down)"},{"type":"root","text":"pend","meaning":"매달리다 (hang)"}],"story":"누군가의 '아래에(de)' '매달려(pend)' 있다 → 의지하다.","example":{"en":"It depends on you.","ko":"그건 너에게 달렸다."}},
  {"word":"suspend","level":"high","meaning":"매달다, 중지시키다","pronunciation":"/səˈspend/","parts":[{"type":"prefix","text":"sus-","meaning":"아래에서 위로"},{"type":"root","text":"pend","meaning":"매달다 (hang)"}],"story":"공중에 둥둥 '매달아(pend)' 놓다 → 일시 중지하다.","example":{"en":"The game was suspended.","ko":"경기가 중단되었다."}},
  {"word":"expend","level":"high","meaning":"소비하다","pronunciation":"/ɪkˈspend/","parts":[{"type":"prefix","text":"ex-","meaning":"밖으로 (out)"},{"type":"root","text":"pend","meaning":"무게를 달다 (weigh)"}],"story":"옛날에는 돈의 '무게를 달아서(pend)' '밖으로(ex)' 내주었다 → 돈을 소비하다.","example":{"en":"Expend energy.","ko":"에너지를 쓰다."}},
  {"word":"compensate","level":"high","meaning":"보상하다","pronunciation":"/ˈkɑːmpenseɪt/","parts":[{"type":"prefix","text":"com-","meaning":"함께 (together)"},{"type":"root","text":"pens","meaning":"무게 달다 (weigh)"}],"story":"잃어버린 것과 '같은(com)' 무게를 저울에 '달아(pens)' 주다 → 보상하다.","example":{"en":"Compensate for the loss.","ko":"손실에 대해 보상하다."}},
  {"word":"dispense","level":"high","meaning":"나누어 주다","pronunciation":"/dɪˈspens/","parts":[{"type":"prefix","text":"dis-","meaning":"따로따로 (apart)"},{"type":"root","text":"pens","meaning":"무게 달다 (weigh)"}],"story":"물건의 무게를 '달아서(pens)' '각각(dis)' 나누어주다 → 배분하다.","example":{"en":"Dispense medicine.","ko":"약을 조제하다."}},
  {"word":"factory","level":"middle","meaning":"공장","pronunciation":"/ˈfæktəri/","parts":[{"type":"root","text":"fac","meaning":"만들다 (make)"},{"type":"suffix","text":"-ory","meaning":"장소"}],"story":"물건을 '만드는(fac)' 장소 → 공장.","example":{"en":"He works in a factory.","ko":"그는 공장에서 일한다."}},
  {"word":"affect","level":"middle","meaning":"영향을 미치다","pronunciation":"/əˈfekt/","parts":[{"type":"prefix","text":"af-","meaning":"~에 (to)"},{"type":"root","text":"fect","meaning":"만들다 (make)"}],"story":"어떤 것에 작용을 '가하다/만들다(fect)' → 영향을 미치다.","example":{"en":"It affects my sleep.","ko":"그것은 내 수면에 영향을 미친다."}},
  {"word":"effect","level":"middle","meaning":"결과, 효과","pronunciation":"/ɪˈfekt/","parts":[{"type":"prefix","text":"ef-","meaning":"밖으로 (out)"},{"type":"root","text":"fect","meaning":"만들다 (make)"}],"story":"원인으로 인해 '밖으로(ef)' '만들어진(fect)' 것 → 결과, 효과.","example":{"en":"The drug has side effects.","ko":"그 약은 부작용(효과)이 있다."}},
  {"word":"perfect","level":"middle","meaning":"완벽한","pronunciation":"/ˈpɜːrfɪkt/","parts":[{"type":"prefix","text":"per-","meaning":"완전히 (completely)"},{"type":"root","text":"fect","meaning":"만들다 (make)"}],"story":"'완전히(per)' 흠잡을 데 없이 '만들어진(fect)' → 완벽한.","example":{"en":"Nobody is perfect.","ko":"아무도 완벽하지 않다."}},
  {"word":"fiction","level":"high","meaning":"소설, 허구","pronunciation":"/ˈfɪkʃn/","parts":[{"type":"root","text":"fict","meaning":"만들다 (make)"},{"type":"suffix","text":"-ion","meaning":"명사형"}],"story":"작가가 머릿속에서 꾸며서 '만들어낸(fict)' 이야기 → 허구.","example":{"en":"It is pure fiction.","ko":"그것은 완전한 허구다."}},
  {"word":"reverse","level":"middle","meaning":"뒤집다","pronunciation":"/rɪˈvɜːrs/","parts":[{"type":"prefix","text":"re-","meaning":"뒤로 (back)"},{"type":"root","text":"vers","meaning":"돌리다 (turn)"}],"story":"가던 방향의 '뒤로(re)' 방향을 '돌리다(vers)' → 뒤집다.","example":{"en":"Reverse the car.","ko":"차를 후진해라."}},
  {"word":"convert","level":"high","meaning":"전환하다","pronunciation":"/kənˈvɜːrt/","parts":[{"type":"prefix","text":"con-","meaning":"완전히 (completely)"},{"type":"root","text":"vert","meaning":"돌리다 (turn)"}],"story":"상태를 '완전히(con)' 다른 방향으로 '돌리다(vert)' → 바꾸다.","example":{"en":"Convert dollars to euros.","ko":"달러를 유로로 환전해라."}},
  {"word":"introvert","level":"high","meaning":"내향적인 사람","pronunciation":"/ˈɪntrəvɜːrt/","parts":[{"type":"prefix","text":"intro-","meaning":"안으로 (inward)"},{"type":"root","text":"vert","meaning":"돌리다 (turn)"}],"story":"관심이 자기 자신 '안으로(intro)' '향해있는(vert)' 사람.","example":{"en":"He is an introvert.","ko":"그는 내향적이다."}},
  {"word":"advertise","level":"middle","meaning":"광고하다","pronunciation":"/ˈædvərtaɪz/","parts":[{"type":"prefix","text":"ad-","meaning":"~쪽으로 (to)"},{"type":"root","text":"vert","meaning":"돌리다 (turn)"}],"story":"사람들의 관심을 상품 '쪽으로(ad)' '돌리게(vert)' 하다 → 광고하다.","example":{"en":"They advertise on TV.","ko":"그들은 TV에 광고한다."}},
  {"word":"universe","level":"middle","meaning":"우주","pronunciation":"/ˈjuːnɪvɜːrs/","parts":[{"type":"prefix","text":"uni-","meaning":"하나 (one)"},{"type":"root","text":"vers","meaning":"돌다 (turn)"}],"story":"만물이 '하나의(uni)' 중심을 향해 '도는(vers)' 공간 → 우주.","example":{"en":"The universe is vast.","ko":"우주는 광대하다."}},
  {"word":"include","level":"middle","meaning":"포함하다","pronunciation":"/ɪnˈkluːd/","parts":[{"type":"prefix","text":"in-","meaning":"안에 (in)"},{"type":"root","text":"clud","meaning":"닫다 (close)"}],"story":"어떤 것을 '안에(in)' 넣고 문을 '닫아버리다(clud)' → 포함하다.","example":{"en":"The price includes tax.","ko":"가격은 세금을 포함한다."}},
  {"word":"exclude","level":"middle","meaning":"제외하다","pronunciation":"/ɪkˈskluːd/","parts":[{"type":"prefix","text":"ex-","meaning":"밖에 (out)"},{"type":"root","text":"clud","meaning":"닫다 (close)"}],"story":"어떤 것을 '밖에(ex)' 두고 문을 '닫아버리다(clud)' → 제외하다.","example":{"en":"Exclude him from the list.","ko":"그를 명단에서 제외해라."}},
  {"word":"conclude","level":"high","meaning":"결론짓다","pronunciation":"/kənˈkluːd/","parts":[{"type":"prefix","text":"con-","meaning":"완전히 (completely)"},{"type":"root","text":"clud","meaning":"닫다 (close)"}],"story":"토론이나 글을 '완전히(con)' 마무리 짓고 '닫다(clud)' → 결론내리다.","example":{"en":"I concluded that he was right.","ko":"나는 그가 옳다고 결론지었다."}},
  {"word":"seclude","level":"high","meaning":"격리하다, 은둔하다","pronunciation":"/sɪˈkluːd/","parts":[{"type":"prefix","text":"se-","meaning":"떨어져서 (apart)"},{"type":"root","text":"clud","meaning":"닫다 (close)"}],"story":"세상과 '떨어져서(se)' 자신만의 공간을 '닫다(clud)' → 격리하다.","example":{"en":"He secluded himself.","ko":"그는 은둔했다."}},
  {"word":"closet","level":"middle","meaning":"벽장","pronunciation":"/ˈklɑːzɪt/","parts":[{"type":"root","text":"clos","meaning":"닫다 (close)"},{"type":"suffix","text":"-et","meaning":"작은 것"}],"story":"물건을 넣고 '닫아두는(clos)' '작은(et)' 공간 → 벽장.","example":{"en":"Put it in the closet.","ko":"그것을 벽장에 넣어라."}},
  {"word":"interrupt","level":"middle","meaning":"방해하다","pronunciation":"/ˌɪntəˈrʌpt/","parts":[{"type":"prefix","text":"inter-","meaning":"사이에 (between)"},{"type":"root","text":"rupt","meaning":"깨다 (break)"}],"story":"사람들 '사이에(inter)' 끼어들어 흐름을 '깨다(rupt)' → 방해하다.","example":{"en":"Don't interrupt me.","ko":"내 말을 끊지 마."}},
  {"word":"bankrupt","level":"high","meaning":"파산한","pronunciation":"/ˈbæŋkrʌpt/","parts":[{"type":"root","text":"bank","meaning":"탁자"},{"type":"root","text":"rupt","meaning":"부수다 (break)"}],"story":"중세 상인이 빚을 지면 그의 환전 '탁자(bank)'를 '부숴버린(rupt)' 것에서 유래.","example":{"en":"The company went bankrupt.","ko":"그 회사는 파산했다."}},
  {"word":"erupt","level":"high","meaning":"폭발하다","pronunciation":"/ɪˈrʌpt/","parts":[{"type":"prefix","text":"e-","meaning":"밖으로 (out)"},{"type":"root","text":"rupt","meaning":"깨다 (break)"}],"story":"화산이 땅을 '깨고(rupt)' 용암을 '밖으로(e)' 내뿜다 → 폭발하다.","example":{"en":"The volcano erupted.","ko":"화산이 폭발했다."}},
  {"word":"corrupt","level":"high","meaning":"부패한","pronunciation":"/kəˈrʌpt/","parts":[{"type":"prefix","text":"cor-","meaning":"완전히 (completely)"},{"type":"root","text":"rupt","meaning":"부수다 (break)"}],"story":"도덕이나 양심이 '완전히(cor)' '부서져(rupt)' 버린 상태 → 부패한.","example":{"en":"A corrupt politician.","ko":"부패한 정치인."}},
  {"word":"abrupt","level":"high","meaning":"갑작스러운","pronunciation":"/əˈbrʌpt/","parts":[{"type":"prefix","text":"ab-","meaning":"떨어져 (off)"},{"type":"root","text":"rupt","meaning":"부러지다 (break)"}],"story":"나뭇가지가 뚝 '부러져서(rupt)' '떨어지듯(ab)' 예고 없이 일어나는 → 갑작스러운.","example":{"en":"An abrupt change.","ko":"갑작스러운 변화."}},
  {"word":"compel","level":"high","meaning":"강요하다","pronunciation":"/kəmˈpel/","parts":[{"type":"prefix","text":"com-","meaning":"강하게 (strongly)"},{"type":"root","text":"pel","meaning":"밀다 (drive)"}],"story":"어떤 일을 하도록 '강하게(com)' 등 떠'밀다(pel)' → 억지로 시키다.","example":{"en":"The rain compelled us to stay.","ko":"비 때문에 우리는 강제로 머물러야 했다."}},
  {"word":"expel","level":"high","meaning":"추방하다","pronunciation":"/ɪkˈspel/","parts":[{"type":"prefix","text":"ex-","meaning":"밖으로 (out)"},{"type":"root","text":"pel","meaning":"밀다 (drive)"}],"story":"조직이나 학교 '밖으로(ex)' '밀어내다(pel)' → 추방하다.","example":{"en":"He was expelled from school.","ko":"그는 퇴학당했다."}},
  {"word":"impulse","level":"high","meaning":"충동","pronunciation":"/ˈɪmpʌls/","parts":[{"type":"prefix","text":"im-","meaning":"안에 (in)"},{"type":"root","text":"puls","meaning":"밀다 (push)"}],"story":"마음 '속(im)'에서 무언가 하라고 강하게 '밀어붙이는(puls)' 힘 → 충동.","example":{"en":"A sudden impulse to laugh.","ko":"갑자기 웃고 싶은 충동."}},
  {"word":"propel","level":"high","meaning":"추진하다","pronunciation":"/prəˈpel/","parts":[{"type":"prefix","text":"pro-","meaning":"앞으로 (forward)"},{"type":"root","text":"pel","meaning":"밀다 (drive)"}],"story":"'앞으로(pro)' 나아가도록 '밀어주다(pel)' → 추진하다.","example":{"en":"Propel the boat.","ko":"보트를 나아가게 하다."}},
  {"word":"repel","level":"high","meaning":"격퇴하다","pronunciation":"/rɪˈpel/","parts":[{"type":"prefix","text":"re-","meaning":"뒤로 (back)"},{"type":"root","text":"pel","meaning":"밀다 (drive)"}],"story":"다가오는 적이나 벌레를 '뒤로(re)' '밀어내다(pel)' → 쫓아버리다.","example":{"en":"Repel mosquitoes.","ko":"모기를 쫓다."}},
  {"word":"construct","level":"middle","meaning":"건설하다","pronunciation":"/kənˈstrʌkt/","parts":[{"type":"prefix","text":"con-","meaning":"함께 (together)"},{"type":"root","text":"struct","meaning":"세우다 (build)"}],"story":"재료를 '함께(con)' 모아 '세우다(struct)' → 건설하다.","example":{"en":"Construct a building.","ko":"건물을 건설하다."}},
  {"word":"destruct","level":"high","meaning":"파괴하다","pronunciation":"/dɪˈstrʌkt/","parts":[{"type":"prefix","text":"de-","meaning":"무너뜨려 (down)"},{"type":"root","text":"struct","meaning":"세우다 (build)"}],"story":"'세워진 것(struct)'을 '무너뜨리다(de)' → 파괴하다.","example":{"en":"Weapons of mass destruction.","ko":"대량 살상(파괴) 무기."}},
