[
  {"word":"local","level":"middle","meaning":"지역의, 현지의","pronunciation":"/ˈloʊkl/","parts":[{"type":"root","text":"loc","meaning":"장소 (place)"},{"type":"suffix","text":"-al","meaning":"형용사형"}],"story":"특정 '장소(loc)'와 관련된 → 지역의.","example":{"en":"A local newspaper.","ko":"지역 신문."}},
