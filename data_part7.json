[
  {"word":"journal","level":"middle","meaning":"일기, 일지, 잡지","pronunciation":"/ˈdʒɜːrnl/","parts":[{"type":"root","text":"jour","meaning":"하루 (day)"},{"type":"suffix","text":"-al","meaning":"명사형"}],"story":"'하루(jour)' 동안 일어난 일을 매일매일 기록하는 장부 → 일기, 정기간행물.","example":{"en":"Keep a daily journal.","ko":"매일 일기를 쓰다."}},
  {"word":"journey","level":"middle","meaning":"여행, 여정","pronunciation":"/ˈdʒɜːrni/","parts":[{"type":"root","text":"jour","meaning":"하루 (day)"},{"type":"suffix","text":"-ney","meaning":"명사형"}],"story":"과거에는 '하루(jour)' 동안 걸어서 갈 수 있는 거리를 뜻했음 → 여행.","example":{"en":"A long journey.","ko":"긴 여행."}},
  {"word":"journalist","level":"middle","meaning":"기자, 언론인","pronunciation":"/ˈdʒɜːrnəlɪst/","parts":[{"type":"root","text":"journal","meaning":"신문, 잡지"},{"type":"suffix","text":"-ist","meaning":"사람"}],"story":"매일 나오는 신문이나 잡지(journal)에 글을 쓰는 '사람(ist)'.","example":{"en":"A political journalist.","ko":"정치부 기자."}},
  {"word":"journalism","level":"high","meaning":"언론, 저널리즘","pronunciation":"/ˈdʒɜːrnəlɪzəm/","parts":[{"type":"root","text":"journal","meaning":"신문"},{"type":"suffix","text":"-ism","meaning":"분야, 사상"}],"story":"뉴스나 잡지를 취재하고 보도하는 직업이나 '분야(ism)'.","example":{"en":"A career in journalism.","ko":"언론계에서의 경력."}},
  {"word":"adjourn","level":"high","meaning":"휴회하다, 연기하다","pronunciation":"/əˈdʒɜːrn/","parts":[{"type":"prefix","text":"ad-","meaning":"~로 (to)"},{"type":"root","text":"journ","meaning":"하루 (day)"}],"story":"회의를 오늘 끝내지 않고 다음 '날(journ)' '로(ad)' 넘기다 → 휴회하다.","example":{"en":"Adjourn the meeting.","ko":"회의를 휴회하다."}},
  {"word":"via","level":"middle","meaning":"~을 경유하여","pronunciation":"/ˈvaɪə/","parts":[{"type":"root","text":"via","meaning":"길 (way)"}],"story":"어느 목적지로 가는 '길(via)'을 거쳐서 → ~을 경유하여.","example":{"en":"Go to Paris via London.","ko":"런던을 경유하여 파리로 가다."}},
  {"word":"viaduct","level":"high","meaning":"고가교, 구름다리","pronunciation":"/ˈvaɪədʌkt/","parts":[{"type":"root","text":"via","meaning":"길 (way)"},{"type":"root","text":"duct","meaning":"이끌다 (lead)"}],"story":"골짜기 위로 차가 다닐 수 있는 '길(via)'을 높이 '끌어올려(duct)' 만든 다리.","example":{"en":"A railway viaduct.","ko":"철도 고가교."}},
  {"word":"obvious","level":"middle","meaning":"명백한, 분명한","pronunciation":"/ˈɑːbviəs/","parts":[{"type":"prefix","text":"ob-","meaning":"앞에 (in front of)"},{"type":"root","text":"vi","meaning":"길 (way)"},{"type":"suffix","text":"-ous","meaning":"형용사형"}],"story":"내가 걷는 '길(vi)' 바로 '앞에(ob)' 놓여 있어서 누구나 볼 수 있는 → 명백한.","example":{"en":"An obvious mistake.","ko":"명백한 실수."}},
  {"word":"previous","level":"middle","meaning":"이전의","pronunciation":"/ˈpriːviəs/","parts":[{"type":"prefix","text":"pre-","meaning":"먼저, 앞에 (before)"},{"type":"root","text":"vi","meaning":"길 (way)"},{"type":"suffix","text":"-ous","meaning":"형용사형"}],"story":"내가 가는 '길(vi)'보다 '앞서서(pre)' 지나간 → 이전의.","example":{"en":"My previous job.","ko":"나의 이전 직장."}},
  {"word":"deviate","level":"high","meaning":"벗어나다, 빗나가다","pronunciation":"/ˈdiːvieɪt/","parts":[{"type":"prefix","text":"de-","meaning":"떨어져 (off)"},{"type":"root","text":"vi","meaning":"길 (way)"},{"type":"suffix","text":"-ate","meaning":"동사형"}],"story":"정해진 '길(vi)'에서 옆으로 '떨어져(de)' 나가다 → 벗어나다.","example":{"en":"Deviate from the route.","ko":"경로에서 벗어나다."}},
  {"word":"medium","level":"middle","meaning":"중간의, 매체","pronunciation":"/ˈmiːdiəm/","parts":[{"type":"root","text":"medi","meaning":"중간 (middle)"},{"type":"suffix","text":"-um","meaning":"명사/형용사형"}],"story":"크기나 위치가 '중간(medi)'에 있는 것. 또는 송신자와 수신자 '중간'에서 정보를 전달하는 매체.","example":{"en":"Medium size.","ko":"중간 사이즈."}},
  {"word":"media","level":"middle","meaning":"매스컴, 대중 매체","pronunciation":"/ˈmiːdiə/","parts":[{"type":"root","text":"medi","meaning":"중간 (middle)"},{"type":"suffix","text":"-a","meaning":"복수형"}],"story":"medium(매체)의 복수형으로, 대중에게 정보를 전달하는 신문/방송 등을 통틀어 일컬음.","example":{"en":"Social media.","ko":"소셜 미디어."}},
  {"word":"mediate","level":"high","meaning":"중재하다","pronunciation":"/ˈmiːdieɪt/","parts":[{"type":"root","text":"medi","meaning":"중간 (middle)"},{"type":"suffix","text":"-ate","meaning":"동사형"}],"story":"싸우는 두 사람 '중간(medi)'에 들어가서 화해시키다 → 중재하다.","example":{"en":"Mediate a dispute.","ko":"분쟁을 중재하다."}},
  {"word":"medieval","level":"high","meaning":"중세의","pronunciation":"/ˌmiːdˈiːvl/","parts":[{"type":"root","text":"medi","meaning":"중간 (middle)"},{"type":"root","text":"ev","meaning":"시대 (age)"},{"type":"suffix","text":"-al","meaning":"형용사형"}],"story":"고대와 근대 '중간(medi)'에 끼어있는 '시대(ev)'의 → 중세의.","example":{"en":"Medieval history.","ko":"중세 역사."}},
  {"word":"immediate","level":"middle","meaning":"즉각적인, 직접적인","pronunciation":"/ɪˈmiːdiət/","parts":[{"type":"prefix","text":"im-","meaning":"없는 (not)"},{"type":"root","text":"medi","meaning":"중간 (middle)"},{"type":"suffix","text":"-ate","meaning":"형용사형"}],"story":"나와 상대방 '중간(medi)'에 거칠 것이 '아무것도 없는(im)' → 즉각적인, 다이렉트의.","example":{"en":"An immediate response.","ko":"즉각적인 반응."}},
  {"word":"initial","level":"middle","meaning":"처음의, 이니셜","pronunciation":"/ɪˈnɪʃl/","parts":[{"type":"root","text":"init","meaning":"들어가다, 시작하다"},{"type":"suffix","text":"-ial","meaning":"형용사형"}],"story":"어떤 일에 처음으로 '발을 들여놓는(init)' → 처음의, 이름의 첫 글자.","example":{"en":"Initial stage.","ko":"초기 단계."}},
  {"word":"initiate","level":"high","meaning":"시작하다, 착수하다","pronunciation":"/ɪˈnɪʃieɪt/","parts":[{"type":"root","text":"init","meaning":"시작하다 (begin)"},{"type":"suffix","text":"-ate","meaning":"동사형"}],"story":"새로운 사업이나 계획을 처음으로 '시작하다(init)'.","example":{"en":"Initiate a project.","ko":"프로젝트를 시작하다."}},
  {"word":"initiative","level":"high","meaning":"주도권, 진취성","pronunciation":"/ɪˈnɪʃətɪv/","parts":[{"type":"root","text":"initiate","meaning":"시작하다"},{"type":"suffix","text":"-ive","meaning":"명사형"}],"story":"남보다 먼저 '시작(init)'해서 이끌고 나가는 힘 → 주도권.","example":{"en":"Take the initiative.","ko":"주도권을 잡다."}},
  {"word":"initially","level":"middle","meaning":"처음에는","pronunciation":"/ɪˈnɪʃəli/","parts":[{"type":"root","text":"initial","meaning":"처음의"},{"type":"suffix","text":"-ly","meaning":"부사형"}],"story":"맨 처음 시작할 때에는.","example":{"en":"Initially, I didn't like it.","ko":"처음에는 그것을 좋아하지 않았다."}},
  {"word":"initiation","level":"high","meaning":"가입, 시작, 신고식","pronunciation":"/ɪˌnɪʃiˈeɪʃn/","parts":[{"type":"root","text":"initiate","meaning":"시작하다"},{"type":"suffix","text":"-ion","meaning":"명사형"}],"story":"집단에 처음 '들어가는(init)' 의식 → 가입, 신고식.","example":{"en":"An initiation ceremony.","ko":"신입 회원 환영회(신고식)."}},
  {"word":"monarch","level":"high","meaning":"군주, 제왕","pronunciation":"/ˈmɑːnərk/","parts":[{"type":"prefix","text":"mono-","meaning":"혼자 (one)"},{"type":"root","text":"arch","meaning":"다스리다 (rule)"}],"story":"국가를 '혼자서(mono)' '다스리는(arch)' 최고 권력자 → 군주.","example":{"en":"A reigning monarch.","ko":"통치 중인 군주."}},
  {"word":"anarchy","level":"high","meaning":"무정부 상태, 난장판","pronunciation":"/ˈænərki/","parts":[{"type":"prefix","text":"an-","meaning":"없는 (without)"},{"type":"root","text":"archy","meaning":"통치 (rule)"}],"story":"국가를 '다스리는(archy)' 법이나 정부가 '없는(an)' 혼란스러운 상태.","example":{"en":"The country fell into anarchy.","ko":"그 나라는 무정부 상태에 빠졌다."}},
  {"word":"architect","level":"middle","meaning":"건축가","pronunciation":"/ˈɑːrkɪtekt/","parts":[{"type":"root","text":"arch","meaning":"으뜸, 우두머리"},{"type":"root","text":"tect","meaning":"만드는 사람"}],"story":"건물을 '만드는(tect)' 사람들 중 기술이 가장 뛰어난 '우두머리(arch)' → 건축가.","example":{"en":"A famous architect.","ko":"유명한 건축가."}},
  {"word":"archive","level":"high","meaning":"기록 보관소","pronunciation":"/ˈɑːrkaɪv/","parts":[{"type":"root","text":"arch","meaning":"오래된 (ancient)"}],"story":"정부의 '오래된(arch)' 역사적 문서를 보관하는 장소.","example":{"en":"The national archives.","ko":"국가 기록 보관소."}},
  {"word":"archaeology","level":"high","meaning":"고고학","pronunciation":"/ˌɑːrkiˈɑːlədʒi/","parts":[{"type":"root","text":"archaeo","meaning":"고대의 (ancient)"},{"type":"suffix","text":"-logy","meaning":"학문"}],"story":"'아주 옛날(arch)'의 인류 유물을 발굴하고 연구하는 '학문(logy)'.","example":{"en":"Study archaeology.","ko":"고고학을 공부하다."}},
  {"word":"democracy","level":"middle","meaning":"민주주의","pronunciation":"/dɪˈmɑːkrəsi/","parts":[{"type":"root","text":"demo","meaning":"국민 (people)"},{"type":"root","text":"cracy","meaning":"통치 (rule)"}],"story":"왕이 아닌 일반 '국민(demo)'이 나라를 '통치(cracy)'하는 정치 형태.","example":{"en":"A liberal democracy.","ko":"자유 민주주의."}},
  {"word":"democratic","level":"middle","meaning":"민주적인","pronunciation":"/ˌdeməˈkrætɪk/","parts":[{"type":"root","text":"democracy","meaning":"민주주의"},{"type":"suffix","text":"-ic","meaning":"형용사형"}],"story":"국민이 주인이 되는 민주주의의 원칙에 따르는.","example":{"en":"A democratic process.","ko":"민주적인 절차."}},
  {"word":"autocrat","level":"high","meaning":"독재자","pronunciation":"/ˈɔːtəkræt/","parts":[{"type":"prefix","text":"auto-","meaning":"스스로 (self)"},{"type":"root","text":"crat","meaning":"통치자 (ruler)"}],"story":"누구의 간섭도 없이 '스스로(auto)' 맘대로 '통치하는 사람(crat)' → 독재자.","example":{"en":"Ruled by an autocrat.","ko":"독재자에 의해 통치되는."}},
  {"word":"aristocrat","level":"high","meaning":"귀족","pronunciation":"/əˈrɪstəkræt/","parts":[{"type":"root","text":"aristo","meaning":"최고의 (best)"},{"type":"root","text":"crat","meaning":"통치자"}],"story":"신분이나 혈통이 '최고(aristo)'라고 여겨지며 '지배하는 자(crat)' → 귀족.","example":{"en":"A wealthy aristocrat.","ko":"부유한 귀족."}},
  {"word":"bureaucrat","level":"high","meaning":"관료, 공무원","pronunciation":"/ˈbjʊrəkræt/","parts":[{"type":"root","text":"bureau","meaning":"사무실, 책상"},{"type":"root","text":"crat","meaning":"통치자"}],"story":"'책상(bureau)'에 앉아 서류로 국가를 '다스리는 자(crat)' → 관료.","example":{"en":"Government bureaucrats.","ko":"정부 관료들."}},
  {"word":"domain","level":"high","meaning":"영역, 영토, 도메인","pronunciation":"/doʊˈmeɪn/","parts":[{"type":"root","text":"dom","meaning":"지배하다, 집 (rule)"},{"type":"suffix","text":"-ain","meaning":"명사형"}],"story":"주인이 법적으로 '다스리고(dom)' 있는 땅이나 지식의 '영역'.","example":{"en":"Public domain.","ko":"공유 영역."}},
  {"word":"dominate","level":"middle","meaning":"지배하다, 우세하다","pronunciation":"/ˈdɑːmɪneɪt/","parts":[{"type":"root","text":"domin","meaning":"지배하다 (rule)"},{"type":"suffix","text":"-ate","meaning":"동사형"}],"story":"남들보다 높은 곳에서 권력으로 '다스리다(domin)'.","example":{"en":"Dominate the market.","ko":"시장을 지배하다."}},
  {"word":"dominant","level":"high","meaning":"우세한, 지배적인","pronunciation":"/ˈdɑːmɪnənt/","parts":[{"type":"root","text":"domin","meaning":"지배하다 (rule)"},{"type":"suffix","text":"-ant","meaning":"형용사형"}],"story":"가장 강력한 힘으로 전체를 '지배하고 있는(domin)'.","example":{"en":"The dominant species.","ko":"지배적인 종."}},
  {"word":"domestic","level":"middle","meaning":"국내의, 가정의","pronunciation":"/dəˈmestɪk/","parts":[{"type":"root","text":"dom","meaning":"집 (house)"},{"type":"suffix","text":"-estic","meaning":"관련된"}],"story":"내가 살고 있는 '집(dom)'(가정)이나 '내 나라'(국내)와 관련된.","example":{"en":"Domestic flights.","ko":"국내선 항공편."}},
  {"word":"predominate","level":"high","meaning":"지배적이다, 우위를 차지하다","pronunciation":"/prɪˈdɑːmɪneɪt/","parts":[{"type":"prefix","text":"pre-","meaning":"앞서서 (before)"},{"type":"root","text":"dominate","meaning":"지배하다"}],"story":"남들보다 먼저 '앞서서(pre)' 힘으로 꾹 눌러 '지배하다(dominate)'.","example":{"en":"Pine trees predominate in this forest.","ko":"이 숲에는 소나무가 지배적이다."}},
  {"word":"legal","level":"middle","meaning":"합법적인, 법률의","pronunciation":"/ˈliːɡl/","parts":[{"type":"root","text":"leg","meaning":"법 (law)"},{"type":"suffix","text":"-al","meaning":"형용사형"}],"story":"국가가 정한 '법(leg)'의 테두리 안에 있는 → 합법적인.","example":{"en":"Take legal action.","ko":"법적 조치를 취하다."}},
  {"word":"illegal","level":"middle","meaning":"불법의","pronunciation":"/ɪˈliːɡl/","parts":[{"type":"prefix","text":"il(in)-","meaning":"아닌 (not)"},{"type":"root","text":"legal","meaning":"합법적인"}],"story":"'법(leg)'에서 허용하는 것이 '아닌(il)' → 불법의.","example":{"en":"Illegal parking.","ko":"불법 주차."}},
  {"word":"legislate","level":"high","meaning":"법률을 제정하다","pronunciation":"/ˈledʒɪsleɪt/","parts":[{"type":"root","text":"leg","meaning":"법 (law)"},{"type":"root","text":"late","meaning":"가져오다"}],"story":"새로운 '법(leg)'안을 의회로 '가져와서(late)' 통과시키다 → 법을 만들다.","example":{"en":"Legislate against discrimination.","ko":"차별을 금지하는 법을 제정하다."}},
  {"word":"legitimate","level":"high","meaning":"정당한, 합법적인","pronunciation":"/lɪˈdʒɪtɪmət/","parts":[{"type":"root","text":"leg","meaning":"법 (law)"},{"type":"suffix","text":"-mate","meaning":"형용사형"}],"story":"'법(leg)'이나 규칙에 비추어 보았을 때 이치에 맞는 → 정당한.","example":{"en":"A legitimate excuse.","ko":"정당한 변명."}},
  {"word":"privilege","level":"high","meaning":"특권","pronunciation":"/ˈprɪvəlɪdʒ/","parts":[{"type":"prefix","text":"privi-","meaning":"개인의 (private)"},{"type":"root","text":"lege(leg)","meaning":"법 (law)"}],"story":"평범한 사람이 아닌, 특정 '개인(privi)'에게만 유리하게 적용되는 '법(lege)' → 특권.","example":{"en":"A special privilege.","ko":"특별한 특권."}},
  {"word":"regular","level":"middle","meaning":"규칙적인, 보통의","pronunciation":"/ˈreɡjələr/","parts":[{"type":"root","text":"reg","meaning":"올바른, 다스리다"},{"type":"suffix","text":"-ular","meaning":"형용사형"}],"story":"정해진 '규칙(reg)'이나 올바른 패턴에 맞게 굴러가는 → 규칙적인.","example":{"en":"Regular exercise.","ko":"규칙적인 운동."}},
  {"word":"regulate","level":"high","meaning":"규제하다, 조절하다","pronunciation":"/ˈreɡjuleɪt/","parts":[{"type":"root","text":"reg","meaning":"다스리다, 규칙"},{"type":"suffix","text":"-ate","meaning":"동사형"}],"story":"법이나 '규칙(reg)'을 만들어서 사람들을 '다스리다(ate)' → 규제하다.","example":{"en":"Regulate prices.","ko":"가격을 규제하다."}},
  {"word":"direct","level":"middle","meaning":"직접적인, 지시하다","pronunciation":"/dəˈrekt/","parts":[{"type":"prefix","text":"di-","meaning":"떨어져"},{"type":"root","text":"rect(reg)","meaning":"똑바른"}],"story":"목적지를 향해 굽은 곳 없이 가장 '똑바르게(rect)' 가는 길 → 직접적인.","example":{"en":"A direct flight.","ko":"직항편."}},
  {"word":"correct","level":"middle","meaning":"정확한, 고치다","pronunciation":"/kəˈrekt/","parts":[{"type":"prefix","text":"cor(con)-","meaning":"완전히"},{"type":"root","text":"rect(reg)","meaning":"올바른"}],"story":"틀린 것을 '완전히(cor)' '올바르게(rect)' 만들다 → 정확한, 고치다.","example":{"en":"A correct answer.","ko":"정확한 정답."}},
  {"word":"erect","level":"high","meaning":"똑바로 선, 세우다","pronunciation":"/ɪˈrekt/","parts":[{"type":"prefix","text":"e-","meaning":"위로 (up)"},{"type":"root","text":"rect","meaning":"똑바른"}],"story":"땅에서 '위로(e)' 굽지 않고 '똑바르게(rect)' 올리다 → 세우다.","example":{"en":"Erect a tent.","ko":"텐트를 치다(세우다)."}},
