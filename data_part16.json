[
  {"word":"conceive","level":"high","meaning":"상상하다, 임신하다","pronunciation":"/kənˈsiːv/","parts":[{"type":"prefix","text":"con-","meaning":"완전히 (completely)"},{"type":"root","text":"ceive","meaning":"잡다, 품다 (take)"}],"story":"마음속에 어떤 생각이나 새로운 생명을 '완전히(con)' '품다(ceive)'.","example":{"en":"Conceive a new idea.","ko":"새로운 아이디어를 상상해내다."}},
  {"word":"perceive","level":"high","meaning":"인지하다, 감지하다","pronunciation":"/pərˈsiːv/","parts":[{"type":"prefix","text":"per-","meaning":"완전히, 꿰뚫어"},{"type":"root","text":"ceive","meaning":"잡다 (take)"}],"story":"오감을 통해 주변 상황을 '완전히(per)' '잡아내다(ceive)' → 인지하다.","example":{"en":"Perceive a change.","ko":"변화를 감지하다."}},
  {"word":"reception","level":"middle","meaning":"환영, 접수처","pronunciation":"/rɪˈsepʃn/","parts":[{"type":"prefix","text":"re-","meaning":"다시, 뒤로"},{"type":"root","text":"cept","meaning":"잡다 (take)"},{"type":"suffix","text":"-ion","meaning":"명사형"}],"story":"찾아오는 손님을 뒤에서 '맞이하여 잡는(cept)' 행위나 장소 → 환영, 접수처.","example":{"en":"A wedding reception.","ko":"결혼 피로연(환영회)."}},
  {"word":"perception","level":"high","meaning":"지각, 인식","pronunciation":"/pərˈsepʃn/","parts":[{"type":"root","text":"perceive","meaning":"인지하다"},{"type":"suffix","text":"-ion","meaning":"명사형"}],"story":"사물이나 현상을 감각을 통해 알아차리는 능력 → 지각, 인식.","example":{"en":"Visual perception.","ko":"시각적 인지."}},
  {"word":"susceptible","level":"high","meaning":"민감한, 영향을 받기 쉬운","pronunciation":"/səˈseptəbl/","parts":[{"type":"prefix","text":"sus(sub)-","meaning":"아래에서"},{"type":"root","text":"cept","meaning":"잡다"},{"type":"suffix","text":"-ible","meaning":"할 수 있는"}],"story":"질병이나 감정에 '아래로(sus)' 쉽게 '잡혀먹힐 수 있는(cept)' → 민감한, 취약한.","example":{"en":"Susceptible to colds.","ko":"감기에 걸리기 쉬운."}},
  {"word":"carrier","level":"middle","meaning":"운송 회사, 보균자","pronunciation":"/ˈkæriər/","parts":[{"type":"root","text":"car","meaning":"마차, 싣다 (car)"},{"type":"suffix","text":"-ier","meaning":"사람/사물"}],"story":"물건이나 병균을 마차에 싣고 '나르는(car)' 것 → 운송 회사, 보균자.","example":{"en":"An aircraft carrier.","ko":"항공 모함."}},
  {"word":"charge","level":"middle","meaning":"요금을 청구하다, 기소하다","pronunciation":"/tʃɑːrdʒ/","parts":[{"type":"root","text":"char(car)","meaning":"짐을 싣다"}],"story":"1. 상대에게 비용(짐)을 '지우다' → 청구하다. 2. 죄(짐)를 지우다 → 기소하다.","example":{"en":"Charge a fee.","ko":"요금을 청구하다."}},
  {"word":"discharge","level":"high","meaning":"방출하다, 퇴원시키다","pronunciation":"/dɪsˈtʃɑːrdʒ/","parts":[{"type":"prefix","text":"dis-","meaning":"반대로, 풀다"},{"type":"root","text":"charge","meaning":"짐을 싣다"}],"story":"실어 두었던 짐이나 책임을 '반대로(dis)' '풀어주다(charge)' → 퇴원/제대시키다.","example":{"en":"Discharge from the hospital.","ko":"병원에서 퇴원하다."}},
  {"word":"carriage","level":"middle","meaning":"마차, 객차","pronunciation":"/ˈkærɪdʒ/","parts":[{"type":"root","text":"car","meaning":"마차"},{"type":"suffix","text":"-age","meaning":"명사형"}],"story":"사람이나 짐을 싣고 다니는 바퀴 달린 탈것 → 마차, 기차의 객차.","example":{"en":"A horse-drawn carriage.","ko":"말이 끄는 마차."}},
  {"word":"cargo","level":"middle","meaning":"화물","pronunciation":"/ˈkɑːrɡoʊ/","parts":[{"type":"root","text":"car","meaning":"싣다 (car)"},{"type":"suffix","text":"-go","meaning":"물건"}],"story":"비행기나 배에 '실어 나르는(car)' 커다란 짐 → 화물.","example":{"en":"Load the cargo.","ko":"화물을 싣다."}},
  {"word":"century","level":"middle","meaning":"1세기, 100년","pronunciation":"/ˈsentʃəri/","parts":[{"type":"root","text":"cent","meaning":"백, 100 (hundred)"},{"type":"suffix","text":"-ury","meaning":"기간"}],"story":"'100(cent)'년이 모인 기간 → 1세기.","example":{"en":"The 21st century.","ko":"21세기."}},
  {"word":"percent","level":"middle","meaning":"퍼센트, 백분율","pronunciation":"/pərˈsent/","parts":[{"type":"prefix","text":"per-","meaning":"~당 (per)"},{"type":"root","text":"cent","meaning":"100"}],"story":"전체를 '100(cent)'으로 보았을 때 그 '비율(per)' → 백분율.","example":{"en":"Fifty percent of the people.","ko":"사람들의 50 퍼센트."}},
  {"word":"centimeter","level":"middle","meaning":"센티미터","pronunciation":"/ˈsentɪmiːtər/","parts":[{"type":"root","text":"centi","meaning":"100분의 1"},{"type":"root","text":"meter","meaning":"미터"}],"story":"1미터를 '100(centi)'으로 나눈 길이의 단위 → 센티미터.","example":{"en":"Ten centimeters long.","ko":"길이 10센티미터."}},
  {"word":"centipede","level":"high","meaning":"지네","pronunciation":"/ˈsentɪpiːd/","parts":[{"type":"root","text":"centi","meaning":"100"},{"type":"root","text":"pede(ped)","meaning":"발 (foot)"}],"story":"'100(centi)'개의 '발(pede)'을 가졌다고 여겨지는 벌레 → 지네.","example":{"en":"A poisonous centipede.","ko":"독이 있는 지네."}},
  {"word":"centigrade","level":"high","meaning":"섭씨의","pronunciation":"/ˈsentɪɡreɪd/","parts":[{"type":"root","text":"centi","meaning":"100"},{"type":"root","text":"grade","meaning":"단계, 등급"}],"story":"물이 어는점과 끓는점 사이를 '100(centi)' '단계(grade)'로 나눈 온도 체계.","example":{"en":"30 degrees centigrade.","ko":"섭씨 30도."}},
  {"word":"circle","level":"middle","meaning":"원, 집단","pronunciation":"/ˈsɜːrkl/","parts":[{"type":"root","text":"circ","meaning":"원 (circle)"},{"type":"suffix","text":"-le","meaning":"명사형"}],"story":"둥근 '원(circ)'. 또는 둥글게 모인 사람들의 '집단'.","example":{"en":"Draw a circle.","ko":"원을 그리다."}},
  {"word":"circular","level":"middle","meaning":"원형의, 순환하는","pronunciation":"/ˈsɜːrkjələr/","parts":[{"type":"root","text":"circ","meaning":"원 (circle)"},{"type":"suffix","text":"-ular","meaning":"형용사형"}],"story":"'원(circ)' 모양을 한, 빙빙 도는 → 원형의.","example":{"en":"A circular table.","ko":"원형 테이블."}},
  {"word":"circulate","level":"high","meaning":"순환하다, 유포되다","pronunciation":"/ˈsɜːrkjəleɪt/","parts":[{"type":"root","text":"circul","meaning":"원 (circle)"},{"type":"suffix","text":"-ate","meaning":"동사형"}],"story":"피나 소문이 '원(circ)'을 그리며 한 바퀴 돌아 제자리로 오다 → 순환하다.","example":{"en":"Blood circulates.","ko":"혈액이 순환한다."}},
  {"word":"circumstance","level":"middle","meaning":"상황, 환경","pronunciation":"/ˈsɜːrkəmstæns/","parts":[{"type":"prefix","text":"circum-","meaning":"주변에 (around)"},{"type":"root","text":"stance","meaning":"서 있는 것 (stand)"}],"story":"나의 '주변에(circum)' '서서(stance)' 나를 둘러싼 것들 → 상황, 환경.","example":{"en":"Under no circumstances.","ko":"어떠한 상황에서도 (~않다)."}},
  {"word":"circuit","level":"high","meaning":"순환, 회로","pronunciation":"/ˈsɜːrkɪt/","parts":[{"type":"prefix","text":"circu-","meaning":"주변, 둥글게"},{"type":"root","text":"it","meaning":"가다 (go)"}],"story":"전기나 자동차가 둥글게 한 바퀴 '돌아(circu)' '가는(it)' 길 → 회로, 서킷.","example":{"en":"A short circuit.","ko":"합선 (짧은 회로)."}},
  {"word":"cite","level":"high","meaning":"인용하다, 소환하다","pronunciation":"/saɪt/","parts":[{"type":"root","text":"cit","meaning":"부르다 (call)"}],"story":"증거나 증인을 내 주장 뒷받침용으로 '불러오다(cit)' → 인용하다.","example":{"en":"Cite an example.","ko":"예시를 인용하다."}},
  {"word":"recite","level":"middle","meaning":"암송하다, 낭독하다","pronunciation":"/rɪˈsaɪt/","parts":[{"type":"prefix","text":"re-","meaning":"다시 (again)"},{"type":"root","text":"cite","meaning":"부르다 (call)"}],"story":"외워둔 글이나 시를 사람들 앞에서 '다시(re)' 소리 내어 '부르다(cite)' → 암송하다.","example":{"en":"Recite a poem.","ko":"시를 암송하다."}},
  {"word":"excite","level":"middle","meaning":"흥분시키다","pronunciation":"/ɪkˈsaɪt/","parts":[{"type":"prefix","text":"ex-","meaning":"밖으로 (out)"},{"type":"root","text":"cite","meaning":"자극하다, 부르다"}],"story":"사람의 감정이나 에너지를 '밖으로(ex)' '불러내다(cite)' → 흥분시키다.","example":{"en":"Excite the crowd.","ko":"관중을 흥분시키다."}},
  {"word":"excitement","level":"middle","meaning":"흥분, 신남","pronunciation":"/ɪkˈsaɪtmənt/","parts":[{"type":"root","text":"excite","meaning":"흥분시키다"},{"type":"suffix","text":"-ment","meaning":"명사형"}],"story":"아드레날린이 밖으로 솟구치는 신나고 흥분되는 상태.","example":{"en":"Full of excitement.","ko":"흥분으로 가득 찬."}},
  {"word":"incite","level":"high","meaning":"선동하다, 자극하다","pronunciation":"/ɪnˈsaɪt/","parts":[{"type":"prefix","text":"in-","meaning":"안에서 (in)"},{"type":"root","text":"cite","meaning":"자극하다, 부르다"}],"story":"군중의 마음 '속(in)'에 불을 지르며 행동하라고 '자극하다(cite)' → 선동하다.","example":{"en":"Incite violence.","ko":"폭력을 선동하다."}},
  {"word":"city","level":"middle","meaning":"도시","pronunciation":"/ˈsɪti/","parts":[{"type":"root","text":"cit(civ)","meaning":"시민 (citizen)"},{"type":"suffix","text":"-y","meaning":"명사형"}],"story":"수많은 '시민(civ)'들이 모여 사는 커다란 공간 → 도시.","example":{"en":"A big city.","ko":"대도시."}},
  {"word":"civil","level":"middle","meaning":"시민의, 민사의, 예의 바른","pronunciation":"/ˈsɪvl/","parts":[{"type":"root","text":"civ","meaning":"시민 (citizen)"},{"type":"suffix","text":"-il","meaning":"형용사형"}],"story":"'시민(civ)'과 관련된. 또는 문명화된 시민답게 행동하는 → 예의 바른.","example":{"en":"Civil rights.","ko":"시민권."}},
  {"word":"civilize","level":"high","meaning":"문명화하다, 개화시키다","pronunciation":"/ˈsɪvəlaɪz/","parts":[{"type":"root","text":"civil","meaning":"시민의"},{"type":"suffix","text":"-ize","meaning":"만들다"}],"story":"야만적인 사람들을 법과 질서가 있는 '시민으로(civil)' '만들다(ize)'.","example":{"en":"Civilize society.","ko":"사회를 문명화하다."}},
  {"word":"civilian","level":"high","meaning":"민간인","pronunciation":"/səˈvɪliən/","parts":[{"type":"root","text":"civil","meaning":"시민의"},{"type":"suffix","text":"-ian","meaning":"사람"}],"story":"군인이나 경찰이 아닌 일반 '시민(civil)'인 '사람(ian)'.","example":{"en":"Innocent civilians.","ko":"무고한 민간인들."}},
  {"word":"civic","level":"high","meaning":"시민의, 도시의","pronunciation":"/ˈsɪvɪk/","parts":[{"type":"root","text":"civ","meaning":"시민 (citizen)"},{"type":"suffix","text":"-ic","meaning":"형용사형"}],"story":"'시민(civ)'으로서의 의무나 '도시(civ)'의 운영과 관련된.","example":{"en":"Civic duty.","ko":"시민의 의무."}},
  {"word":"culture","level":"middle","meaning":"문화, 배양","pronunciation":"/ˈkʌltʃər/","parts":[{"type":"root","text":"cult","meaning":"경작하다, 기르다"},{"type":"suffix","text":"-ure","meaning":"명사형"}],"story":"땅을 '경작하듯(cult)' 인간이 지식과 예술을 길러낸 산물 → 문화.","example":{"en":"Korean culture.","ko":"한국 문화."}},
  {"word":"cultivate","level":"high","meaning":"경작하다, 기르다","pronunciation":"/ˈkʌltɪveɪt/","parts":[{"type":"root","text":"cult","meaning":"경작하다"},{"type":"suffix","text":"-ivate","meaning":"동사형"}],"story":"땅을 일구어 작물을 '경작하다(cult)'. 또는 재능을 기르다.","example":{"en":"Cultivate the land.","ko":"땅을 경작하다."}},
  {"word":"agriculture","level":"middle","meaning":"농업","pronunciation":"/ˈæɡrɪkʌltʃər/","parts":[{"type":"root","text":"agri","meaning":"밭 (field)"},{"type":"root","text":"culture","meaning":"경작 (cultivation)"}],"story":"'밭(agri)'을 일구고 '경작하는(culture)' 산업 → 농업.","example":{"en":"The agriculture industry.","ko":"농업."}},
  {"word":"colony","level":"middle","meaning":"식민지, 군락","pronunciation":"/ˈkɑːləni/","parts":[{"type":"root","text":"col(cult)","meaning":"경작하다"},{"type":"suffix","text":"-ony","meaning":"장소"}],"story":"새로운 땅을 '경작하러(col)' 간 사람들이 정착하여 세운 곳 → 식민지.","example":{"en":"A former British colony.","ko":"과거 영국의 식민지."}},
  {"word":"colonist","level":"high","meaning":"식민지 이주자","pronunciation":"/ˈkɑːlənɪst/","parts":[{"type":"root","text":"colony","meaning":"식민지"},{"type":"suffix","text":"-ist","meaning":"사람"}],"story":"새로운 땅을 개척하기 위해 '식민지로(colony)' 간 '사람(ist)'.","example":{"en":"The early colonists.","ko":"초기 식민지 개척자들."}},
  {"word":"epidemic","level":"high","meaning":"유행병, 전염병","pronunciation":"/ˌepɪˈdemɪk/","parts":[{"type":"prefix","text":"epi-","meaning":"~사이에, 퍼져 (among)"},{"type":"root","text":"dem","meaning":"사람 (people)"},{"type":"suffix","text":"-ic","meaning":"명사/형용사형"}],"story":"많은 '사람들(dem)' '사이에(epi)' 무섭게 퍼져나가는 병 → 유행병.","example":{"en":"A flu epidemic.","ko":"독감 유행."}},
  {"word":"pandemic","level":"high","meaning":"세계적인 유행병","pronunciation":"/pænˈdemɪk/","parts":[{"type":"prefix","text":"pan-","meaning":"모든 (all)"},{"type":"root","text":"dem","meaning":"사람 (people)"},{"type":"suffix","text":"-ic","meaning":"형용사형"}],"story":"'모든(pan)' '사람들(dem)'과 전 세계 국가에 영향을 미치는 거대한 전염병.","example":{"en":"The COVID-19 pandemic.","ko":"코로나19 팬데믹."}},
  {"word":"endemic","level":"high","meaning":"풍토병의, 고유한","pronunciation":"/enˈdemɪk/","parts":[{"type":"prefix","text":"en-","meaning":"안에 (in)"},{"type":"root","text":"dem","meaning":"사람, 지역"},{"type":"suffix","text":"-ic","meaning":"형용사형"}],"story":"특정 지역의 '사람들(dem)' '안에서만(en)' 발생하거나 존재하는 → 풍토병의.","example":{"en":"An endemic disease.","ko":"풍토병."}},
  {"word":"demographic","level":"high","meaning":"인구통계학의","pronunciation":"/ˌdeməˈɡræfɪk/","parts":[{"type":"root","text":"demo","meaning":"사람 (people)"},{"type":"root","text":"graph","meaning":"쓰다, 기록하다"}],"story":"'사람들(demo)'의 나이, 성별 등을 조사하여 '기록한(graph)' → 인구통계학의.","example":{"en":"Demographic changes.","ko":"인구통계학적 변화."}},
  {"word":"demagogue","level":"high","meaning":"선동 정치가","pronunciation":"/ˈdeməɡɑːɡ/","parts":[{"type":"root","text":"dem","meaning":"대중 (people)"},{"type":"root","text":"agogue","meaning":"이끄는 사람"}],"story":"거짓말과 감정 호소로 '대중(dem)'을 맘대로 '이끌고 다니는 사람(agogue)' → 선동가.","example":{"en":"A dangerous demagogue.","ko":"위험한 선동 정치가."}},
  {"word":"durable","level":"middle","meaning":"내구성이 있는, 오래가는","pronunciation":"/ˈdʊrəbl/","parts":[{"type":"root","text":"dur","meaning":"단단한, 지속하다 (hard)"},{"type":"suffix","text":"-able","meaning":"할 수 있는"}],"story":"물건이 '단단해서(dur)' 오래 버틸 수 '있는(able)' → 내구성이 있는.","example":{"en":"Durable materials.","ko":"내구성이 강한 재료."}},
  {"word":"duration","level":"middle","meaning":"지속 기간","pronunciation":"/duˈreɪʃn/","parts":[{"type":"root","text":"dur","meaning":"지속하다 (last)"},{"type":"suffix","text":"-ation","meaning":"명사형"}],"story":"어떤 사건이나 행동이 '지속되는(dur)' 기간.","example":{"en":"For the duration of the flight.","ko":"비행이 지속되는 기간 동안."}},
  {"word":"during","level":"middle","meaning":"~하는 동안","pronunciation":"/ˈdʊrɪŋ/","parts":[{"type":"root","text":"dur","meaning":"지속하다"},{"type":"suffix","text":"-ing","meaning":"진행형"}],"story":"어떤 일이 계속 '지속되고(dur)' 있는 중에 → ~하는 동안.","example":{"en":"During the summer.","ko":"여름 동안."}},
  {"word":"endure","level":"high","meaning":"견디다, 참다","pronunciation":"/ɪnˈdʊr/","parts":[{"type":"prefix","text":"en-","meaning":"만들다 (make)"},{"type":"root","text":"dur","meaning":"단단한 (hard)"}],"story":"고통 속에서 내 마음을 돌처럼 '단단하게(dur)' '만들어(en)' 버티다 → 견디다.","example":{"en":"Endure the pain.","ko":"고통을 견디다."}},
  {"word":"endurance","level":"high","meaning":"인내, 지구력","pronunciation":"/ɪnˈdʊrəns/","parts":[{"type":"root","text":"endure","meaning":"견디다"},{"type":"suffix","text":"-ance","meaning":"명사형"}],"story":"힘들고 고된 상황을 꾹 참고 '견뎌내는(endure)' 힘 → 인내력.","example":{"en":"Test your endurance.","ko":"너의 지구력을 시험하다."}}
]