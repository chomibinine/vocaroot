[
  {"word":"reflect","level":"middle","meaning":"반사하다, 반성하다","pronunciation":"/rɪˈflekt/","parts":[{"type":"prefix","text":"re-","meaning":"뒤로 (back)"},{"type":"root","text":"flect","meaning":"구부리다 (bend)"}],"story":"빛이나 생각이 '뒤로(re)' '꺾여(flect)' 되돌아오다 → 반사하다, 되돌아보다.","example":{"en":"The mirror reflects light.","ko":"거울은 빛을 반사한다."}},
  {"word":"flexible","level":"middle","meaning":"유연한","pronunciation":"/ˈfleksəbl/","parts":[{"type":"root","text":"flex","meaning":"구부리다 (bend)"},{"type":"suffix","text":"-ible","meaning":"할 수 있는"}],"story":"쉽게 '구부릴(flex)' 수 '있는(ible)' 성질 → 유연한.","example":{"en":"I have a flexible schedule.","ko":"나는 일정이 유연하다."}},
  {"word":"deflect","level":"high","meaning":"방향을 바꾸다","pronunciation":"/dɪˈflekt/","parts":[{"type":"prefix","text":"de-","meaning":"빗겨서, 아래로"},{"type":"root","text":"flect","meaning":"구부리다 (bend)"}],"story":"날아오는 것을 '빗겨서(de)' '꺾어내다(flect)' → 방향을 바꾸다.","example":{"en":"Deflect the ball.","ko":"공의 방향을 바꾸다."}},
  {"word":"reflex","level":"high","meaning":"반사 작용","pronunciation":"/ˈriːfleks/","parts":[{"type":"prefix","text":"re-","meaning":"뒤로 (back)"},{"type":"root","text":"flex","meaning":"구부러짐 (bend)"}],"story":"자극을 받자마자 무의식적으로 '뒤로(re)' '꺾여(flex)' 나오는 반응 → 반사 작용.","example":{"en":"Quick reflexes.","ko":"빠른 반사 신경."}},
  {"word":"inflect","level":"high","meaning":"굴절하다, 억양을 주다","pronunciation":"/ɪnˈflekt/","parts":[{"type":"prefix","text":"in-","meaning":"안으로 (into)"},{"type":"root","text":"flect","meaning":"구부리다 (bend)"}],"story":"목소리나 단어의 형태를 '안으로(in)' '구부려(flect)' 변화를 주다.","example":{"en":"Inflect a verb.","ko":"동사를 활용하다."}},
  {"word":"president","level":"middle","meaning":"대통령, 회장","pronunciation":"/ˈprezɪdənt/","parts":[{"type":"prefix","text":"pre-","meaning":"앞에 (before)"},{"type":"root","text":"sid","meaning":"앉다 (sit)"}],"story":"회의나 조직의 가장 맨 '앞에(pre)' '앉아 있는(sid)' 사람 → 대통령.","example":{"en":"The president of the company.","ko":"그 회사의 회장."}},
  {"word":"reside","level":"middle","meaning":"거주하다","pronunciation":"/rɪˈzaɪd/","parts":[{"type":"prefix","text":"re-","meaning":"계속 (back/again)"},{"type":"root","text":"sid","meaning":"앉다 (sit)"}],"story":"한 장소에 짐을 풀고 '계속(re)' '앉아(sid)' 있다 → 거주하다.","example":{"en":"He resides in Seoul.","ko":"그는 서울에 거주한다."}},
  {"word":"session","level":"middle","meaning":"회기, 학기","pronunciation":"/ˈseʃn/","parts":[{"type":"root","text":"sess","meaning":"앉다 (sit)"},{"type":"suffix","text":"-ion","meaning":"명사형"}],"story":"사람들이 회의를 위해 모여 '앉아 있는(sess)' 기간 → 회기, 학기.","example":{"en":"The spring session.","ko":"봄 학기."}},
  {"word":"obsess","level":"high","meaning":"집착하게 하다","pronunciation":"/əbˈses/","parts":[{"type":"prefix","text":"ob-","meaning":"~앞에 (against)"},{"type":"root","text":"sess","meaning":"앉다 (sit)"}],"story":"어떤 생각이 머릿속 '앞에(ob)' 딱 버티고 '앉아(sess)' 떠나지 않다 → 집착하게 하다.","example":{"en":"He is obsessed with games.","ko":"그는 게임에 집착한다."}},
  {"word":"assess","level":"high","meaning":"평가하다","pronunciation":"/əˈses/","parts":[{"type":"prefix","text":"as-","meaning":"곁에 (to)"},{"type":"root","text":"sess","meaning":"앉다 (sit)"}],"story":"물건이나 사람 '곁에(as)' '앉아서(sess)' 가치를 매기다 → 평가하다.","example":{"en":"Assess the value.","ko":"가치를 평가하다."}},
  {"word":"current","level":"middle","meaning":"현재의, 흐름","pronunciation":"/ˈkɜːrənt/","parts":[{"type":"root","text":"curr","meaning":"달리다 (run)"},{"type":"suffix","text":"-ent","meaning":"형용사형"}],"story":"지금 이 순간 멈추지 않고 '달리고/흐르고(curr)' 있는 것 → 현재의.","example":{"en":"Current events.","ko":"현재의 사건들(시사)."}},
  {"word":"occur","level":"middle","meaning":"발생하다","pronunciation":"/əˈkɜːr/","parts":[{"type":"prefix","text":"oc-","meaning":"~를 향해 (toward)"},{"type":"root","text":"cur","meaning":"달리다 (run)"}],"story":"어떤 사건이 내 쪽을 '향해(oc)' '달려오다(cur)' → 발생하다.","example":{"en":"An accident occurred.","ko":"사고가 발생했다."}},
  {"word":"excursion","level":"high","meaning":"짧은 여행, 소풍","pronunciation":"/ɪkˈskɜːrʒn/","parts":[{"type":"prefix","text":"ex-","meaning":"밖으로 (out)"},{"type":"root","text":"curs","meaning":"달리다 (run)"}],"story":"일상에서 벗어나 '밖으로(ex)' 신나게 '달려나가는(curs)' 것 → 소풍.","example":{"en":"Go on an excursion.","ko":"소풍을 가다."}},
  {"word":"recur","level":"high","meaning":"재발하다","pronunciation":"/rɪˈkɜːr/","parts":[{"type":"prefix","text":"re-","meaning":"다시 (again)"},{"type":"root","text":"cur","meaning":"달리다 (run)"}],"story":"한 번 끝났던 문제가 '다시(re)' '달려오다(cur)' → 재발하다.","example":{"en":"The pain recurred.","ko":"통증이 재발했다."}},
  {"word":"concur","level":"high","meaning":"동의하다","pronunciation":"/kənˈkɜːr/","parts":[{"type":"prefix","text":"con-","meaning":"함께 (together)"},{"type":"root","text":"cur","meaning":"달리다 (run)"}],"story":"여러 사람의 생각이 '함께(con)' 같은 방향으로 '달려가다(cur)' → 동의하다.","example":{"en":"I completely concur.","ko":"저는 전적으로 동의합니다."}},
  {"word":"value","level":"middle","meaning":"가치, 가치 있게 여기다","pronunciation":"/ˈvæljuː/","parts":[{"type":"root","text":"val","meaning":"가치 있는 (worth)"}],"story":"무언가가 지닌 '가치(val)'나 중요성.","example":{"en":"The value of money.","ko":"돈의 가치."}},
  {"word":"valid","level":"high","meaning":"유효한, 타당한","pronunciation":"/ˈvælɪd/","parts":[{"type":"root","text":"val","meaning":"강한 (strong)"},{"type":"suffix","text":"-id","meaning":"형용사형"}],"story":"주장이나 티켓이 여전히 효력이 '강하고 가치있는(val)' → 유효한.","example":{"en":"A valid passport.","ko":"유효한 여권."}},
  {"word":"evaluate","level":"middle","meaning":"평가하다","pronunciation":"/ɪˈvæljueɪt/","parts":[{"type":"prefix","text":"e-","meaning":"밖으로 (out)"},{"type":"root","text":"val","meaning":"가치 (worth)"}],"story":"어떤 것의 '가치(val)'를 겉으로 '끌어내다(e)' → 평가하다.","example":{"en":"Evaluate the results.","ko":"결과를 평가하다."}},
  {"word":"available","level":"middle","meaning":"이용 가능한","pronunciation":"/əˈveɪləbl/","parts":[{"type":"prefix","text":"a-","meaning":"~에 (to)"},{"type":"root","text":"vail","meaning":"가치, 힘 (worth)"},{"type":"suffix","text":"-able","meaning":"할 수 있는"}],"story":"내가 필요할 때 '가치(vail)'를 발휘'할 수 있는(able)' 상태 → 이용 가능한.","example":{"en":"Tickets are available online.","ko":"티켓은 온라인에서 이용 가능합니다."}},
  {"word":"prevail","level":"high","meaning":"만연하다, 승리하다","pronunciation":"/prɪˈveɪl/","parts":[{"type":"prefix","text":"pre-","meaning":"앞서서"},{"type":"root","text":"vail","meaning":"강하다 (strong)"}],"story":"남들보다 '앞서서(pre)' 힘이 가장 '강하다(vail)' → 승리하다.","example":{"en":"Justice will prevail.","ko":"정의가 승리할 것이다."}},
  {"word":"sequence","level":"middle","meaning":"순서, 연속","pronunciation":"/ˈsiːkwəns/","parts":[{"type":"root","text":"sequ","meaning":"따르다 (follow)"},{"type":"suffix","text":"-ence","meaning":"명사형"}],"story":"사건이나 숫자가 차례대로 꼬리를 '따라오는(sequ)' 것 → 순서, 연속.","example":{"en":"In logical sequence.","ko":"논리적인 순서로."}},
  {"word":"consequence","level":"middle","meaning":"결과, 중요성","pronunciation":"/ˈkɑːnsəkwens/","parts":[{"type":"prefix","text":"con-","meaning":"함께 (together)"},{"type":"root","text":"sequ","meaning":"따르다 (follow)"}],"story":"어떤 원인과 '함께(con)' 필연적으로 '따라오는(sequ)' 것 → 결과.","example":{"en":"Accept the consequences.","ko":"결과를 받아들여라."}},
  {"word":"subsequent","level":"high","meaning":"그 다음의","pronunciation":"/ˈsʌbsɪkwənt/","parts":[{"type":"prefix","text":"sub-","meaning":"뒤에, 아래에 (under)"},{"type":"root","text":"sequ","meaning":"따르다 (follow)"}],"story":"어떤 사건의 바로 '뒤를(sub)' 이어서 '따라오는(sequ)' → 그 다음의.","example":{"en":"Subsequent events.","ko":"그 다음의 사건들."}},
  {"word":"execute","level":"high","meaning":"실행하다, 처형하다","pronunciation":"/ˈeksɪkjuːt/","parts":[{"type":"prefix","text":"ex-","meaning":"밖으로 (out)"},{"type":"root","text":"secut","meaning":"따르다 (follow)"}],"story":"계획이나 명령을 '끝까지(밖으로)' '따라가서(secut)' 해내다 → 실행하다.","example":{"en":"Execute a plan.","ko":"계획을 실행하다."}},
  {"word":"prosecute","level":"high","meaning":"기소하다","pronunciation":"/ˈprɑːsɪkjuːt/","parts":[{"type":"prefix","text":"pro-","meaning":"앞으로 (forward)"},{"type":"root","text":"secut","meaning":"따르다 (follow)"}],"story":"범죄자를 법정 '앞으로(pro)' 계속 '따라가며(secut)' 추궁하다 → 기소하다.","example":{"en":"Prosecute a criminal.","ko":"범죄자를 기소하다."}},
  {"word":"found","level":"middle","meaning":"설립하다, 기초를 두다","pronunciation":"/faʊnd/","parts":[{"type":"root","text":"found","meaning":"바닥 (bottom)"}],"story":"건물이나 조직의 가장 아랫'바닥(found)'을 단단히 다지다 → 설립하다.","example":{"en":"Found a company.","ko":"회사를 설립하다."}},
  {"word":"fundamental","level":"middle","meaning":"근본적인","pronunciation":"/ˌfʌndəˈmentl/","parts":[{"type":"root","text":"fund","meaning":"바닥 (bottom)"},{"type":"suffix","text":"-al","meaning":"형용사형"}],"story":"가장 밑'바닥(fund)'에 깔려 기초가 되는 → 근본적인.","example":{"en":"A fundamental difference.","ko":"근본적인 차이."}},
  {"word":"confuse","level":"middle","meaning":"혼란스럽게 하다","pronunciation":"/kənˈfjuːz/","parts":[{"type":"prefix","text":"con-","meaning":"함께 (together)"},{"type":"root","text":"fuse","meaning":"붓다, 섞다 (pour)"}],"story":"이것저것 '함께(con)' 마구잡이로 '부어(fuse)' 섞어버리다 → 혼란스럽게 하다.","example":{"en":"Don't confuse me.","ko":"나를 헷갈리게 하지 마."}},
  {"word":"refuse","level":"middle","meaning":"거절하다","pronunciation":"/rɪˈfjuːz/","parts":[{"type":"prefix","text":"re-","meaning":"뒤로 (back)"},{"type":"root","text":"fuse","meaning":"붓다 (pour)"}],"story":"상대방이 주는 것을 받지 않고 '뒤로(re)' 엎어 '부어버리다(fuse)' → 거절하다.","example":{"en":"Refuse an offer.","ko":"제안을 거절하다."}},
  {"word":"refund","level":"middle","meaning":"환불(하다)","pronunciation":"/ˈriːfʌnd/","parts":[{"type":"prefix","text":"re-","meaning":"다시 (back)"},{"type":"root","text":"fund","meaning":"붓다, 돈 (pour)"}],"story":"지불했던 돈을 '다시(re)' 지갑으로 '부어주다(fund)' → 환불하다.","example":{"en":"Get a full refund.","ko":"전액 환불을 받다."}},
  {"word":"manual","level":"middle","meaning":"수동의, 설명서","pronunciation":"/ˈmænjuəl/","parts":[{"type":"root","text":"manu","meaning":"손 (hand)"},{"type":"suffix","text":"-al","meaning":"관련된"}],"story":"기계가 아니라 '손(manu)'으로 직접 다루는 → 수동의.","example":{"en":"Manual labor.","ko":"육체 노동."}},
  {"word":"manage","level":"middle","meaning":"관리하다","pronunciation":"/ˈmænɪdʒ/","parts":[{"type":"root","text":"man","meaning":"손 (hand)"},{"type":"suffix","text":"-age","meaning":"동사형"}],"story":"야생마의 고삐를 '손(man)'으로 꽉 잡고 다루다 → 관리하다.","example":{"en":"Manage a team.","ko":"팀을 관리하다."}},
  {"word":"manufacture","level":"middle","meaning":"제조하다","pronunciation":"/ˌmænjuˈfæktʃər/","parts":[{"type":"root","text":"manu","meaning":"손 (hand)"},{"type":"root","text":"fact","meaning":"만들다 (make)"}],"story":"기계가 없던 시절에 '손(manu)'으로 물건을 '만들다(fact)' → 제조하다.","example":{"en":"Manufacture cars.","ko":"자동차를 제조하다."}},
  {"word":"manipulate","level":"high","meaning":"조작하다","pronunciation":"/məˈnɪpjuleɪt/","parts":[{"type":"root","text":"mani","meaning":"손 (hand)"},{"type":"root","text":"pul","meaning":"다루다"}],"story":"기계나 사람의 마음을 내 '손(mani)'바닥 위에서 능숙하게 다루다 → 조작하다.","example":{"en":"Manipulate public opinion.","ko":"여론을 조작하다."}},
  {"word":"manuscript","level":"high","meaning":"원고","pronunciation":"/ˈmænjuskrɪpt/","parts":[{"type":"root","text":"manu","meaning":"손 (hand)"},{"type":"root","text":"script","meaning":"쓰다 (write)"}],"story":"인쇄기가 없던 시절, '손(manu)'으로 직접 '쓴(script)' 책 → 원고.","example":{"en":"An original manuscript.","ko":"원본 원고."}},
  {"word":"minute","level":"middle","meaning":"분, 미세한","pronunciation":"/ˈmɪnɪt/","parts":[{"type":"root","text":"min","meaning":"작은 (small)"},{"type":"suffix","text":"-ute","meaning":"단위"}],"story":"시간을 쪼개고 쪼갠 아주 '작은(min)' 단위 → 분.","example":{"en":"Wait a minute.","ko":"잠깐만 기다려."}},
  {"word":"minor","level":"middle","meaning":"사소한, 미성년자","pronunciation":"/ˈmaɪnər/","parts":[{"type":"root","text":"min","meaning":"작은 (small)"},{"type":"suffix","text":"-or","meaning":"더 ~한"}],"story":"중요도나 나이가 '더 작은(min)' → 사소한, 미성년자.","example":{"en":"A minor problem.","ko":"사소한 문제."}},
  {"word":"minimum","level":"middle","meaning":"최소","pronunciation":"/ˈmɪnɪməm/","parts":[{"type":"root","text":"mini","meaning":"작은 (small)"},{"type":"suffix","text":"-mum","meaning":"가장 ~한"}],"story":"어떤 범위에서 '가장 작은(mini)' 것 → 최소치.","example":{"en":"The minimum wage.","ko":"최저 임금."}},
  {"word":"minister","level":"high","meaning":"장관, 목사","pronunciation":"/ˈmɪnɪstər/","parts":[{"type":"root","text":"mini","meaning":"작은 (small)"},{"type":"suffix","text":"-ster","meaning":"사람"}],"story":"자신을 '작은(mini) 자'로 낮추어 섬기는 사람 → 장관, 목사.","example":{"en":"The prime minister.","ko":"국무총리."}},
  {"word":"diminish","level":"high","meaning":"줄어들다","pronunciation":"/dɪˈmɪnɪʃ/","parts":[{"type":"prefix","text":"di-","meaning":"완전히"},{"type":"root","text":"min","meaning":"작은 (small)"}],"story":"크기나 세력을 '완전히 작게(min)' 만들어 버리다 → 감소시키다.","example":{"en":"His influence diminished.","ko":"그의 영향력이 줄어들었다."}},
  {"word":"part","level":"middle","meaning":"부분, 헤어지다","pronunciation":"/pɑːrt/","parts":[{"type":"root","text":"part","meaning":"나누다 (divide)"}],"story":"전체에서 '나누어진(part)' 한 조각 → 부분.","example":{"en":"Part of the plan.","ko":"계획의 일부."}},
  {"word":"partial","level":"middle","meaning":"부분적인, 편파적인","pronunciation":"/ˈpɑːrʃl/","parts":[{"type":"root","text":"part","meaning":"부분 (part)"},{"type":"suffix","text":"-ial","meaning":"형용사형"}],"story":"전체가 아니라 한 '부분(part)'에만 치우친 → 부분적인, 편파적인.","example":{"en":"A partial refund.","ko":"부분 환불."}},
  {"word":"participate","level":"middle","meaning":"참여하다","pronunciation":"/pɑːrˈtɪsɪpeɪt/","parts":[{"type":"root","text":"parti","meaning":"부분 (part)"},{"type":"root","text":"cip","meaning":"잡다 (take)"}],"story":"행사나 조직에서 내 '부분(part)'을 맡아 '잡다(cip)' → 참여하다.","example":{"en":"Participate in the event.","ko":"행사에 참여하다."}},
  {"word":"apart","level":"middle","meaning":"떨어져서","pronunciation":"/əˈpɑːrt/","parts":[{"type":"prefix","text":"a-","meaning":"~으로"},{"type":"root","text":"part","meaning":"나누다 (divide)"}],"story":"여러 조각/부분(part)으로 나뉘어진 상태 → 떨어져서.","example":{"en":"Take it apart.","ko":"그것을 분해해라."}},
  {"word":"depart","level":"high","meaning":"출발하다","pronunciation":"/dɪˈpɑːrt/","parts":[{"type":"prefix","text":"de-","meaning":"떨어져서"},{"type":"root","text":"part","meaning":"갈라지다"}],"story":"원래 있던 무리에서 '떨어져(de)' '갈라져 나가다(part)' → 출발하다.","example":{"en":"The train departs at 9.","ko":"기차는 9시에 출발한다."}},
  {"word":"animal","level":"middle","meaning":"동물","pronunciation":"/ˈænɪml/","parts":[{"type":"root","text":"anim","meaning":"생명, 숨 (life)"},{"type":"suffix","text":"-al","meaning":"명사형"}],"story":"스스로 숨을 쉬며 '생명(anim)'을 가지고 움직이는 존재 → 동물.","example":{"en":"Wild animals.","ko":"야생 동물들."}},
  {"word":"animate","level":"high","meaning":"생기를 불어넣다","pronunciation":"/ˈænɪmeɪt/","parts":[{"type":"root","text":"anim","meaning":"생명 (life)"},{"type":"suffix","text":"-ate","meaning":"동사형"}],"story":"그림이나 사물에 '생명(anim)'을 주어 살아 움직이게 하다.","example":{"en":"An animated movie.","ko":"애니메이션 영화."}},
