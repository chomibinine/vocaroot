[
  {"word":"brief","level":"middle","meaning":"짧은, 간단한","pronunciation":"/briːf/","parts":[{"type":"root","text":"brev(brief)","meaning":"짧은 (short)"}],"story":"시간이나 길이가 '짧은(brev)' → 간단한, 짧은.","example":{"en":"A brief summary.","ko":"간단한 요약."}},
  {"word":"abbreviate","level":"high","meaning":"줄여 쓰다, 요약하다","pronunciation":"/əˈbriːvieɪt/","parts":[{"type":"prefix","text":"ab(ad)-","meaning":"~로 (to)"},{"type":"root","text":"brev","meaning":"짧은 (short)"},{"type":"suffix","text":"-ate","meaning":"동사형"}],"story":"단어나 문장을 어떤 한도를 향해 '짧게(brev)' '만들다(ate)' → 줄여 쓰다.","example":{"en":"Abbreviate the word.","ko":"단어를 줄여 쓰다."}},
  {"word":"brevity","level":"high","meaning":"간결함","pronunciation":"/ˈbrevəti/","parts":[{"type":"root","text":"brev","meaning":"짧은 (short)"},{"type":"suffix","text":"-ity","meaning":"명사형"}],"story":"말이나 글이 '짧은(brev)' 상태 → 간결함.","example":{"en":"The brevity of human life.","ko":"인생의 덧없음(짧음)."}},
  {"word":"briefcase","level":"middle","meaning":"서류 가방","pronunciation":"/ˈbriːfkeɪs/","parts":[{"type":"root","text":"brief","meaning":"짧은, 소송 서류"},{"type":"root","text":"case","meaning":"상자"}],"story":"변호사들이 법정에 들고 가는 '짧은(brief)' 소송 서류들을 담는 가방 → 서류 가방.","example":{"en":"Carry a briefcase.","ko":"서류 가방을 들고 다니다."}},
  {"word":"briefing","level":"middle","meaning":"보고, 브리핑","pronunciation":"/ˈbriːfɪŋ/","parts":[{"type":"root","text":"brief","meaning":"짧은, 보고서"},{"type":"suffix","text":"-ing","meaning":"명사형"}],"story":"어떤 상황을 '짧고(brief)' 간결하게 요약해서 알려주는 시간 → 브리핑.","example":{"en":"A morning briefing.","ko":"아침 브리핑."}},
  {"word":"candle","level":"middle","meaning":"양초","pronunciation":"/ˈkændl/","parts":[{"type":"root","text":"cand","meaning":"빛나는, 하얀 (glowing)"}],"story":"어둠 속에서 '빛나게(cand)' 불을 밝히는 도구 → 양초.","example":{"en":"Blow out the candle.","ko":"양초를 불어서 끄다."}},
  {"word":"candid","level":"high","meaning":"솔직한, 숨김없는","pronunciation":"/ˈkændɪd/","parts":[{"type":"root","text":"cand","meaning":"하얀, 순수한 (white)"},{"type":"suffix","text":"-id","meaning":"형용사형"}],"story":"마음속에 검은 의도가 없이 '하얗고(cand)' 순수한 → 솔직한.","example":{"en":"A candid interview.","ko":"솔직한 인터뷰."}},
  {"word":"candidate","level":"middle","meaning":"후보자","pronunciation":"/ˈkændɪdət/","parts":[{"type":"root","text":"cand","meaning":"하얀 (white)"},{"type":"suffix","text":"-ate","meaning":"사람"}],"story":"고대 로마에서 관직에 출마하는 사람이 '순수함(cand)'을 보여주기 위해 하얀 옷을 입은 데서 유래 → 후보자.","example":{"en":"A presidential candidate.","ko":"대통령 후보자."}},
  {"word":"candor","level":"high","meaning":"솔직함, 정직","pronunciation":"/ˈkændər/","parts":[{"type":"root","text":"cand","meaning":"하얀, 맑은"},{"type":"suffix","text":"-or","meaning":"명사형"}],"story":"마음이 하얗고 맑아 숨김이 없는 상태 → 솔직함.","example":{"en":"Speak with candor.","ko":"솔직하게 말하다."}},
  {"word":"incandescent","level":"high","meaning":"백열의, 눈부신","pronunciation":"/ˌɪnkænˈdesnt/","parts":[{"type":"prefix","text":"in-","meaning":"안에 (in)"},{"type":"root","text":"cand","meaning":"빛나는"},{"type":"suffix","text":"-escent","meaning":"상태로 변하는"}],"story":"안에서 열이 발생하여 '하얗게 빛나는(cand)' 상태가 되는 → 눈부신, 백열의.","example":{"en":"An incandescent light bulb.","ko":"백열전구."}},
  {"word":"donate","level":"middle","meaning":"기부하다","pronunciation":"/ˈdoʊneɪt/","parts":[{"type":"root","text":"don","meaning":"주다 (give)"},{"type":"suffix","text":"-ate","meaning":"동사형"}],"story":"내가 가진 돈이나 물건을 대가 없이 '주다(don)' → 기부하다.","example":{"en":"Donate money to charity.","ko":"자선 단체에 돈을 기부하다."}},
  {"word":"donor","level":"middle","meaning":"기증자, 헌혈자","pronunciation":"/ˈdoʊnər/","parts":[{"type":"root","text":"don","meaning":"주다 (give)"},{"type":"suffix","text":"-or","meaning":"사람"}],"story":"자신의 장기나 재산을 남에게 '주는(don)' 사람 → 기증자.","example":{"en":"An organ donor.","ko":"장기 기증자."}},
  {"word":"pardon","level":"middle","meaning":"용서하다, 사면하다","pronunciation":"/ˈpɑːrdn/","parts":[{"type":"prefix","text":"par(per)-","meaning":"완전히 (completely)"},{"type":"root","text":"don","meaning":"주다 (give)"}],"story":"상대방의 죄를 '완전히(par)' 면제해 '주다(don)' → 용서하다.","example":{"en":"I beg your pardon.","ko":"(다시 말해 달라는 의미의) 용서해 주십시오."}},
  {"word":"anecdote","level":"high","meaning":"일화, 숨은 이야기","pronunciation":"/ˈænɪkdoʊt/","parts":[{"type":"prefix","text":"an-","meaning":"아닌 (not)"},{"type":"prefix","text":"ec-","meaning":"밖으로 (out)"},{"type":"root","text":"dote(don)","meaning":"주다 (give)"}],"story":"세상 '밖으로(ec)' 아직 '주어지지(dote)' '않은(an)' 숨겨진 이야기 → 일화.","example":{"en":"A funny anecdote.","ko":"재미있는 일화."}},
  {"word":"dose","level":"high","meaning":"(약의) 복용량","pronunciation":"/doʊs/","parts":[{"type":"root","text":"dos(don)","meaning":"주다 (give)"}],"story":"환자에게 한 번에 먹으라고 '주어지는(dos)' 약의 양 → 복용량.","example":{"en":"A high dose of vitamin C.","ko":"비타민 C 고용량."}},
  {"word":"flower","level":"middle","meaning":"꽃","pronunciation":"/ˈflaʊər/","parts":[{"type":"root","text":"flow(flor)","meaning":"꽃 (flower)"}],"story":"식물에서 아름답게 피어나는 부분.","example":{"en":"A beautiful flower.","ko":"아름다운 꽃."}},
  {"word":"flourish","level":"high","meaning":"번창하다, 잘 자라다","pronunciation":"/ˈflɜːrɪʃ/","parts":[{"type":"root","text":"flour(flor)","meaning":"꽃 (flower)"},{"type":"suffix","text":"-ish","meaning":"동사형"}],"story":"'꽃(flour)'이 활짝 피어나듯 사업이나 식물이 잘 자라다 → 번창하다.","example":{"en":"The business is flourishing.","ko":"사업이 번창하고 있다."}},
  {"word":"floral","level":"middle","meaning":"꽃의, 꽃무늬의","pronunciation":"/ˈflɔːrəl/","parts":[{"type":"root","text":"flor","meaning":"꽃 (flower)"},{"type":"suffix","text":"-al","meaning":"형용사형"}],"story":"'꽃(flor)'과 관련된 무늬나 향기를 가진.","example":{"en":"A floral dress.","ko":"꽃무늬 드레스."}},
  {"word":"florist","level":"middle","meaning":"꽃집 주인, 플로리스트","pronunciation":"/ˈflɔːrɪst/","parts":[{"type":"root","text":"flor","meaning":"꽃 (flower)"},{"type":"suffix","text":"-ist","meaning":"사람"}],"story":"'꽃(flor)'을 다루고 파는 '사람(ist)'.","example":{"en":"Buy flowers from a florist.","ko":"꽃집에서 꽃을 사다."}},
  {"word":"flour","level":"middle","meaning":"밀가루","pronunciation":"/ˈflaʊər/","parts":[{"type":"root","text":"flour(flor)","meaning":"꽃, 가장 좋은 부분"}],"story":"과거에는 곡물을 빻아 얻은 '가장 고운(꽃 같은)' 부분을 flour라고 부름 → 밀가루.","example":{"en":"Wheat flour.","ko":"밀가루."}},
  {"word":"grave","level":"middle","meaning":"무덤, 심각한","pronunciation":"/ɡreɪv/","parts":[{"type":"root","text":"grav","meaning":"무거운 (heavy)"}],"story":"마음이 짓눌리듯 '무거운(grav)' 상태 → 심각한. 무거운 돌을 얹은 곳 → 무덤.","example":{"en":"A grave mistake.","ko":"심각한 실수."}},
  {"word":"gravity","level":"middle","meaning":"중력, 심각성","pronunciation":"/ˈɡrævəti/","parts":[{"type":"root","text":"grav","meaning":"무거운 (heavy)"},{"type":"suffix","text":"-ity","meaning":"명사형"}],"story":"지구가 물체를 '무겁게(grav)' 아래로 끌어당기는 힘 → 중력.","example":{"en":"The law of gravity.","ko":"중력의 법칙."}},
  {"word":"grief","level":"middle","meaning":"큰 슬픔","pronunciation":"/ɡriːf/","parts":[{"type":"root","text":"grief(grav)","meaning":"무거운 (heavy)"}],"story":"마음을 짓누르는 아주 '무거운(grief)' 감정 → 깊은 슬픔.","example":{"en":"Overcome with grief.","ko":"큰 슬픔에 잠긴."}},
  {"word":"grieve","level":"high","meaning":"비통해하다, 슬퍼하다","pronunciation":"/ɡriːv/","parts":[{"type":"root","text":"griev(grav)","meaning":"무거운 (heavy)"}],"story":"마음에 '무거운(griev)' 슬픔을 안고 아파하다.","example":{"en":"Grieve for the dead.","ko":"죽은 이를 애도하다."}},
  {"word":"aggravate","level":"high","meaning":"악화시키다","pronunciation":"/ˈæɡrəveɪt/","parts":[{"type":"prefix","text":"ag(ad)-","meaning":"~로 (to)"},{"type":"root","text":"grav","meaning":"무거운 (heavy)"},{"type":"suffix","text":"-ate","meaning":"동사형"}],"story":"상황이나 병을 지금보다 더 '무겁게(grav)' '만들다(ate)' → 악화시키다.","example":{"en":"Aggravate the problem.","ko":"문제를 악화시키다."}},
  {"word":"habit","level":"middle","meaning":"습관","pronunciation":"/ˈhæbɪt/","parts":[{"type":"root","text":"hab","meaning":"가지다 (have)"}],"story":"내가 오랫동안 내 몸에 '가지고(hab)' 있는 행동 → 습관.","example":{"en":"Break a bad habit.","ko":"나쁜 습관을 고치다."}},
  {"word":"habitat","level":"middle","meaning":"서식지","pronunciation":"/ˈhæbɪtæt/","parts":[{"type":"root","text":"habit","meaning":"살다, 가지다"},{"type":"suffix","text":"-at","meaning":"장소"}],"story":"동식물이 자연 상태로 '살고 있는(hab)' 장소 → 서식지.","example":{"en":"Destroy animal habitats.","ko":"동물의 서식지를 파괴하다."}},
  {"word":"inhabit","level":"high","meaning":"거주하다, 서식하다","pronunciation":"/ɪnˈhæbɪt/","parts":[{"type":"prefix","text":"in-","meaning":"안에 (in)"},{"type":"root","text":"habit","meaning":"살다 (dwell)"}],"story":"어떤 장소 '안에(in)' 자리를 잡고 '살다(habit)'.","example":{"en":"The island is inhabited by birds.","ko":"그 섬에는 새들이 서식한다."}},
  {"word":"exhibit","level":"middle","meaning":"전시하다, 보여주다","pronunciation":"/ɪɡˈzɪbɪt/","parts":[{"type":"prefix","text":"ex-","meaning":"밖으로 (out)"},{"type":"root","text":"hibit(hab)","meaning":"가지다 (have)"}],"story":"내가 '가지고(hibit)' 있는 것을 남들이 보도록 '밖으로(ex)' 꺼내놓다 → 전시하다.","example":{"en":"Exhibit artwork.","ko":"예술품을 전시하다."}},
  {"word":"prohibit","level":"high","meaning":"금지하다","pronunciation":"/prəˈhɪbɪt/","parts":[{"type":"prefix","text":"pro-","meaning":"앞에서 (in front)"},{"type":"root","text":"hibit(hab)","meaning":"가지다, 유지하다"}],"story":"남이 행동하지 못하게 '앞에서(pro)' 선을 그어 '유지하다(hibit)' → 막다, 금지하다.","example":{"en":"Smoking is prohibited.","ko":"흡연은 금지되어 있다."}},
  {"word":"liberty","level":"middle","meaning":"자유","pronunciation":"/ˈlɪbərti/","parts":[{"type":"root","text":"liber","meaning":"자유로운 (free)"},{"type":"suffix","text":"-ty","meaning":"명사형"}],"story":"속박에서 벗어나 '자유로운(liber)' 상태 → 자유.","example":{"en":"The Statue of Liberty.","ko":"자유의 여신상."}},
  {"word":"liberal","level":"high","meaning":"자유민주적인, 관대한","pronunciation":"/ˈlɪbərəl/","parts":[{"type":"root","text":"liber","meaning":"자유로운 (free)"},{"type":"suffix","text":"-al","meaning":"형용사형"}],"story":"생각이나 제도가 '자유로운(liber)' 것을 추구하는 → 자유주의의, 관대한.","example":{"en":"Liberal arts.","ko":"교양 과목 (자유 인문학)."}},
  {"word":"liberate","level":"high","meaning":"해방시키다, 자유롭게 하다","pronunciation":"/ˈlɪbəreɪt/","parts":[{"type":"root","text":"liber","meaning":"자유로운 (free)"},{"type":"suffix","text":"-ate","meaning":"만들다"}],"story":"억압받는 사람들을 '자유롭게(liber)' '만들어주다(ate)' → 해방시키다.","example":{"en":"Liberate the slaves.","ko":"노예를 해방시키다."}},
  {"word":"deliver","level":"middle","meaning":"배달하다, 연설하다, 구출하다","pronunciation":"/dɪˈlɪvər/","parts":[{"type":"prefix","text":"de-","meaning":"완전히"},{"type":"root","text":"liver(liber)","meaning":"자유롭게 하다"}],"story":"1. 물건을 속박에서 풀어 '자유롭게' 넘겨주다 → 배달하다. 2. 위험에서 '자유롭게' 하다 → 구출하다.","example":{"en":"Deliver a package.","ko":"소포를 배달하다."}},
  {"word":"liberation","level":"high","meaning":"해방, 석방","pronunciation":"/ˌlɪbəˈreɪʃn/","parts":[{"type":"root","text":"liberate","meaning":"해방하다"},{"type":"suffix","text":"-ion","meaning":"명사형"}],"story":"자유가 없는 곳에서 자유롭게 되는 사건이나 행동 → 해방.","example":{"en":"National liberation.","ko":"국가 해방."}},
  {"word":"lucid","level":"high","meaning":"명쾌한, 맑은","pronunciation":"/ˈluːsɪd/","parts":[{"type":"root","text":"luc","meaning":"빛 (light)"},{"type":"suffix","text":"-id","meaning":"형용사형"}],"story":"'빛(luc)'이 통과하는 것처럼 흐림이 없고 뚜렷한 → 명쾌한.","example":{"en":"A lucid explanation.","ko":"명쾌한 설명."}},
  {"word":"illuminate","level":"high","meaning":"비추다, 명백히 밝히다","pronunciation":"/ɪˈluːmɪneɪt/","parts":[{"type":"prefix","text":"il(in)-","meaning":"안에, ~로 (in)"},{"type":"root","text":"lumin","meaning":"빛 (light)"},{"type":"suffix","text":"-ate","meaning":"만들다"}],"story":"어두운 곳에 '빛(lumin)'을 비추어 훤하게 '만들다(ate)' → 비추다, (사실을) 밝히다.","example":{"en":"Illuminate the room.","ko":"방을 환하게 비추다."}},
  {"word":"illustrate","level":"middle","meaning":"삽화를 넣다, 설명하다","pronunciation":"/ˈɪləstreɪt/","parts":[{"type":"prefix","text":"il(in)-","meaning":"안으로"},{"type":"root","text":"lus","meaning":"빛 (light)"},{"type":"suffix","text":"-ate","meaning":"동사형"}],"story":"그림(빛)을 던져 주어 내용이 환하게 이해되도록 '만들다(ate)' → 삽화를 넣다, 설명하다.","example":{"en":"Illustrate a book.","ko":"책에 삽화를 넣다."}},
  {"word":"luminous","level":"high","meaning":"어둠에서 빛나는, 야광의","pronunciation":"/ˈluːmɪnəs/","parts":[{"type":"root","text":"lumin","meaning":"빛 (light)"},{"type":"suffix","text":"-ous","meaning":"가득한"}],"story":"'빛(lumin)'이 '가득한(ous)' → 빛을 내는, 반짝이는.","example":{"en":"Luminous stars.","ko":"빛나는 별들."}},
  {"word":"luxury","level":"middle","meaning":"호화로움, 사치","pronunciation":"/ˈlʌkʃəri/","parts":[{"type":"root","text":"lux","meaning":"빛 (light)"},{"type":"suffix","text":"-ury","meaning":"명사형"}],"story":"번쩍번쩍 '빛(lux)'이 날 정도로 값비싸고 화려한 생활 → 호화로움.","example":{"en":"Live in luxury.","ko":"호화롭게 살다."}},
  {"word":"memory","level":"middle","meaning":"기억, 기억력","pronunciation":"/ˈmeməri/","parts":[{"type":"root","text":"mem","meaning":"마음에 두다 (remember)"},{"type":"suffix","text":"-ory","meaning":"명사형"}],"story":"경험을 마음속에 '담아둔(mem)' 것 → 기억.","example":{"en":"A good memory.","ko":"좋은 기억력."}},
  {"word":"remember","level":"middle","meaning":"기억하다","pronunciation":"/rɪˈmembər/","parts":[{"type":"prefix","text":"re-","meaning":"다시 (again)"},{"type":"root","text":"member(mem)","meaning":"마음에 두다"}],"story":"잊혀졌던 것을 '다시(re)' '마음에 떠올리다(mem)' → 기억하다.","example":{"en":"I remember you.","ko":"나는 널 기억해."}},
  {"word":"memo","level":"middle","meaning":"메모, 기록","pronunciation":"/ˈmemoʊ/","parts":[{"type":"root","text":"memo(mem)","meaning":"기억하다"}],"story":"나중에 다시 '기억하기(mem)' 위해 짧게 적어두는 글 → 메모.","example":{"en":"Leave a memo.","ko":"메모를 남기다."}},
  {"word":"monument","level":"high","meaning":"기념비, 기념물","pronunciation":"/ˈmɑːnjumənt/","parts":[{"type":"root","text":"monu(mem)","meaning":"기억하다, 상기시키다"},{"type":"suffix","text":"-ment","meaning":"명사형"}],"story":"어떤 사람이나 사건을 '기억하게(monu)' 만들어 놓은 건축물 → 기념비.","example":{"en":"A national monument.","ko":"국가 기념물."}},
  {"word":"amnesia","level":"high","meaning":"기억 상실증","pronunciation":"/æmˈniːʒə/","parts":[{"type":"prefix","text":"a-","meaning":"없는 (without)"},{"type":"root","text":"mnes(mem)","meaning":"기억 (memory)"},{"type":"suffix","text":"-ia","meaning":"질병"}],"story":"과거의 '기억(mnes)'이 '사라진(a)' 병 → 기억 상실증.","example":{"en":"Suffer from amnesia.","ko":"기억 상실증을 앓다."}}
]