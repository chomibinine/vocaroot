[
  {"word":"essence","level":"high","meaning":"본질, 정수","pronunciation":"/ˈesns/","parts":[{"type":"root","text":"ess","meaning":"존재하다 (be)"},{"type":"suffix","text":"-ence","meaning":"명사형"}],"story":"어떤 사물이 그것으로 '존재하게(ess)' 만드는 가장 중요한 알맹이 → 본질.","example":{"en":"The essence of the problem.","ko":"문제의 본질."}},
  {"word":"essential","level":"middle","meaning":"필수적인, 본질적인","pronunciation":"/ɪˈsenʃl/","parts":[{"type":"root","text":"essent(essence)","meaning":"본질, 존재"},{"type":"suffix","text":"-ial","meaning":"형용사형"}],"story":"사물이 '존재하기(ess)' 위해 반드시 필요한 → 필수적인.","example":{"en":"Water is essential for life.","ko":"물은 생명에 필수적이다."}},
  {"word":"present","level":"middle","meaning":"현재의, 참석한, 선물","pronunciation":"/ˈpreznt/","parts":[{"type":"prefix","text":"pre-","meaning":"앞에 (before)"},{"type":"root","text":"sent(ess)","meaning":"존재하다 (be)"}],"story":"내 '눈앞에(pre)' 살아 '존재하는(sent)' 것 → 현재, 참석한. 눈앞에 내미는 것 → 선물.","example":{"en":"At the present time.","ko":"현재 시간에."}},
  {"word":"represent","level":"middle","meaning":"대표하다, 나타내다","pronunciation":"/ˌreprɪˈzent/","parts":[{"type":"prefix","text":"re-","meaning":"다시, 대신하여"},{"type":"root","text":"present","meaning":"참석한, 존재하는"}],"story":"자신을 뽑아준 사람들을 '대신하여(re)' 무대 위에 '존재하다(present)' → 대표하다.","example":{"en":"Represent the country.","ko":"나라를 대표하다."}},
  {"word":"absent","level":"middle","meaning":"결석한, 부재중인","pronunciation":"/ˈæbsənt/","parts":[{"type":"prefix","text":"ab-","meaning":"멀리, 떨어져 (away)"},{"type":"root","text":"sent(ess)","meaning":"존재하다 (be)"}],"story":"원래 있어야 할 교실에서 '멀리 떨어져서(ab)' '존재하는(sent)' → 결석한.","example":{"en":"Absent from school.","ko":"학교에 결석한."}},
  {"word":"esteem","level":"high","meaning":"존경, 존중하다","pronunciation":"/ɪˈstiːm/","parts":[{"type":"root","text":"esteem(estim)","meaning":"가치를 매기다 (value)"}],"story":"그 사람의 가치(estim)를 아주 높게 매기다 → 존경하다.","example":{"en":"Hold in high esteem.","ko":"깊이 존경하다."}},
  {"word":"estimate","level":"middle","meaning":"추정하다, 견적","pronunciation":"/ˈestɪmeɪt/","parts":[{"type":"root","text":"estim","meaning":"평가하다 (value)"},{"type":"suffix","text":"-ate","meaning":"동사형"}],"story":"집이나 차의 가격(가치)을 대략적으로 계산하여 '평가해보다(estim)' → 추정하다, 견적을 내다.","example":{"en":"Estimate the cost.","ko":"비용을 추정하다."}},
  {"word":"underestimate","level":"high","meaning":"과소평가하다","pronunciation":"/ˌʌndərˈestɪmeɪt/","parts":[{"type":"prefix","text":"under-","meaning":"아래로 (below)"},{"type":"root","text":"estimate","meaning":"평가하다"}],"story":"상대방의 진짜 실력이나 가치보다 한참 '아래로(under)' 낮춰서 '평가하다(estimate)'.","example":{"en":"Never underestimate your rival.","ko":"절대 적을 과소평가하지 마라."}},
  {"word":"overestimate","level":"high","meaning":"과대평가하다","pronunciation":"/ˌoʊvərˈestɪmeɪt/","parts":[{"type":"prefix","text":"over-","meaning":"넘어서 (above)"},{"type":"root","text":"estimate","meaning":"평가하다"}],"story":"사물의 진짜 가치를 '뛰어넘어(over)' 지나치게 높게 '평가하다(estimate)'.","example":{"en":"Overestimate the damage.","ko":"피해를 과대평가하다."}},
  {"word":"estimable","level":"high","meaning":"존경할 만한","pronunciation":"/ˈestɪməbl/","parts":[{"type":"root","text":"estim","meaning":"가치, 존경"},{"type":"suffix","text":"-able","meaning":"할 수 있는"}],"story":"그 사람이 가진 훌륭한 가치로 인해 충분히 '존경(estim)'받을 수 '있는(able)'.","example":{"en":"An estimable achievement.","ko":"존경할 만한 업적."}},
  {"word":"fare","level":"middle","meaning":"요금, 운임","pronunciation":"/fer/","parts":[{"type":"root","text":"fare","meaning":"가다, 여행하다 (go)"}],"story":"과거에 배나 마차를 타고 '여행해 갈(fare)' 때 내던 돈 → 교통 요금.","example":{"en":"Pay the bus fare.","ko":"버스 요금을 내다."}},
  {"word":"farewell","level":"middle","meaning":"작별 인사, 이별의","pronunciation":"/ˌferˈwel/","parts":[{"type":"root","text":"fare","meaning":"가다 (go)"},{"type":"root","text":"well","meaning":"잘 (well)"}],"story":"떠나는 사람에게 '잘(well)' '가라(fare)'고 인사해 주는 것 → 작별 인사.","example":{"en":"A farewell party.","ko":"송별회."}},
  {"word":"welfare","level":"middle","meaning":"복지, 안녕","pronunciation":"/ˈwelfer/","parts":[{"type":"root","text":"wel(well)","meaning":"잘 (well)"},{"type":"root","text":"fare","meaning":"지내다, 가다 (go)"}],"story":"모든 국민이 아프지 않고 '잘(well)' '살아가도록(fare)' 돕는 제도 → 복지.","example":{"en":"Social welfare.","ko":"사회 복지."}},
  {"word":"warfare","level":"high","meaning":"전쟁, 전투","pronunciation":"/ˈwɔːrfer/","parts":[{"type":"root","text":"war","meaning":"전쟁"},{"type":"root","text":"fare","meaning":"가다, 수행하다"}],"story":"무기를 들고 적과 '전쟁(war)'을 하러 '나아가는(fare)' 행위 → 전투.","example":{"en":"Modern warfare.","ko":"현대전."}},
  {"word":"ferry","level":"middle","meaning":"연락선, 나르다","pronunciation":"/ˈferi/","parts":[{"type":"root","text":"fer(fare)","meaning":"가다, 나르다 (carry)"},{"type":"suffix","text":"-y","meaning":"명사형"}],"story":"강이나 바다를 건너 사람과 차를 '실어 나르는(fer)' 배 → 연락선, 페리.","example":{"en":"Take a ferry to the island.","ko":"섬으로 가는 페리를 타다."}},
  {"word":"figure","level":"middle","meaning":"수치, 인물, 모양","pronunciation":"/ˈfɪɡjər/","parts":[{"type":"root","text":"fig","meaning":"만들다, 형태 (form)"},{"type":"suffix","text":"-ure","meaning":"명사형"}],"story":"흙을 빚어 '만들어낸(fig)' 형태 → 모양, 인물. (모양을 숫자로 나타낸 것 → 수치).","example":{"en":"A famous historical figure.","ko":"유명한 역사적 인물."}},
  {"word":"configure","level":"high","meaning":"환경을 설정하다, 구성하다","pronunciation":"/kənˈfɪɡjər/","parts":[{"type":"prefix","text":"con-","meaning":"함께 (together)"},{"type":"root","text":"figure","meaning":"형태를 만들다"}],"story":"컴퓨터 부품이나 프로그램을 '함께(con)' 맞춰서 올바른 '형태로 만들다(figure)' → 환경을 설정하다.","example":{"en":"Configure the router.","ko":"라우터(공유기) 환경을 설정하다."}},
  {"word":"feature","level":"middle","meaning":"특징, 이목구비, 특징으로 삼다","pronunciation":"/ˈfiːtʃər/","parts":[{"type":"root","text":"feat(fig)","meaning":"만들다, 형태 (make)"},{"type":"suffix","text":"-ure","meaning":"명사형"}],"story":"사람의 얼굴이나 사물이 '만들어진(feat)' 고유한 생김새 → 특징, 이목구비.","example":{"en":"A key feature of the product.","ko":"그 제품의 핵심 특징."}},
  {"word":"figurative","level":"high","meaning":"비유적인","pronunciation":"/ˈfɪɡjərətɪv/","parts":[{"type":"root","text":"figure","meaning":"모양, 비유"},{"type":"suffix","text":"-ative","meaning":"형용사형"}],"story":"어떤 '모양이나 형태(figure)'에 빗대어 묘사하는 → 비유적인.","example":{"en":"Literal and figurative meanings.","ko":"글자 그대로의 의미와 비유적 의미."}},
  {"word":"disfigure","level":"high","meaning":"흉하게 만들다","pronunciation":"/dɪsˈfɪɡjər/","parts":[{"type":"prefix","text":"dis-","meaning":"망가뜨려 (ruin)"},{"type":"root","text":"figure","meaning":"형태, 외모"}],"story":"원래의 아름다운 '형태나 외모(figure)'를 훼손시켜 '망가뜨리다(dis)' → 흉하게 만들다.","example":{"en":"Disfigured by a burn.","ko":"화상으로 흉해진."}},
  {"word":"gesture","level":"middle","meaning":"몸짓, 제스처","pronunciation":"/ˈdʒestʃər/","parts":[{"type":"root","text":"gest","meaning":"나르다, 행동하다 (carry)"},{"type":"suffix","text":"-ure","meaning":"명사형"}],"story":"자신의 생각이나 감정을 몸의 움직임으로 '나르는(gest)' 행위 → 제스처.","example":{"en":"A friendly gesture.","ko":"친근한 제스처(몸짓)."}},
  {"word":"digest","level":"middle","meaning":"소화하다, 요약하다","pronunciation":"/daɪˈdʒest/","parts":[{"type":"prefix","text":"di(dis)-","meaning":"따로따로, 분리하여"},{"type":"root","text":"gest","meaning":"나르다 (carry)"}],"story":"위장 속에서 음식을 잘게 부수어 '따로따로(di)' '실어 나르다(gest)' → 소화하다.","example":{"en":"Hard to digest.","ko":"소화하기 어려운."}},
  {"word":"suggest","level":"middle","meaning":"제안하다, 암시하다","pronunciation":"/səɡˈdʒest/","parts":[{"type":"prefix","text":"sug(sub)-","meaning":"아래에서 (under)"},{"type":"root","text":"gest","meaning":"나르다 (carry)"}],"story":"내 생각을 상대방 '아래에(sug)' 살며시 '가져다 놓다(gest)' → 제안하다.","example":{"en":"Suggest a new idea.","ko":"새 아이디어를 제안하다."}},
  {"word":"register","level":"middle","meaning":"등록하다, 명부","pronunciation":"/ˈredʒɪstər/","parts":[{"type":"prefix","text":"re-","meaning":"뒤로, 기록하여 (back)"},{"type":"root","text":"gist(gest)","meaning":"나르다 (carry)"}],"story":"중요한 정보나 이름을 명부에 '기록하여(re)' 장부로 '가져가다(gist)' → 등록하다.","example":{"en":"Register for a class.","ko":"수업에 등록하다."}},
  {"word":"congestion","level":"high","meaning":"혼잡, 밀집","pronunciation":"/kənˈdʒestʃən/","parts":[{"type":"prefix","text":"con-","meaning":"함께 (together)"},{"type":"root","text":"gest","meaning":"나르다 (carry)"},{"type":"suffix","text":"-ion","meaning":"명사형"}],"story":"차량이나 사람들이 한 곳으로 '함께(con)' '실려 와서(gest)' 꽉 막힌 상태 → 혼잡.","example":{"en":"Traffic congestion.","ko":"교통 혼잡."}},
  {"word":"exit","level":"middle","meaning":"출구, 나가다","pronunciation":"/ˈeɡzɪt/","parts":[{"type":"prefix","text":"ex-","meaning":"밖으로 (out)"},{"type":"root","text":"it","meaning":"가다 (go)"}],"story":"건물 '밖으로(ex)' 나'가는(it)' 문 → 출구.","example":{"en":"Emergency exit.","ko":"비상구."}},
  {"word":"transit","level":"middle","meaning":"수송, 환승","pronunciation":"/ˈtrænzɪt/","parts":[{"type":"prefix","text":"trans-","meaning":"가로질러 (across)"},{"type":"root","text":"it","meaning":"가다 (go)"}],"story":"물건이나 사람이 이쪽에서 저쪽으로 '가로질러(trans)' '가는(it)' 것 → 수송, 환승.","example":{"en":"Public transit.","ko":"대중교통."}},
  {"word":"visit","level":"middle","meaning":"방문하다","pronunciation":"/ˈvɪzɪt/","parts":[{"type":"root","text":"vis","meaning":"보다 (see)"},{"type":"root","text":"it","meaning":"가다 (go)"}],"story":"누군가를 '보러(vis)' 그 장소로 '가다(it)' → 방문하다.","example":{"en":"Visit a museum.","ko":"박물관을 방문하다."}},
  {"word":"ambition","level":"middle","meaning":"야망, 포부","pronunciation":"/æmˈbɪʃn/","parts":[{"type":"prefix","text":"ambi-","meaning":"주변을 (around)"},{"type":"root","text":"it","meaning":"가다 (go)"},{"type":"suffix","text":"-ion","meaning":"명사형"}],"story":"고대 로마 정치인이 표를 얻으려고 '주변을(ambi)' 돌아다니며 '가는(it)' 데서 유래 → 야망.","example":{"en":"A man of ambition.","ko":"야망이 있는 남자."}},
  {"word":"perish","level":"high","meaning":"죽다, 소멸하다","pronunciation":"/ˈperɪʃ/","parts":[{"type":"prefix","text":"per-","meaning":"완전히 (completely)"},{"type":"root","text":"ish(it)","meaning":"가다 (go)"}],"story":"존재하던 것이 세상에서 '완전히(per)' 떠나'가(ish)' 버리다 → 죽다, 소멸하다.","example":{"en":"Many perished in the fire.","ko":"많은 사람들이 화재로 죽었다."}},
  {"word":"oblige","level":"high","meaning":"의무를 지우다, 강요하다","pronunciation":"/əˈblaɪdʒ/","parts":[{"type":"prefix","text":"ob-","meaning":"~쪽으로 (to)"},{"type":"root","text":"lige(lig)","meaning":"묶다 (bind)"}],"story":"어떤 책임을 지도록 사람을 법이나 도덕의 끈으로 꽉 '묶어버리다(lige)' → 의무를 지우다.","example":{"en":"I am obliged to help.","ko":"나는 도와야 할 의무가 있다."}},
  {"word":"religion","level":"middle","meaning":"종교","pronunciation":"/rɪˈlɪdʒən/","parts":[{"type":"prefix","text":"re-","meaning":"다시, 단단히 (back)"},{"type":"root","text":"lig","meaning":"묶다 (bind)"},{"type":"suffix","text":"-ion","meaning":"명사형"}],"story":"인간과 신 사이의 끊어진 관계를 '다시(re)' 단단하게 '묶어주는(lig)' 신앙 → 종교.","example":{"en":"Freedom of religion.","ko":"종교의 자유."}},
  {"word":"ligament","level":"high","meaning":"인대","pronunciation":"/ˈlɪɡəmənt/","parts":[{"type":"root","text":"liga(lig)","meaning":"묶다 (bind)"},{"type":"suffix","text":"-ment","meaning":"명사형"}],"story":"뼈와 뼈 사이를 단단하게 '묶어주는(liga)' 조직 → 인대.","example":{"en":"Tear a ligament.","ko":"인대가 찢어지다."}},
  {"word":"league","level":"middle","meaning":"연맹, 리그","pronunciation":"/liːɡ/","parts":[{"type":"root","text":"leag(lig)","meaning":"묶다 (bind)"}],"story":"여러 팀이나 국가들이 하나의 목적으로 끈끈하게 '묶여(leag)' 있는 집단 → 연맹, 리그.","example":{"en":"The major league.","ko":"메이저 리그."}},
  {"word":"colleague","level":"middle","meaning":"동료","pronunciation":"/ˈkɑːliːɡ/","parts":[{"type":"prefix","text":"col(com)-","meaning":"함께 (together)"},{"type":"root","text":"league(lig)","meaning":"묶다 (bind)"}],"story":"직장에서 같은 목표를 위해 '함께(col)' '묶여(league)' 일하는 사람 → 직장 동료.","example":{"en":"My colleagues at work.","ko":"나의 직장 동료들."}},
  {"word":"limit","level":"middle","meaning":"한계, 제한하다","pronunciation":"/ˈlɪmɪt/","parts":[{"type":"root","text":"limit","meaning":"경계, 선 (boundary)"}],"story":"더 이상 넘어갈 수 없게 그어진 '경계선(limit)'.","example":{"en":"Speed limit.","ko":"제한 속도."}},
  {"word":"limited","level":"middle","meaning":"제한된, 한정된","pronunciation":"/ˈlɪmɪtɪd/","parts":[{"type":"root","text":"limit","meaning":"경계"},{"type":"suffix","text":"-ed","meaning":"형용사형"}],"story":"'경계선(limit)'이 그어져 있어서 마음대로 할 수 없는 → 한정된.","example":{"en":"A limited edition.","ko":"한정판."}},
  {"word":"unlimited","level":"middle","meaning":"무제한의","pronunciation":"/ʌnˈlɪmɪtɪd/","parts":[{"type":"prefix","text":"un-","meaning":"없는 (not)"},{"type":"root","text":"limited","meaning":"제한된"}],"story":"막아서는 '경계선(limit)'이 아예 '없는(un)' → 무제한의.","example":{"en":"Unlimited data.","ko":"무제한 데이터."}},
  {"word":"eliminate","level":"high","meaning":"제거하다, 없애다","pronunciation":"/ɪˈlɪmɪneɪt/","parts":[{"type":"prefix","text":"e(x)-","meaning":"밖으로 (out)"},{"type":"root","text":"limin(limit)","meaning":"경계선 (boundary)"},{"type":"suffix","text":"-ate","meaning":"동사형"}],"story":"원하는 무리의 '경계선(limin)' '밖으로(e)' 아예 쫓아내 버리다 → 제거하다.","example":{"en":"Eliminate toxins.","ko":"독소를 제거하다."}},
  {"word":"preliminary","level":"high","meaning":"예비의, 예선","pronunciation":"/prɪˈlɪmɪneri/","parts":[{"type":"prefix","text":"pre-","meaning":"앞에, 미리 (before)"},{"type":"root","text":"limin","meaning":"경계, 문지방"},{"type":"suffix","text":"-ary","meaning":"형용사형"}],"story":"본선이라는 '경계선(limin)'을 넘기 '전에(pre)' 미리 거쳐야 하는 단계 → 예비의, 예선.","example":{"en":"A preliminary exam.","ko":"예비 시험."}},
  {"word":"long","level":"middle","meaning":"긴, 갈망하다","pronunciation":"/lɔːŋ/","parts":[{"type":"root","text":"long","meaning":"긴 (long)"}],"story":"1. 길이가 '긴'. 2. 목을 '길게' 빼고 무언가를 간절히 기다리다 → 갈망하다.","example":{"en":"Long for peace.","ko":"평화를 갈망하다."}},
  {"word":"belong","level":"middle","meaning":"~에 속하다, 제자리다","pronunciation":"/bɪˈlɔːŋ/","parts":[{"type":"prefix","text":"be-","meaning":"강조"},{"type":"root","text":"long","meaning":"원하다, 길다"}],"story":"특정 집단에 들어가기를 강하게 '갈망하여(long)' 마침내 그곳의 일원이 되다 → 속하다.","example":{"en":"I belong to this club.","ko":"나는 이 동아리에 속해 있다."}},
  {"word":"prolong","level":"high","meaning":"연장하다","pronunciation":"/prəˈlɔːŋ/","parts":[{"type":"prefix","text":"pro-","meaning":"앞으로 (forward)"},{"type":"root","text":"long","meaning":"긴 (long)"}],"story":"시간이나 기간을 '앞으로(pro)' 더 '길게(long)' 잡아 늘이다 → 연장하다.","example":{"en":"Prolong life.","ko":"수명을 연장하다."}},
  {"word":"linger","level":"high","meaning":"(아쉬운 듯) 남아있다, 꾸물거리다","pronunciation":"/ˈlɪŋɡər/","parts":[{"type":"root","text":"ling(long)","meaning":"긴 (long)"},{"type":"suffix","text":"-er","meaning":"동사형"}],"story":"떠나기 아쉬워 한 곳에 '오래(길게, ling)' 머물며 꾸물거리다.","example":{"en":"The smell lingered.","ko":"그 냄새가 오래 남아있었다."}},
  {"word":"longitude","level":"high","meaning":"경도 (지구의 세로선)","pronunciation":"/ˈlɑːndʒɪtuːd/","parts":[{"type":"root","text":"long","meaning":"긴 (long)"},{"type":"suffix","text":"-itude","meaning":"상태, 정도"}],"story":"지구본에서 위에서 아래로 '길게(long)' 그어진 선망 → 경도 (참고: 위도는 latitude).","example":{"en":"Lines of longitude.","ko":"경도선."}},
