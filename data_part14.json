[
  {"word":"announce","level":"middle","meaning":"발표하다, 알리다","pronunciation":"/əˈnaʊns/","parts":[{"type":"prefix","text":"an(ad)-","meaning":"~를 향해 (to)"},{"type":"root","text":"nounc","meaning":"알리다 (report)"}],"story":"대중들을 '향해(an)' 소식이나 결정을 '알리다(nounc)' → 발표하다.","example":{"en":"Announce a new policy.","ko":"새 정책을 발표하다."}},
  {"word":"pronounce","level":"middle","meaning":"발음하다, 선고하다","pronunciation":"/prəˈnaʊns/","parts":[{"type":"prefix","text":"pro-","meaning":"앞으로 (forward)"},{"type":"root","text":"nounc","meaning":"알리다 (report)"}],"story":"사람들 '앞에서(pro)' 소리를 내어 입 밖으로 '알리다(nounc)' → 발음하다.","example":{"en":"Pronounce the word correctly.","ko":"단어를 정확하게 발음하다."}},
  {"word":"denounce","level":"high","meaning":"비난하다, 고발하다","pronunciation":"/dɪˈnaʊns/","parts":[{"type":"prefix","text":"de-","meaning":"아래로, 나쁘게"},{"type":"root","text":"nounc","meaning":"알리다 (report)"}],"story":"남을 깎아'내리거나(de)' 나쁜 점을 널리 '알리다(nounc)' → 맹비난하다.","example":{"en":"Denounce the violence.","ko":"폭력을 비난하다."}},
  {"word":"renounce","level":"high","meaning":"포기하다, 단념하다","pronunciation":"/rɪˈnaʊns/","parts":[{"type":"prefix","text":"re-","meaning":"뒤로, 반대로 (back)"},{"type":"root","text":"nounc","meaning":"알리다 (report)"}],"story":"내게 주어진 권리나 주장을 '거부하겠다(re)'고 공개적으로 '알리다(nounc)'.","example":{"en":"Renounce the throne.","ko":"왕위를 포기하다."}},
  {"word":"pronunciation","level":"middle","meaning":"발음","pronunciation":"/prəˌnʌnsiˈeɪʃn/","parts":[{"type":"root","text":"pronounce","meaning":"발음하다"},{"type":"suffix","text":"-ation","meaning":"명사형"}],"story":"소리를 내어 말하는 방식이나 그 행위 → 발음.","example":{"en":"Good English pronunciation.","ko":"좋은 영어 발음."}},
  {"word":"point","level":"middle","meaning":"점, 요점, 가리키다","pronunciation":"/pɔɪnt/","parts":[{"type":"root","text":"point","meaning":"찌르다, 점 (prick)"}],"story":"바늘로 콕 '찔러서(point)' 생긴 자국이나 어떤 곳을 콕 찍어 가리키다.","example":{"en":"Point at the map.","ko":"지도를 가리키다."}},
  {"word":"appoint","level":"middle","meaning":"임명하다, 약속하다","pronunciation":"/əˈpɔɪnt/","parts":[{"type":"prefix","text":"ap(ad)-","meaning":"~쪽으로 (to)"},{"type":"root","text":"point","meaning":"가리키다 (prick)"}],"story":"어떤 사람 '쪽으로(ap)' 손가락을 콕 '가리켜서(point)' 자리를 맡기다 → 임명하다.","example":{"en":"Appoint a new manager.","ko":"새 매니저를 임명하다."}},
  {"word":"disappoint","level":"middle","meaning":"실망시키다","pronunciation":"/ˌdɪsəˈpɔɪnt/","parts":[{"type":"prefix","text":"dis-","meaning":"반대로 (away)"},{"type":"root","text":"appoint","meaning":"약속하다"}],"story":"상대방과 했던 '약속(appoint)'을 '깨버리다(dis)' → 기대에 어긋나 실망시키다.","example":{"en":"Don't disappoint me.","ko":"날 실망시키지 마."}},
  {"word":"punctual","level":"high","meaning":"시간을 엄수하는","pronunciation":"/ˈpʌŋktʃuəl/","parts":[{"type":"root","text":"punct","meaning":"찌르다, 점 (prick)"},{"type":"suffix","text":"-ual","meaning":"형용사형"}],"story":"약속한 시간이라는 '점(punct)'에 정확하게 콕 맞춰 도착하는 → 시간을 잘 지키는.","example":{"en":"Be punctual for the meeting.","ko":"회의 시간을 엄수해라."}},
  {"word":"punctuate","level":"high","meaning":"구두점을 찍다, 강조하다","pronunciation":"/ˈpʌŋktʃueɪt/","parts":[{"type":"root","text":"punct","meaning":"점 (point)"},{"type":"suffix","text":"-ate","meaning":"동사형"}],"story":"글의 의미가 명확해지도록 마침표 같은 '점(punct)'을 '찍다(ate)'.","example":{"en":"Punctuate a sentence.","ko":"문장에 구두점을 찍다."}},
  {"word":"fable","level":"middle","meaning":"우화, 꾸며낸 이야기","pronunciation":"/ˈfeɪbl/","parts":[{"type":"root","text":"fa","meaning":"말하다 (speak)"},{"type":"suffix","text":"-ble","meaning":"명사형"}],"story":"옛날부터 사람들의 입으로 '말해져(fa)' 전해 내려오는 교훈적인 이야기 → 우화.","example":{"en":"Aesop's fables.","ko":"이솝 우화."}},
  {"word":"fame","level":"middle","meaning":"명성, 평판","pronunciation":"/feɪm/","parts":[{"type":"root","text":"fa","meaning":"말하다 (speak)"},{"type":"suffix","text":"-me","meaning":"명사형"}],"story":"어떤 사람에 대해 대중들이 '입을 모아 좋게 말하는(fa)' 것 → 명성.","example":{"en":"Gain wealth and fame.","ko":"부와 명성을 얻다."}},
  {"word":"fate","level":"middle","meaning":"운명, 숙명","pronunciation":"/feɪt/","parts":[{"type":"root","text":"fa","meaning":"말하다 (speak)"},{"type":"suffix","text":"-te","meaning":"명사형"}],"story":"신이 태어날 때부터 어떻게 살라고 '말해(fa)' 둔 것 → 결정된 운명.","example":{"en":"Accept one's fate.","ko":"자신의 운명을 받아들이다."}},
  {"word":"confess","level":"high","meaning":"자백하다, 고백하다","pronunciation":"/kənˈfes/","parts":[{"type":"prefix","text":"con-","meaning":"완전히 (completely)"},{"type":"root","text":"fess","meaning":"말하다 (speak)"}],"story":"숨겨왔던 진실이나 죄를 남김없이 '완전히(con)' '말해버리다(fess)' → 자백하다.","example":{"en":"Confess a crime.","ko":"범죄를 자백하다."}},
  {"word":"profess","level":"high","meaning":"공언하다, 고백하다","pronunciation":"/prəˈfes/","parts":[{"type":"prefix","text":"pro-","meaning":"앞에서 (forward)"},{"type":"root","text":"fess","meaning":"말하다 (speak)"}],"story":"대중들 '앞에(pro)' 나서서 자신의 믿음이나 직업을 당당히 '말하다(fess)' → 공언하다.","example":{"en":"Profess one's love.","ko":"자신의 사랑을 고백하다."}},
  {"word":"false","level":"middle","meaning":"거짓의, 틀린","pronunciation":"/fɔːls/","parts":[{"type":"root","text":"fals","meaning":"속이다, 틀리다 (deceive)"}],"story":"진실을 '속이거나(fals)' 잘못된 사실에 바탕을 둔.","example":{"en":"True or false.","ko":"참 또는 거짓."}},
  {"word":"fail","level":"middle","meaning":"실패하다, 낙제하다","pronunciation":"/feɪl/","parts":[{"type":"root","text":"fail(fals)","meaning":"잘못되다 (deceive)"}],"story":"목표를 이루는 데 '잘못되어(fail)' 뜻대로 되지 않다 → 실패하다.","example":{"en":"Fail a test.","ko":"시험에 낙제하다."}},
  {"word":"fault","level":"middle","meaning":"잘못, 책임, 결점","pronunciation":"/fɔːlt/","parts":[{"type":"root","text":"fault(fals)","meaning":"잘못, 속임 (deceive)"}],"story":"기대나 규칙에 어긋나 '잘못된(fault)' 부분이나 행동 → 결점, 과실.","example":{"en":"It's my fault.","ko":"그건 내 잘못이다."}},
  {"word":"falsify","level":"high","meaning":"위조하다, 조작하다","pronunciation":"/ˈfɔːlsɪfaɪ/","parts":[{"type":"root","text":"fals","meaning":"거짓 (false)"},{"type":"suffix","text":"-ify","meaning":"만들다"}],"story":"서류나 기록을 '거짓으로(fals)' '만들다(ify)' → 위조하다.","example":{"en":"Falsify documents.","ko":"문서를 위조하다."}},
  {"word":"fallacy","level":"high","meaning":"오류, 잘못된 생각","pronunciation":"/ˈfæləsi/","parts":[{"type":"root","text":"fall(fals)","meaning":"속이다 (deceive)"},{"type":"suffix","text":"-acy","meaning":"명사형"}],"story":"사람을 '속이는(fall)' 겉만 그럴싸한 잘못된 논리 → 오류.","example":{"en":"A logical fallacy.","ko":"논리적 오류."}},
  {"word":"grateful","level":"middle","meaning":"감사하는, 고마워하는","pronunciation":"/ˈɡreɪtfl/","parts":[{"type":"root","text":"grat","meaning":"기쁘게 하는 (pleasing)"},{"type":"suffix","text":"-ful","meaning":"가득한"}],"story":"남의 도움을 받아 마음이 '기쁘고 고마움으로(grat)' '가득한(ful)'.","example":{"en":"I am very grateful.","ko":"나는 매우 감사하게 생각한다."}},
  {"word":"congratulate","level":"middle","meaning":"축하하다","pronunciation":"/kənˈɡrætʃuleɪt/","parts":[{"type":"prefix","text":"con-","meaning":"함께 (together)"},{"type":"root","text":"grat","meaning":"기쁜 (pleasing)"},{"type":"suffix","text":"-ate","meaning":"동사형"}],"story":"다른 사람의 좋은 일에 '함께(con)' '기뻐해(grat)' 주다 → 축하하다.","example":{"en":"Congratulate him on his success.","ko":"그의 성공을 축하하다."}},
  {"word":"gratitude","level":"high","meaning":"감사, 고마움","pronunciation":"/ˈɡrætɪtuːd/","parts":[{"type":"root","text":"grat","meaning":"감사하는 (thankful)"},{"type":"suffix","text":"-itude","meaning":"명사형"}],"story":"남이 베풀어준 은혜에 대해 '감사하는(grat)' 마음의 상태.","example":{"en":"Show gratitude.","ko":"감사를 표하다."}},
  {"word":"grace","level":"middle","meaning":"우아함, 은혜","pronunciation":"/ɡreɪs/","parts":[{"type":"root","text":"grac(grat)","meaning":"기쁘게 하는 (pleasing)"}],"story":"사람들의 마음을 '기쁘게(grac)' 해주는 아름다운 행동이나 신의 선물 → 우아함, 은혜.","example":{"en":"Move with grace.","ko":"우아하게 움직이다."}},
  {"word":"agree","level":"middle","meaning":"동의하다, 일치하다","pronunciation":"/əˈɡriː/","parts":[{"type":"prefix","text":"a(d)-","meaning":"~로 (to)"},{"type":"root","text":"gree(grat)","meaning":"기쁜 (pleasing)"}],"story":"상대방의 제안이 내 마음에도 '기쁘게(gree)' 다가오다 → 동의하다.","example":{"en":"I agree with you.","ko":"너의 의견에 동의해."}},
  {"word":"adhere","level":"high","meaning":"들러붙다, 고수하다","pronunciation":"/ədˈhɪr/","parts":[{"type":"prefix","text":"ad-","meaning":"~에 (to)"},{"type":"root","text":"here","meaning":"붙다 (stick)"}],"story":"풀이나 접착제처럼 어떤 표면'에(ad)' 착 '들러붙다(here)'. 원칙을 고수하다.","example":{"en":"Adhere to the rules.","ko":"규칙을 고수하다."}},
  {"word":"cohere","level":"high","meaning":"밀착하다, 조리가 있다","pronunciation":"/koʊˈhɪr/","parts":[{"type":"prefix","text":"co(n)-","meaning":"함께 (together)"},{"type":"root","text":"here","meaning":"붙다 (stick)"}],"story":"생각이나 물질들이 '함께(co)' 단단히 '들러붙다(here)' → 논리가 일관성 있다.","example":{"en":"The theory doesn't cohere.","ko":"그 이론은 조리가 맞지 않는다."}},
  {"word":"inherent","level":"high","meaning":"내재하는, 본질적인","pronunciation":"/ɪnˈhɪrənt/","parts":[{"type":"prefix","text":"in-","meaning":"안에 (in)"},{"type":"root","text":"her","meaning":"붙다 (stick)"},{"type":"suffix","text":"-ent","meaning":"형용사형"}],"story":"태어날 때부터 몸이나 본성 '안에(in)' 딱 '붙어있는(her)' → 내재하는.","example":{"en":"Inherent risks.","ko":"내재된 위험들."}},
  {"word":"hesitate","level":"middle","meaning":"망설이다, 주저하다","pronunciation":"/ˈhezɪteɪt/","parts":[{"type":"root","text":"hes(her)","meaning":"붙다 (stick)"},{"type":"suffix","text":"-ate","meaning":"동사형"}],"story":"두려움 때문에 발걸음이 바닥에 '붙어서(hes)' 떨어지지 않다 → 망설이다.","example":{"en":"Don't hesitate to ask.","ko":"망설이지 말고 물어보세요."}},
  {"word":"adhesive","level":"high","meaning":"접착제, 들러붙는","pronunciation":"/ədˈhiːsɪv/","parts":[{"type":"prefix","text":"ad-","meaning":"~에 (to)"},{"type":"root","text":"hes","meaning":"붙다 (stick)"},{"type":"suffix","text":"-ive","meaning":"형용사형"}],"story":"물건을 어딘가'에(ad)' 꽉 '달라붙게(hes)' 만드는 물질 → 접착제.","example":{"en":"Adhesive tape.","ko":"접착 테이프."}},
  {"word":"join","level":"middle","meaning":"연결하다, 가입하다","pronunciation":"/dʒɔɪn/","parts":[{"type":"root","text":"join(junct)","meaning":"연결하다 (join)"}],"story":"떨어져 있던 두 개를 하나로 '연결하거나' 어떤 단체에 '연결되다'.","example":{"en":"Join a club.","ko":"동아리에 가입하다."}},
  {"word":"joint","level":"middle","meaning":"관절, 공동의","pronunciation":"/dʒɔɪnt/","parts":[{"type":"root","text":"join","meaning":"연결하다"},{"type":"suffix","text":"-t","meaning":"명사형"}],"story":"뼈와 뼈가 서로 '연결되는(join)' 부위 → 관절. 둘 이상이 연결된 → 공동의.","example":{"en":"A joint effort.","ko":"공동의 노력."}},
  {"word":"adjoin","level":"high","meaning":"인접하다, 붙어있다","pronunciation":"/əˈdʒɔɪn/","parts":[{"type":"prefix","text":"ad-","meaning":"~에 (to)"},{"type":"root","text":"join","meaning":"연결되다"}],"story":"우리 집과 옆집이 서로 벽을 맞대고 '연결되어(join)' 있다 → 인접하다.","example":{"en":"An adjoining room.","ko":"인접한 방 (옆방)."}},
  {"word":"junction","level":"high","meaning":"교차로, 연결 지점","pronunciation":"/ˈdʒʌŋkʃn/","parts":[{"type":"root","text":"junct","meaning":"연결하다 (join)"},{"type":"suffix","text":"-ion","meaning":"명사형"}],"story":"도로나 철도가 서로 만나 '연결되는(junct)' 지점 → 교차로, 환승역.","example":{"en":"A busy junction.","ko":"혼잡한 교차로."}},
  {"word":"conjunction","level":"high","meaning":"결합, 접속사","pronunciation":"/kənˈdʒʌŋkʃn/","parts":[{"type":"prefix","text":"con-","meaning":"함께 (together)"},{"type":"root","text":"junct","meaning":"연결하다 (join)"},{"type":"suffix","text":"-ion","meaning":"명사형"}],"story":"두 가지 이상의 것을 '함께(con)' '연결해 주는(junct)' 것 → 결합, (문법의) 접속사.","example":{"en":"In conjunction with others.","ko":"다른 사람들과 결합하여(공동으로)."}},
  {"word":"translate","level":"middle","meaning":"번역하다, 통역하다","pronunciation":"/trænsˈleɪt/","parts":[{"type":"prefix","text":"trans-","meaning":"가로질러, 넘어 (across)"},{"type":"root","text":"lat","meaning":"나르다 (carry)"}],"story":"하나의 언어에서 그 의미를 다른 언어로 '넘겨서(trans)' '나르다(lat)' → 번역하다.","example":{"en":"Translate English into Korean.","ko":"영어를 한국어로 번역하다."}},
  {"word":"relate","level":"middle","meaning":"관련시키다, 이야기하다","pronunciation":"/rɪˈleɪt/","parts":[{"type":"prefix","text":"re-","meaning":"다시, 뒤로 (back)"},{"type":"root","text":"lat","meaning":"나르다 (carry)"}],"story":"이전의 정보들을 '다시(re)' '가져와(lat)' 현재와 연결하다 → 관련시키다.","example":{"en":"Relate to the topic.","ko":"주제와 관련되다."}},
  {"word":"relative","level":"middle","meaning":"친척, 상대적인","pronunciation":"/ˈrelətɪv/","parts":[{"type":"root","text":"relat(e)","meaning":"관련된"},{"type":"suffix","text":"-ive","meaning":"명사/형용사형"}],"story":"나와 피로 '관련이 있는(relat)' 사람 → 친척. 비교하여 관련된 → 상대적인.","example":{"en":"A close relative.","ko":"가까운 친척."}},
  {"word":"delay","level":"middle","meaning":"미루다, 연기, 지연","pronunciation":"/dɪˈleɪ/","parts":[{"type":"prefix","text":"de-","meaning":"멀리, 아래로 (away)"},{"type":"root","text":"lay(lat)","meaning":"나르다, 두다 (carry)"}],"story":"원래 하기로 했던 약속 시간을 저 멀리 뒤로 '가져다(lay)' 놓다 → 미루다.","example":{"en":"Delay the flight.","ko":"비행기를 연기하다."}},
  {"word":"correlate","level":"high","meaning":"연관성을 보여주다, 상관관계가 있다","pronunciation":"/ˈkɔːrəleɪt/","parts":[{"type":"prefix","text":"cor(con)-","meaning":"함께 (together)"},{"type":"root","text":"relate","meaning":"관련시키다"}],"story":"두 가지 데이터가 '함께(cor)' 밀접하게 '관련되어(relate)' 변화하다.","example":{"en":"Poverty and crime correlate.","ko":"빈곤과 범죄는 상관관계가 있다."}},
  {"word":"relax","level":"middle","meaning":"휴식하다, 완화하다","pronunciation":"/rɪˈlæks/","parts":[{"type":"prefix","text":"re-","meaning":"다시, 뒤로 (back)"},{"type":"root","text":"lax","meaning":"느슨한 (loose)"}],"story":"긴장되었던 몸과 마음을 '다시(re)' '느슨하게(lax)' 풀다 → 휴식하다.","example":{"en":"Relax on the beach.","ko":"해변에서 휴식하다."}},
  {"word":"release","level":"middle","meaning":"풀어주다, 출시하다","pronunciation":"/rɪˈliːs/","parts":[{"type":"prefix","text":"re-","meaning":"다시, 뒤로 (back)"},{"type":"root","text":"lease(lax)","meaning":"느슨한 (loose)"}],"story":"묶여있던 끈이나 구속을 '느슨하게(lease)' 풀어서 밖으로 내보내다 → 풀어주다, 출시하다.","example":{"en":"Release a new album.","ko":"새 앨범을 출시하다."}},
  {"word":"analyze","level":"high","meaning":"분석하다","pronunciation":"/ˈænəlaɪz/","parts":[{"type":"prefix","text":"ana-","meaning":"위로, 완전히 (up)"},{"type":"root","text":"lyze(lys)","meaning":"풀다 (loose)"}],"story":"복잡한 문제나 물질을 '완전히(ana)' 여러 조각으로 '풀어서(lyze)' 조사하다 → 분석하다.","example":{"en":"Analyze the data.","ko":"데이터를 분석하다."}},
  {"word":"paralyze","level":"high","meaning":"마비시키다","pronunciation":"/ˈpærəlaɪz/","parts":[{"type":"prefix","text":"para-","meaning":"옆에, 비정상적인 (beside)"},{"type":"root","text":"lyze(lys)","meaning":"풀다 (loose)"}],"story":"근육의 신경망이 비정상적으로 '풀려버려(lyze)' 힘을 못 쓰는 상태로 만들다 → 마비시키다.","example":{"en":"The traffic was paralyzed.","ko":"교통이 마비되었다."}},
