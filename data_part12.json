[
  {"word":"fragment","level":"middle","meaning":"파편, 조각","pronunciation":"/ˈfræɡmənt/","parts":[{"type":"root","text":"frag","meaning":"깨다 (break)"},{"type":"suffix","text":"-ment","meaning":"명사형"}],"story":"유리나 돌이 '깨져서(frag)' 떨어져 나온 조각 → 파편.","example":{"en":"A fragment of glass.","ko":"유리 파편."}},
  {"word":"fragile","level":"middle","meaning":"부서지기 쉬운, 취약한","pronunciation":"/ˈfrædʒl/","parts":[{"type":"root","text":"frag","meaning":"깨다 (break)"},{"type":"suffix","text":"-ile","meaning":"~하기 쉬운"}],"story":"살짝만 건드려도 쉽게 '깨질(frag)' 수 있는 성질의 → 부서지기 쉬운.","example":{"en":"Fragile items.","ko":"파손 주의 물품."}},
  {"word":"fraction","level":"high","meaning":"부분, 분수","pronunciation":"/ˈfrækʃn/","parts":[{"type":"root","text":"fract","meaning":"깨다 (break)"},{"type":"suffix","text":"-ion","meaning":"명사형"}],"story":"전체를 여러 조각으로 '깨서(fract)' 나눈 것 중의 일부 → 분수, 일부분.","example":{"en":"A fraction of a second.","ko":"눈 깜짝할 사이 (1초의 아주 작은 부분)."}},
  {"word":"fracture","level":"high","meaning":"골절, 균열","pronunciation":"/ˈfræktʃər/","parts":[{"type":"root","text":"fract","meaning":"깨다 (break)"},{"type":"suffix","text":"-ure","meaning":"명사형"}],"story":"뼈나 단단한 물체가 물리적 충격으로 '깨지거나(fract)' 부러진 상태 → 골절.","example":{"en":"A bone fracture.","ko":"뼈 골절."}},
  {"word":"refract","level":"high","meaning":"굴절시키다","pronunciation":"/rɪˈfrækt/","parts":[{"type":"prefix","text":"re-","meaning":"뒤로, 꺾여 (back)"},{"type":"root","text":"fract","meaning":"깨다 (break)"}],"story":"빛이 물이나 렌즈를 통과하면서 직진하지 못하고 꺾여서 '깨지다(fract)' → 굴절되다.","example":{"en":"Water refracts light.","ko":"물은 빛을 굴절시킨다."}},
  {"word":"congregate","level":"high","meaning":"모이다, 집합하다","pronunciation":"/ˈkɑːŋɡrɪɡeɪt/","parts":[{"type":"prefix","text":"con-","meaning":"함께 (together)"},{"type":"root","text":"greg","meaning":"무리 (flock)"},{"type":"suffix","text":"-ate","meaning":"동사형"}],"story":"사람들이 한 장소에 '함께(con)' '무리(greg)' 지어 서다 → 모이다.","example":{"en":"People congregated in the square.","ko":"사람들이 광장에 모였다."}},
  {"word":"segregate","level":"high","meaning":"분리하다, 차별하다","pronunciation":"/ˈseɡrɪɡeɪt/","parts":[{"type":"prefix","text":"se-","meaning":"떨어져서 (apart)"},{"type":"root","text":"greg","meaning":"무리 (flock)"},{"type":"suffix","text":"-ate","meaning":"동사형"}],"story":"원래 있던 '무리(greg)'에서 강제로 떼어내어 '떨어뜨려(se)' 놓다 → 분리하다, 격리하다.","example":{"en":"Segregate waste.","ko":"쓰레기를 분리수거하다."}},
  {"word":"aggregate","level":"high","meaning":"합계, 종합하다","pronunciation":"/ˈæɡrɪɡət/","parts":[{"type":"prefix","text":"ag(ad)-","meaning":"~쪽으로 (to)"},{"type":"root","text":"greg","meaning":"무리 (flock)"},{"type":"suffix","text":"-ate","meaning":"만들다"}],"story":"작은 조각들을 한 '무리(greg)' '쪽으로(ag)' 끌어모아 큰 덩어리를 만들다 → 합계.","example":{"en":"The aggregate amount.","ko":"총합계."}},
  {"word":"gregarious","level":"high","meaning":"사교적인, 군거하는","pronunciation":"/ɡrɪˈɡeriəs/","parts":[{"type":"root","text":"greg","meaning":"무리 (flock)"},{"type":"suffix","text":"-arious","meaning":"형용사형"}],"story":"혼자 있는 것보다 '무리(greg)'와 함께 어울리기를 좋아하는 성격 → 사교적인.","example":{"en":"A gregarious personality.","ko":"사교적인 성격."}},
  {"word":"egregious","level":"high","meaning":"지독한, 터무니없는","pronunciation":"/ɪˈɡriːdʒiəs/","parts":[{"type":"prefix","text":"e(x)-","meaning":"밖으로 (out)"},{"type":"root","text":"greg","meaning":"무리 (flock)"},{"type":"suffix","text":"-ious","meaning":"형용사형"}],"story":"잘못이 너무 커서 정상적인 '무리(greg)' '밖으로(e)' 쫓겨날 만큼 심각한 → 지독한.","example":{"en":"An egregious error.","ko":"터무니없는 실수."}},
  {"word":"prime","level":"middle","meaning":"주요한, 최고의","pronunciation":"/praɪm/","parts":[{"type":"root","text":"prim","meaning":"첫째, 으뜸 (first)"}],"story":"모든 것 중에서 '첫 번째(prim)'로 꼽히는 품질이나 중요성 → 최고의.","example":{"en":"Prime beef.","ko":"최상급 쇠고기."}},
  {"word":"primary","level":"middle","meaning":"주된, 초등의","pronunciation":"/ˈpraɪmeri/","parts":[{"type":"root","text":"prim","meaning":"첫째 (first)"},{"type":"suffix","text":"-ary","meaning":"관련된"}],"story":"순서나 중요도가 '첫 번째(prim)'에 해당하는 → 주된, 초등 교육의.","example":{"en":"Primary school.","ko":"초등학교."}},
  {"word":"primitive","level":"middle","meaning":"원시의, 초기의","pronunciation":"/ˈprɪmətɪv/","parts":[{"type":"root","text":"prim","meaning":"처음 (first)"},{"type":"suffix","text":"-itive","meaning":"형용사형"}],"story":"인류나 문명의 가장 '처음(prim)' 단계에 있었던 → 원시적인.","example":{"en":"Primitive humans.","ko":"원시 인류."}},
  {"word":"principal","level":"middle","meaning":"주요한, 교장","pronunciation":"/ˈprɪnsəpl/","parts":[{"type":"root","text":"prin(prim)","meaning":"첫째, 으뜸"},{"type":"root","text":"cip","meaning":"잡다 (take)"},{"type":"suffix","text":"-al","meaning":"사람, 형용사"}],"story":"학교나 조직에서 가장 '으뜸(prin)'가는 자리를 '잡고(cip)' 있는 사람 → 교장.","example":{"en":"The principal of the school.","ko":"학교 교장 선생님."}},
  {"word":"principle","level":"middle","meaning":"원칙, 원리","pronunciation":"/ˈprɪnsəpl/","parts":[{"type":"root","text":"prin(prim)","meaning":"첫째 (first)"},{"type":"root","text":"cip","meaning":"잡다 (take)"},{"type":"suffix","text":"-le","meaning":"명사형"}],"story":"사람이 살아가면서 '가장 우선(prin)'으로 마음속에 꽉 '잡아야(cip)' 하는 신념 → 원칙.","example":{"en":"Stick to my principles.","ko":"내 원칙을 고수하다."}},
  {"word":"solve","level":"middle","meaning":"해결하다, 풀다","pronunciation":"/sɑːlv/","parts":[{"type":"root","text":"solv","meaning":"느슨하게 하다, 풀다 (loosen)"}],"story":"엉킨 문제의 실타래를 '느슨하게 풀어(solv)' 정답을 찾아내다.","example":{"en":"Solve a problem.","ko":"문제를 해결하다."}},
  {"word":"resolve","level":"high","meaning":"해결하다, 결심하다","pronunciation":"/rɪˈzɑːlv/","parts":[{"type":"prefix","text":"re-","meaning":"완전히, 다시"},{"type":"root","text":"solv","meaning":"풀다 (loosen)"}],"story":"마음속의 찌찌함을 '완전히(re)' '풀어버리고(solv)' 앞으로 나아가기로 단단히 마음먹다 → 결심하다.","example":{"en":"Resolve a conflict.","ko":"갈등을 해결하다."}},
  {"word":"dissolve","level":"high","meaning":"녹이다, 해산하다","pronunciation":"/dɪˈzɑːlv/","parts":[{"type":"prefix","text":"dis-","meaning":"분리하여 (apart)"},{"type":"root","text":"solv","meaning":"풀다 (loosen)"}],"story":"물질의 결합을 '풀어서(solv)' 여러 개로 '분리하다(dis)' → 물에 녹다, 조직을 해산하다.","example":{"en":"Sugar dissolves in water.","ko":"설탕은 물에 녹는다."}},
  {"word":"absolute","level":"high","meaning":"절대적인, 완전한","pronunciation":"/ˈæbsəluːt/","parts":[{"type":"prefix","text":"ab-","meaning":"멀리, 떨어져서 (away)"},{"type":"root","text":"solute(solv)","meaning":"풀다 (loosen)"}],"story":"세상의 규칙이나 제약으로부터 '완전히 떨어져(ab)' '풀려난(solute)' 자유로운 상태 → 절대적인.","example":{"en":"Absolute power.","ko":"절대 권력."}},
  {"word":"solution","level":"middle","meaning":"해결책, 용액","pronunciation":"/səˈluːʃn/","parts":[{"type":"root","text":"solut","meaning":"풀다 (loosen)"},{"type":"suffix","text":"-ion","meaning":"명사형"}],"story":"어려운 문제를 '풀어낸(solut)' 결과물 → 해결책. 물질이 물에 풀려있는 것 → 용액.","example":{"en":"Find a solution.","ko":"해결책을 찾다."}},
  {"word":"sphere","level":"middle","meaning":"구, 공, 영역","pronunciation":"/sfɪr/","parts":[{"type":"root","text":"spher","meaning":"구, 둥근 공 (ball)"}],"story":"입체적으로 둥근 공 모양을 나타내는 말 → 구, 활동 영역.","example":{"en":"The political sphere.","ko":"정치적 영역."}},
  {"word":"atmosphere","level":"middle","meaning":"대기, 분위기","pronunciation":"/ˈætməsfɪr/","parts":[{"type":"root","text":"atmo","meaning":"증기, 공기 (vapor)"},{"type":"root","text":"sphere","meaning":"구, 지구 (ball)"}],"story":"둥근 '지구(sphere)'를 감싸고 있는 '공기(atmo)' 층 → 대기, 분위기.","example":{"en":"A friendly atmosphere.","ko":"친근한 분위기."}},
  {"word":"hemisphere","level":"high","meaning":"반구","pronunciation":"/ˈhemɪsfɪr/","parts":[{"type":"prefix","text":"hemi-","meaning":"반, 절반 (half)"},{"type":"root","text":"sphere","meaning":"구, 공 (ball)"}],"story":"지구라는 거대한 '공(sphere)'을 '절반(hemi)'으로 자른 부분 → 북반구, 남반구.","example":{"en":"The northern hemisphere.","ko":"북반구."}},
  {"word":"spherical","level":"high","meaning":"구 모양의","pronunciation":"/ˈsferɪkl/","parts":[{"type":"root","text":"spher","meaning":"구, 공"},{"type":"suffix","text":"-ical","meaning":"형용사형"}],"story":"네모나지 않고 '둥근 공(spher)' 모양을 띤.","example":{"en":"A spherical object.","ko":"구형 물체."}},
  {"word":"stratosphere","level":"high","meaning":"성층권","pronunciation":"/ˈstrætəsfɪr/","parts":[{"type":"root","text":"strato","meaning":"층, 겹 (layer)"},{"type":"root","text":"sphere","meaning":"구 (ball)"}],"story":"대기권 중에서 구름이 없고 안정된 '층(strato)'을 이루며 지구를 감싸는 영역.","example":{"en":"Fly in the stratosphere.","ko":"성층권에서 비행하다."}},
  {"word":"detail","level":"middle","meaning":"세부 사항, 상세히 알리다","pronunciation":"/ˈdiːteɪl/","parts":[{"type":"prefix","text":"de-","meaning":"완전히, 아래로"},{"type":"root","text":"tail","meaning":"자르다 (cut)"}],"story":"어떤 덩어리를 아주 잘게 '완전히(de)' '잘라서(tail)' 나누어 놓은 조각들 → 세부 사항.","example":{"en":"Explain in detail.","ko":"상세히 설명하다."}},
  {"word":"retail","level":"high","meaning":"소매, 소매하다","pronunciation":"/ˈriːteɪl/","parts":[{"type":"prefix","text":"re-","meaning":"다시 (again)"},{"type":"root","text":"tail","meaning":"자르다 (cut)"}],"story":"도매상에서 대량으로 사 온 물건을 소비자에게 팔기 위해 '다시(re)' 작게 '잘라(tail)' 파는 것 → 소매.","example":{"en":"The retail price.","ko":"소매가."}},
  {"word":"tailor","level":"middle","meaning":"재단사, 맞추다","pronunciation":"/ˈteɪlər/","parts":[{"type":"root","text":"tail","meaning":"자르다 (cut)"},{"type":"suffix","text":"-or","meaning":"사람"}],"story":"손님의 체형에 맞게 천을 치수에 맞춰 '자르는(tail)' '사람(or)' → 재단사.","example":{"en":"A custom tailor.","ko":"맞춤복 재단사."}},
  {"word":"curtail","level":"high","meaning":"축소하다, 삭감하다","pronunciation":"/kɜːrˈteɪl/","parts":[{"type":"root","text":"curt","meaning":"짧은 (short)"},{"type":"root","text":"tail","meaning":"자르다 (cut)"}],"story":"길게 이어진 것의 끝부분을 '잘라내어(tail)' '짧게(curt)' 만들다 → 축소하다.","example":{"en":"Curtail spending.","ko":"지출을 삭감하다."}},
  {"word":"entail","level":"high","meaning":"수반하다, 필요로 하다","pronunciation":"/ɪnˈteɪl/","parts":[{"type":"prefix","text":"en-","meaning":"만들다 (make)"},{"type":"root","text":"tail","meaning":"꼬리, 상속 (tail)"}],"story":"과거 법률에서 재산의 상속인 꼬리(tail)를 정해두어 필연적으로 그 결과가 따라오게 만들다 → 수반하다.","example":{"en":"The job entails a lot of travel.","ko":"그 일은 많은 출장을 수반한다."}},
  {"word":"technique","level":"middle","meaning":"기법, 기술","pronunciation":"/tekˈniːk/","parts":[{"type":"root","text":"techn","meaning":"기술, 예술 (art/skill)"},{"type":"suffix","text":"-ique","meaning":"명사형"}],"story":"오랜 연습과 노력으로 몸에 익힌 숙련된 '기술(techn)'.","example":{"en":"A new painting technique.","ko":"새로운 그림 기법."}},
  {"word":"technology","level":"middle","meaning":"과학 기술","pronunciation":"/tekˈnɑːlədʒi/","parts":[{"type":"root","text":"techno","meaning":"기술 (skill)"},{"type":"suffix","text":"-logy","meaning":"학문"}],"story":"인간의 삶을 편하게 하기 위한 기계나 도구의 '기술(techno)'을 연구하는 학문 → 과학 기술.","example":{"en":"Information technology.","ko":"정보기술 (IT)."}},
  {"word":"technical","level":"middle","meaning":"기술적인, 전문적인","pronunciation":"/ˈteknɪkl/","parts":[{"type":"root","text":"techn","meaning":"기술 (skill)"},{"type":"suffix","text":"-ical","meaning":"형용사형"}],"story":"고도의 '기술(techn)'이나 전문 지식과 관련된.","example":{"en":"Technical support.","ko":"기술 지원."}},
  {"word":"technician","level":"middle","meaning":"기술자, 전문가","pronunciation":"/tekˈnɪʃn/","parts":[{"type":"root","text":"techn","meaning":"기술 (skill)"},{"type":"suffix","text":"-ician","meaning":"사람"}],"story":"특정 분야의 기계나 '기술(techn)'을 전문적으로 다루는 사람 → 기술자.","example":{"en":"A lab technician.","ko":"실험실 기술자."}},
  {"word":"biotechnology","level":"high","meaning":"생명 공학","pronunciation":"/ˌbaɪoʊtekˈnɑːlədʒi/","parts":[{"type":"root","text":"bio","meaning":"생명"},{"type":"root","text":"technology","meaning":"기술"}],"story":"'생명(bio)'체의 원리를 바탕으로 인간에게 유용한 것을 만들어내는 '기술(technology)' → 생명 공학.","example":{"en":"Advances in biotechnology.","ko":"생명 공학의 발전."}},
  {"word":"theology","level":"high","meaning":"신학","pronunciation":"/θiˈɑːlədʒi/","parts":[{"type":"root","text":"theo","meaning":"신 (god)"},{"type":"suffix","text":"-logy","meaning":"학문"}],"story":"세상을 창조한 '신(theo)'의 존재와 종교적 교리를 연구하는 '학문(logy)'.","example":{"en":"Study theology.","ko":"신학을 공부하다."}},
  {"word":"atheist","level":"high","meaning":"무신론자","pronunciation":"/ˈeɪθiɪst/","parts":[{"type":"prefix","text":"a-","meaning":"없는 (without)"},{"type":"root","text":"the","meaning":"신 (god)"},{"type":"suffix","text":"-ist","meaning":"사람"}],"story":"세상에 '신(the)'이 '존재하지 않는(a)'다고 믿는 사람 → 무신론자.","example":{"en":"He is a strict atheist.","ko":"그는 철저한 무신론자이다."}},
  {"word":"theism","level":"high","meaning":"유신론","pronunciation":"/ˈθiːɪzəm/","parts":[{"type":"root","text":"the","meaning":"신 (god)"},{"type":"suffix","text":"-ism","meaning":"사상"}],"story":"우주를 창조하고 관리하는 '신(the)'이 존재한다고 믿는 '사상(ism)'.","example":{"en":"The concept of theism.","ko":"유신론의 개념."}},
  {"word":"pantheon","level":"high","meaning":"만신전, 영묘","pronunciation":"/ˈpænθiɑːn/","parts":[{"type":"prefix","text":"pan-","meaning":"모든 (all)"},{"type":"root","text":"theo","meaning":"신 (god)"},{"type":"suffix","text":"-on","meaning":"장소"}],"story":"로마 시대에 '모든(pan)' '신(theo)'들을 모시기 위해 지은 웅장한 건축물 → 만신전, 위인들의 전당.","example":{"en":"The Roman Pantheon.","ko":"로마의 판테온."}},
  {"word":"polytheism","level":"high","meaning":"다신교","pronunciation":"/ˈpɑːliθiːɪzəm/","parts":[{"type":"prefix","text":"poly-","meaning":"많은 (many)"},{"type":"root","text":"the","meaning":"신 (god)"},{"type":"suffix","text":"-ism","meaning":"사상"}],"story":"그리스 로마 신화처럼 세상에 '많은(poly)' '신(the)'들이 존재한다고 믿는 종교.","example":{"en":"Ancient Greek polytheism.","ko":"고대 그리스의 다신교."}},
  {"word":"tone","level":"middle","meaning":"어조, 음색, 분위기","pronunciation":"/toʊn/","parts":[{"type":"root","text":"ton","meaning":"소리, 팽팽함 (sound)"}],"story":"성대가 팽팽하게 당겨지며 나는 '소리(ton)'의 높낮이와 느낌 → 어조, 분위기.","example":{"en":"A friendly tone.","ko":"친절한 어조."}},
  {"word":"tune","level":"middle","meaning":"곡조, 선율, 조율하다","pronunciation":"/tuːn/","parts":[{"type":"root","text":"tun(ton)","meaning":"소리 (sound)"}],"story":"악기가 내는 아름다운 '소리(tun)'. 또는 악기가 제 소리를 내게 맞추다 → 조율하다.","example":{"en":"Sing a tune.","ko":"노래(곡조)를 부르다."}},
  {"word":"intonation","level":"high","meaning":"억양","pronunciation":"/ˌɪntəˈneɪʃn/","parts":[{"type":"prefix","text":"in-","meaning":"안에 (in)"},{"type":"root","text":"ton","meaning":"소리 (sound)"},{"type":"suffix","text":"-ation","meaning":"명사형"}],"story":"문장을 말할 때 그 '안(in)'에 들어가는 '소리의 높낮이(ton)' → 억양.","example":{"en":"Rising intonation.","ko":"상승 억양."}},
  {"word":"monotonous","level":"high","meaning":"단조로운, 지루한","pronunciation":"/məˈnɑːtənəs/","parts":[{"type":"prefix","text":"mono-","meaning":"하나의 (one)"},{"type":"root","text":"ton","meaning":"소리 (sound)"},{"type":"suffix","text":"-ous","meaning":"형용사형"}],"story":"높낮이 변화 없이 오직 '하나의(mono)' '소리(ton)'만 계속 반복되어 → 지루한.","example":{"en":"A monotonous voice.","ko":"단조로운 목소리."}},
  {"word":"attune","level":"high","meaning":"조율하다, 맞추다","pronunciation":"/əˈtuːn/","parts":[{"type":"prefix","text":"at(ad)-","meaning":"~에 (to)"},{"type":"root","text":"tune","meaning":"소리, 조화"}],"story":"상대방의 마음이나 상황'에(at)' 내 '소리/주파수(tune)'를 부드럽게 맞추다.","example":{"en":"Attuned to the needs of customers.","ko":"고객의 요구에 맞춰진."}},
  {"word":"toxic","level":"middle","meaning":"유독한, 독성의","pronunciation":"/ˈtɑːksɪk/","parts":[{"type":"root","text":"tox","meaning":"독 (poison)"},{"type":"suffix","text":"-ic","meaning":"형용사형"}],"story":"고대 그리스어에서 화살에 바르는 '독(tox)'에서 유래 → 유독한.","example":{"en":"Toxic chemicals.","ko":"유독한 화학물질."}},
  {"word":"toxin","level":"high","meaning":"독소","pronunciation":"/ˈtɑːksɪn/","parts":[{"type":"root","text":"tox","meaning":"독 (poison)"},{"type":"suffix","text":"-in","meaning":"물질"}],"story":"생물체가 만들어내는 '독(tox)' 성분을 가진 화학 물질 → 독소.","example":{"en":"Release toxins.","ko":"독소를 배출하다."}},
  {"word":"intoxicate","level":"high","meaning":"취하게 하다, 중독시키다","pronunciation":"/ɪnˈtɑːksɪkeɪt/","parts":[{"type":"prefix","text":"in-","meaning":"안으로"},{"type":"root","text":"toxic","meaning":"독성"},{"type":"suffix","text":"-ate","meaning":"동사형"}],"story":"술이나 알코올(독)이 몸 '안으로(in)' 들어가 이성을 마비시키다 → 취하게 하다.","example":{"en":"Intoxicated with success.","ko":"승리감에 도취된."}},
  {"word":"detoxify","level":"high","meaning":"해독하다","pronunciation":"/diˈtɑːksɪfaɪ/","parts":[{"type":"prefix","text":"de-","meaning":"제거하다 (remove)"},{"type":"root","text":"tox","meaning":"독 (poison)"},{"type":"suffix","text":"-ify","meaning":"만들다"}],"story":"몸속에 쌓인 나쁜 '독소(tox)'를 씻어내어 '제거(de)'하다 → 디톡스하다.","example":{"en":"Detoxify the body.","ko":"몸을 해독하다."}},
  {"word":"toxicology","level":"high","meaning":"독성학","pronunciation":"/ˌtɑːksɪˈkɑːlədʒi/","parts":[{"type":"root","text":"toxico","meaning":"독 (poison)"},{"type":"suffix","text":"-logy","meaning":"학문"}],"story":"화학물질의 '독성(toxico)'과 그 해독법을 전문적으로 연구하는 '학문(logy)'.","example":{"en":"A professor of toxicology.","ko":"독성학 교수."}}
