[
  {"word":"persuade","level":"middle","meaning":"설득하다","pronunciation":"/pərˈsweɪd/","parts":[{"type":"prefix","text":"per-","meaning":"완전히 (completely)"},{"type":"root","text":"suade","meaning":"달콤하게 권하다 (advise)"}],"story":"상대방의 마음이 돌아서도록 '완전히(per)' '달콤한 말로 권하다(suade)' → 설득하다.","example":{"en":"Persuade him to join.","ko":"그가 가입하도록 설득하다."}},
  {"word":"persuasion","level":"middle","meaning":"설득, 신념","pronunciation":"/pərˈsweɪʒn/","parts":[{"type":"root","text":"persuade","meaning":"설득하다"},{"type":"suffix","text":"-sion","meaning":"명사형"}],"story":"달콤한 말로 상대방을 내가 원하는 방향으로 이끄는 것 → 설득.","example":{"en":"The power of persuasion.","ko":"설득의 힘."}},
  {"word":"persuasive","level":"high","meaning":"설득력 있는","pronunciation":"/pərˈsweɪsɪv/","parts":[{"type":"root","text":"persuade","meaning":"설득하다"},{"type":"suffix","text":"-sive","meaning":"형용사형"}],"story":"사람의 마음을 흔들어 내 편으로 만들 만큼 논리와 매력이 있는 → 설득력 있는.","example":{"en":"A persuasive argument.","ko":"설득력 있는 주장."}},
  {"word":"dissuade","level":"high","meaning":"만류하다, 단념시키다","pronunciation":"/dɪˈsweɪd/","parts":[{"type":"prefix","text":"dis-","meaning":"반대로, 멀리 (away)"},{"type":"root","text":"suade","meaning":"권하다 (advise)"}],"story":"어떤 행동을 하지 못하도록 '반대 방향으로(dis)' '권하다(suade)' → 만류하다.","example":{"en":"Dissuade her from leaving.","ko":"그녀가 떠나지 못하게 만류하다."}},
  {"word":"assuage","level":"high","meaning":"누그러뜨리다, 달래다","pronunciation":"/əˈsweɪdʒ/","parts":[{"type":"prefix","text":"as(ad)-","meaning":"~쪽으로 (to)"},{"type":"root","text":"suage(suade)","meaning":"달콤한 (sweet)"}],"story":"화난 마음이나 고통을 '달콤하고 부드럽게(suage)' 만들다 → 달래다.","example":{"en":"Assuage someone's anger.","ko":"누군가의 분노를 누그러뜨리다."}},
  {"word":"surge","level":"high","meaning":"급증하다, 밀려들다","pronunciation":"/sɜːrdʒ/","parts":[{"type":"root","text":"surg","meaning":"위로 일어나다 (rise)"}],"story":"물결이나 감정이 갑자기 확 '위로 솟아오르다(surg)' → 급증, 밀려들다.","example":{"en":"A surge in demand.","ko":"수요의 급증."}},
  {"word":"resurgent","level":"high","meaning":"다시 일어서는, 부활하는","pronunciation":"/rɪˈsɜːrdʒənt/","parts":[{"type":"prefix","text":"re-","meaning":"다시 (again)"},{"type":"root","text":"surg","meaning":"일어나다 (rise)"},{"type":"suffix","text":"-ent","meaning":"형용사형"}],"story":"가라앉았던 세력이나 유행이 '다시(re)' '솟아오르는(surg)' → 부활하는.","example":{"en":"A resurgent economy.","ko":"다시 살아나는 경제."}},
  {"word":"insurgent","level":"high","meaning":"반란을 일으키는, 반군","pronunciation":"/ɪnˈsɜːrdʒənt/","parts":[{"type":"prefix","text":"in-","meaning":"대항하여 (against)"},{"type":"root","text":"surg","meaning":"일어나다 (rise)"},{"type":"suffix","text":"-ent","meaning":"사람"}],"story":"기존 정부나 체제에 '대항하여(in)' 무기를 들고 '일어난(surg)' 사람 → 반군.","example":{"en":"Armed insurgents.","ko":"무장한 반군들."}},
  {"word":"source","level":"middle","meaning":"원천, 출처","pronunciation":"/sɔːrs/","parts":[{"type":"root","text":"sourc(surg)","meaning":"솟아오르다 (rise)"}],"story":"물이 땅속에서 '솟아오르는(sourc)' 샘물이나 강물의 시작점 → 원천, 근원.","example":{"en":"The source of the river.","ko":"그 강의 발원지(원천)."}},
  {"word":"resource","level":"middle","meaning":"자원, 재원","pronunciation":"/ˈriːsɔːrs/","parts":[{"type":"prefix","text":"re-","meaning":"다시, 계속 (again)"},{"type":"root","text":"source","meaning":"원천 (rise)"}],"story":"필요할 때마다 '계속해서(re)' 솟아나오고(source) 얻어 쓸 수 있는 것 → 천연자원, 재산.","example":{"en":"Natural resources.","ko":"천연 자원."}},
  {"word":"protect","level":"middle","meaning":"보호하다, 지키다","pronunciation":"/prəˈtekt/","parts":[{"type":"prefix","text":"pro-","meaning":"앞에서 (in front)"},{"type":"root","text":"tect","meaning":"덮다 (cover)"}],"story":"위험이 다가오지 못하게 '앞에서(pro)' 방패막이로 '덮어주다(tect)' → 보호하다.","example":{"en":"Protect the environment.","ko":"환경을 보호하다."}},
  {"word":"protection","level":"middle","meaning":"보호, 방어","pronunciation":"/prəˈtekʃn/","parts":[{"type":"root","text":"protect","meaning":"보호하다"},{"type":"suffix","text":"-ion","meaning":"명사형"}],"story":"위험이나 손상으로부터 대상을 안전하게 지켜주는 행위.","example":{"en":"Data protection.","ko":"데이터 보호."}},
  {"word":"protective","level":"middle","meaning":"보호하는, 방어적인","pronunciation":"/prəˈtektɪv/","parts":[{"type":"root","text":"protect","meaning":"보호하다"},{"type":"suffix","text":"-ive","meaning":"형용사형"}],"story":"어떤 대상을 상처 입지 않게 덮어주고 막아주는 역할을 하는.","example":{"en":"Protective clothing.","ko":"보호복."}},
  {"word":"detect","level":"middle","meaning":"발견하다, 감지하다","pronunciation":"/dɪˈtekt/","parts":[{"type":"prefix","text":"de-","meaning":"제거하다, 벗기다 (un-)"},{"type":"root","text":"tect","meaning":"덮다 (cover)"}],"story":"무언가를 숨기려고 '덮어둔(tect)' 것을 들추고 '벗겨내다(de)' → 숨겨진 것을 알아내다.","example":{"en":"Detect a lie.","ko":"거짓말을 감지하다."}},
  {"word":"detective","level":"middle","meaning":"탐정, 형사","pronunciation":"/dɪˈtektɪv/","parts":[{"type":"root","text":"detect","meaning":"발견하다, 찾아내다"},{"type":"suffix","text":"-ive","meaning":"사람"}],"story":"범죄의 숨겨진 증거를 벗겨내어 '찾아내는(detect)' '사람(ive)' → 탐정.","example":{"en":"A private detective.","ko":"사립 탐정."}},
  {"word":"text","level":"middle","meaning":"본문, 글, 문자 메시지","pronunciation":"/tekst/","parts":[{"type":"root","text":"text","meaning":"짜다, 엮다 (weave)"}],"story":"단어와 문장들을 실처럼 가로세로로 '엮어서(text)' 만든 것 → 글, 본문.","example":{"en":"Send a text message.","ko":"문자 메시지를 보내다."}},
  {"word":"context","level":"high","meaning":"문맥, 맥락, 상황","pronunciation":"/ˈkɑːntekst/","parts":[{"type":"prefix","text":"con-","meaning":"함께 (together)"},{"type":"root","text":"text","meaning":"짜다 (weave)"}],"story":"단어와 주변 문장들이 '함께(con)' '짜여서(text)' 이루는 전체적인 분위기나 흐름 → 문맥.","example":{"en":"Out of context.","ko":"문맥을 벗어난."}},
  {"word":"texture","level":"middle","meaning":"질감, 감촉","pronunciation":"/ˈtekstʃər/","parts":[{"type":"root","text":"text","meaning":"짜다 (weave)"},{"type":"suffix","text":"-ure","meaning":"명사형"}],"story":"천이나 직물을 '짠(text)' 방식에 따라 만졌을 때 느껴지는 거칠거나 부드러운 느낌 → 질감.","example":{"en":"A smooth texture.","ko":"부드러운 질감."}},
  {"word":"textile","level":"high","meaning":"직물, 옷감","pronunciation":"/ˈtekstaɪl/","parts":[{"type":"root","text":"text","meaning":"짜다 (weave)"},{"type":"suffix","text":"-ile","meaning":"명사/형용사형"}],"story":"실을 교차하여 '짜서(text)' 만든 천이나 옷감.","example":{"en":"The textile industry.","ko":"섬유(직물) 산업."}},
  {"word":"pretext","level":"high","meaning":"구실, 핑계","pronunciation":"/ˈpriːtekst/","parts":[{"type":"prefix","text":"pre-","meaning":"앞에 (before)"},{"type":"root","text":"text","meaning":"짜다 (weave)"}],"story":"진짜 의도는 숨기고 사람들 '앞에(pre)' 내세우려고 교묘하게 '짜 맞춘(text)' 말 → 핑계.","example":{"en":"Under the pretext of helping.","ko":"도와준다는 구실로."}},
  {"word":"tradition","level":"middle","meaning":"전통, 관습","pronunciation":"/trəˈdɪʃn/","parts":[{"type":"root","text":"trad","meaning":"넘겨주다 (hand over)"},{"type":"suffix","text":"-ition","meaning":"명사형"}],"story":"과거 세대에서 다음 세대로 계속해서 '넘겨주고(trad)' 전해져 내려온 것 → 전통.","example":{"en":"A long tradition.","ko":"오랜 전통."}},
  {"word":"traditional","level":"middle","meaning":"전통적인","pronunciation":"/trəˈdɪʃənl/","parts":[{"type":"root","text":"tradition","meaning":"전통"},{"type":"suffix","text":"-al","meaning":"형용사형"}],"story":"오랜 세월 동안 전해 내려오는 방식이나 사상을 따르는.","example":{"en":"Traditional Korean food.","ko":"한국 전통 음식."}},
  {"word":"trade","level":"middle","meaning":"무역, 거래(하다)","pronunciation":"/treɪd/","parts":[{"type":"root","text":"trade(trad)","meaning":"넘겨주다 (hand over)"}],"story":"서로가 가진 물건이나 돈을 상대방에게 '넘겨주고(trad)' 받는 행위 → 무역.","example":{"en":"International trade.","ko":"국제 무역."}},
  {"word":"traitor","level":"high","meaning":"반역자, 배신자","pronunciation":"/ˈtreɪtər/","parts":[{"type":"root","text":"trait(trad)","meaning":"넘겨주다 (hand over)"},{"type":"suffix","text":"-or","meaning":"사람"}],"story":"자신의 조국이나 동료를 적의 손에 '넘겨주는(trait)' '사람(or)' → 반역자.","example":{"en":"A traitor to his country.","ko":"조국의 반역자."}},
  {"word":"treason","level":"high","meaning":"반역죄, 배신","pronunciation":"/ˈtriːzn/","parts":[{"type":"root","text":"treas(trad)","meaning":"넘겨주다 (hand over)"},{"type":"suffix","text":"-on","meaning":"명사형"}],"story":"국가의 기밀이나 권력을 적에게 '넘겨주는(treas)' 행위나 범죄 → 반역죄.","example":{"en":"Commit treason.","ko":"반역죄를 저지르다."}},
  {"word":"consist","level":"middle","meaning":"구성되다, 일치하다","pronunciation":"/kənˈsɪst/","parts":[{"type":"prefix","text":"con-","meaning":"함께 (together)"},{"type":"root","text":"sist","meaning":"서다 (stand)"}],"story":"여러 가지 부품이나 요소들이 '함께(con)' 묶여서 하나의 모양으로 '서 있다(sist)' → 구성되다.","example":{"en":"Water consists of hydrogen and oxygen.","ko":"물은 수소와 산소로 구성된다."}},
  {"word":"insist","level":"middle","meaning":"주장하다, 고집하다","pronunciation":"/ɪnˈsɪst/","parts":[{"type":"prefix","text":"in-","meaning":"위에 (on)"},{"type":"root","text":"sist","meaning":"서다 (stand)"}],"story":"자신의 의견 '위에(in)' 꼿꼿이 '서서(sist)' 절대 물러나지 않다 → 고집하다.","example":{"en":"He insisted on paying.","ko":"그는 자기가 돈을 내겠다고 고집했다."}},
  {"word":"persist","level":"high","meaning":"집요하게 계속하다, 지속되다","pronunciation":"/pərˈsɪst/","parts":[{"type":"prefix","text":"per-","meaning":"끝까지 (through)"},{"type":"root","text":"sist","meaning":"서다 (stand)"}],"story":"반대나 어려움에도 불구하고 '끝까지(per)' 버티고 '서 있다(sist)' → 고집스럽게 계속하다.","example":{"en":"Persist in one's opinion.","ko":"자기 의견을 끝까지 고집하다."}},
  {"word":"resist","level":"middle","meaning":"저항하다, 반대하다","pronunciation":"/rɪˈzɪst/","parts":[{"type":"prefix","text":"re-","meaning":"대항하여 (against)"},{"type":"root","text":"sist","meaning":"서다 (stand)"}],"story":"밀고 들어오는 힘에 '대항하여(re)' 밀리지 않고 딱 버티고 '서다(sist)' → 저항하다.","example":{"en":"Resist temptation.","ko":"유혹에 저항하다."}},
  {"word":"assist","level":"middle","meaning":"돕다, 거들다","pronunciation":"/əˈsɪst/","parts":[{"type":"prefix","text":"as(ad)-","meaning":"옆에 (to)"},{"type":"root","text":"sist","meaning":"서다 (stand)"}],"story":"도움이 필요한 사람 '옆에(as)' 나란히 '서서(sist)' 힘을 보태주다 → 돕다.","example":{"en":"Assist a customer.","ko":"고객을 돕다."}},
  {"word":"abound","level":"high","meaning":"풍부하다, 아주 많다","pronunciation":"/əˈbaʊnd/","parts":[{"type":"prefix","text":"ab-","meaning":"넘쳐서 (away)"},{"type":"root","text":"ound(und)","meaning":"물결 (wave)"}],"story":"넘치는 '물결(und)'처럼 사물이나 사람이 파도 치듯 아주 많다 → 풍부하다.","example":{"en":"Rumors abound.","ko":"소문이 파다하다(넘쳐난다)."}},
  {"word":"abundant","level":"middle","meaning":"풍부한, 넘치는","pronunciation":"/əˈbʌndənt/","parts":[{"type":"root","text":"abound","meaning":"풍부하다"},{"type":"suffix","text":"-ant","meaning":"형용사형"}],"story":"파도가 넘실거리듯 자원이나 수량이 아주 넉넉하고 넘쳐나는.","example":{"en":"Abundant resources.","ko":"풍부한 자원."}},
  {"word":"abundance","level":"middle","meaning":"풍부, 다량","pronunciation":"/əˈbʌndəns/","parts":[{"type":"root","text":"abound","meaning":"풍부하다"},{"type":"suffix","text":"-ance","meaning":"명사형"}],"story":"무언가가 모자람 없이 넘칠 정도로 아주 많은 상태.","example":{"en":"An abundance of food.","ko":"풍부한 음식."}},
  {"word":"surround","level":"middle","meaning":"둘러싸다, 포위하다","pronunciation":"/səˈraʊnd/","parts":[{"type":"prefix","text":"sur-","meaning":"넘어서 (over)"},{"type":"root","text":"round(und)","meaning":"물결 (wave)"}],"story":"사방에서 '물결(und)'이 덮쳐오듯 대상을 둥글게 '에워싸다(sur)' → 포위하다.","example":{"en":"Surrounded by mountains.","ko":"산으로 둘러싸인."}},
  {"word":"redundant","level":"high","meaning":"불필요한, 중복되는","pronunciation":"/rɪˈdʌndənt/","parts":[{"type":"prefix","text":"red(re)-","meaning":"다시, 넘치게"},{"type":"root","text":"und","meaning":"물결 (wave)"},{"type":"suffix","text":"-ant","meaning":"형용사형"}],"story":"이미 꽉 찼는데 '물결(und)'이 '다시(red)' 밀려와 찰랑거려 넘쳐버리는 → 불필요하게 남아도는.","example":{"en":"Redundant workers.","ko":"잉여(정리해고 대상) 인력."}},
  {"word":"verb","level":"middle","meaning":"동사","pronunciation":"/vɜːrb/","parts":[{"type":"root","text":"verb","meaning":"단어 (word)"}],"story":"문장을 만들 때 행동을 나타내는 가장 핵심적인 '단어(verb)' → 동사.","example":{"en":"An irregular verb.","ko":"불규칙 동사."}},
  {"word":"verbal","level":"middle","meaning":"언어의, 구두의 (말의)","pronunciation":"/ˈvɜːrbl/","parts":[{"type":"root","text":"verb","meaning":"단어, 말 (word)"},{"type":"suffix","text":"-al","meaning":"형용사형"}],"story":"글씨가 아니라 입 밖으로 내뱉는 '단어(verb)'나 말과 관련된 → 구두의.","example":{"en":"A verbal agreement.","ko":"구두(말) 약속."}},
  {"word":"proverb","level":"middle","meaning":"속담, 격언","pronunciation":"/ˈprɑːvɜːrb/","parts":[{"type":"prefix","text":"pro-","meaning":"앞에 (before)"},{"type":"root","text":"verb","meaning":"말, 단어 (word)"}],"story":"예전부터 사람들 '앞에서(pro)' 교훈을 주려고 자주 쓰이던 '말(verb)' → 속담.","example":{"en":"An old proverb.","ko":"오래된 속담."}},
  {"word":"adverb","level":"middle","meaning":"부사","pronunciation":"/ˈædvɜːrb/","parts":[{"type":"prefix","text":"ad-","meaning":"~에, 더하여 (to)"},{"type":"root","text":"verb","meaning":"동사 (verb)"}],"story":"문장에서 동사(verb)나 다른 단어에 뜻을 '더하여(ad)' 꾸며주는 말 → 부사.","example":{"en":"An adverb modifies a verb.","ko":"부사는 동사를 수식한다."}},
  {"word":"verbatim","level":"high","meaning":"말 그대로, 글자 그대로","pronunciation":"/vɜːrˈbeɪtɪm/","parts":[{"type":"root","text":"verb","meaning":"단어 (word)"},{"type":"suffix","text":"-atim","meaning":"그대로"}],"story":"남이 한 말을 한 '단어(verb)'도 틀리지 않고 토씨 하나 똑같이 → 글자 그대로.","example":{"en":"Repeat verbatim.","ko":"토씨 하나 안 틀리고 반복하다."}},
  {"word":"victor","level":"middle","meaning":"승리자","pronunciation":"/ˈvɪktər/","parts":[{"type":"root","text":"vict","meaning":"이기다 (conquer)"},{"type":"suffix","text":"-or","meaning":"사람"}],"story":"전쟁이나 경기에서 적을 '이긴(vict)' '사람(or)' → 승리자.","example":{"en":"The victor of the battle.","ko":"전투의 승리자."}},
  {"word":"victory","level":"middle","meaning":"승리","pronunciation":"/ˈvɪktəri/","parts":[{"type":"root","text":"vict","meaning":"이기다"},{"type":"suffix","text":"-ory","meaning":"명사형"}],"story":"상대방을 정복하고 이겨서 얻어낸 영광스러운 결과 → 승리.","example":{"en":"A great victory.","ko":"위대한 승리."}},
  {"word":"victim","level":"middle","meaning":"희생자, 피해자","pronunciation":"/ˈvɪktɪm/","parts":[{"type":"root","text":"vict","meaning":"정복당하다, 이기다"},{"type":"suffix","text":"-im","meaning":"사람"}],"story":"전쟁에서 승리자(victor)에게 정복당해 죽거나 다친 사람 → 희생자.","example":{"en":"An innocent victim.","ko":"무고한 희생자."}},
  {"word":"convince","level":"middle","meaning":"납득시키다, 확신시키다","pronunciation":"/kənˈvɪns/","parts":[{"type":"prefix","text":"con-","meaning":"완전히 (completely)"},{"type":"root","text":"vince(vict)","meaning":"이기다 (conquer)"}],"story":"말로 상대방의 의심을 '완전히(con)' 정복하고 '이겨서(vince)' 내 편으로 만들다 → 납득시키다.","example":{"en":"Convince him to stay.","ko":"그가 머물도록 설득(확신)시키다."}},
  {"word":"province","level":"middle","meaning":"지방, 주(州)","pronunciation":"/ˈprɑːvɪns/","parts":[{"type":"prefix","text":"pro-","meaning":"앞으로"},{"type":"root","text":"vince(vict)","meaning":"정복하다 (conquer)"}],"story":"과거 로마가 앞으로 나아가 군대로 '정복한(vince)' 영토 → 속주, 지방.","example":{"en":"Gyeonggi province.","ko":"경기도."}},
  {"word":"appear","level":"middle","meaning":"나타나다, ~인 것 같다","pronunciation":"/əˈpɪr/","parts":[{"type":"prefix","text":"ap(ad)-","meaning":"~쪽으로 (to)"},{"type":"root","text":"pear","meaning":"보이다 (visible)"}],"story":"사람들 눈 '앞으로(ap)' 그 모습이 또렷하게 '보이다(pear)' → 나타나다.","example":{"en":"He appeared suddenly.","ko":"그가 갑자기 나타났다."}},
  {"word":"apparent","level":"middle","meaning":"분명한, 겉보기의","pronunciation":"/əˈpærənt/","parts":[{"type":"prefix","text":"ap-","meaning":"~쪽으로"},{"type":"root","text":"par(pear)","meaning":"보이다"},{"type":"suffix","text":"-ent","meaning":"형용사형"}],"story":"눈앞에 훤히 '드러나 보이는(par)' → 명백한. 겉으로만 '보이는' → 겉보기의.","example":{"en":"For no apparent reason.","ko":"분명한 이유 없이."}},
  {"word":"appearance","level":"middle","meaning":"외모, 겉모습, 출현","pronunciation":"/əˈpɪrəns/","parts":[{"type":"root","text":"appear","meaning":"보이다"},{"type":"suffix","text":"-ance","meaning":"명사형"}],"story":"사람들 눈에 겉으로 '보여지는' 형태나 생김새 → 외모.","example":{"en":"Judge by appearance.","ko":"겉모습으로 판단하다."}},
  {"word":"disappear","level":"middle","meaning":"사라지다","pronunciation":"/ˌdɪsəˈpɪr/","parts":[{"type":"prefix","text":"dis-","meaning":"반대로, 멀리"},{"type":"root","text":"appear","meaning":"보이다"}],"story":"보이던 모습이 '반대로(dis)' 멀리 가서 더 이상 눈에 보이지 않게 되다 → 사라지다.","example":{"en":"Disappear into the dark.","ko":"어둠 속으로 사라지다."}},
  {"word":"transparent","level":"high","meaning":"투명한, 명백한","pronunciation":"/trænsˈpærənt/","parts":[{"type":"prefix","text":"trans-","meaning":"통과하여 (through)"},{"type":"root","text":"par","meaning":"보이다 (visible)"},{"type":"suffix","text":"-ent","meaning":"형용사형"}],"story":"유리나 물처럼 속이 '관통하여(trans)' 훤히 '들여다보이는(par)' → 투명한.","example":{"en":"Transparent glass.","ko":"투명한 유리."}}
