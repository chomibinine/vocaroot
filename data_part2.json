[
  {"word":"sympathy","level":"middle","meaning":"동정, 공감","pronunciation":"/ˈsɪmpəθi/","parts":[{"type":"prefix","text":"sym-","meaning":"함께 (together)"},{"type":"root","text":"pathy","meaning":"감정 (feeling)"}],"story":"타인의 슬픔을 '함께(sym)' '느끼는 것(pathy)' → 동정.","example":{"en":"I feel sympathy for her.","ko":"그녀에게 공감한다."}},
  {"word":"apathy","level":"high","meaning":"무관심","pronunciation":"/ˈæpəθi/","parts":[{"type":"prefix","text":"a-","meaning":"없는 (without)"},{"type":"root","text":"pathy","meaning":"감정 (feeling)"}],"story":"아무런 '감정(pathy)'이 '없는(a)' 상태 → 무관심.","example":{"en":"Public apathy.","ko":"대중의 무관심."}},
  {"word":"telepathy","level":"middle","meaning":"텔레파시","pronunciation":"/təˈlepəθi/","parts":[{"type":"prefix","text":"tele-","meaning":"멀리서 (far)"},{"type":"root","text":"pathy","meaning":"감정 (feeling)"}],"story":"'멀리(tele)' 떨어져도 '감정(pathy)'이 전달됨.","example":{"en":"Communicate by telepathy.","ko":"텔레파시로 소통하다."}},
  {"word":"passion","level":"middle","meaning":"열정","pronunciation":"/ˈpæʃn/","parts":[{"type":"root","text":"pass","meaning":"고통, 감정 (suffering)"},{"type":"suffix","text":"-ion","meaning":"명사형"}],"story":"고통을 감수할 만큼 강렬한 '감정(pass)' → 열정.","example":{"en":"Passion for music.","ko":"음악에 대한 열정."}},
  {"word":"passive","level":"middle","meaning":"수동적인","pronunciation":"/ˈpæsɪv/","parts":[{"type":"root","text":"pass","meaning":"고통을 겪다"},{"type":"suffix","text":"-ive","meaning":"형용사형"}],"story":"능동적으로 하지 않고 힘을 '받아들이는(pass)' → 수동적인.","example":{"en":"A passive attitude.","ko":"수동적인 태도."}},
  {"word":"capital","level":"middle","meaning":"수도, 자본","pronunciation":"/ˈkæpɪtl/","parts":[{"type":"root","text":"capit","meaning":"머리 (head)"},{"type":"suffix","text":"-al","meaning":"관련된"}],"story":"국가의 '머리(capit)' 역할을 하는 것 → 수도.","example":{"en":"Seoul is the capital.","ko":"서울은 수도다."}},
  {"word":"captain","level":"middle","meaning":"선장, 주장","pronunciation":"/ˈkæptɪn/","parts":[{"type":"root","text":"capt","meaning":"머리 (head)"},{"type":"suffix","text":"-ain","meaning":"사람"}],"story":"배나 팀의 '머리(capt)' 역할을 하는 사람 → 선장.","example":{"en":"The captain of the ship.","ko":"배의 선장."}},
  {"word":"cabbage","level":"middle","meaning":"양배추","pronunciation":"/ˈkæbɪdʒ/","parts":[{"type":"root","text":"cab","meaning":"머리 (head)"}],"story":"모양이 사람 '머리(cap)'처럼 둥글게 생겨서 붙은 이름.","example":{"en":"Chop the cabbage.","ko":"양배추를 썰어라."}},
  {"word":"cape","level":"high","meaning":"망토","pronunciation":"/keɪp/","parts":[{"type":"root","text":"cap","meaning":"머리 (head)"}],"story":"'머리(cap)'까지 덮어쓰는 옷 → 망토.","example":{"en":"Superman wears a cape.","ko":"슈퍼맨은 망토를 입는다."}},
  {"word":"capable","level":"middle","meaning":"유능한","pronunciation":"/ˈkeɪpəbl/","parts":[{"type":"root","text":"cap","meaning":"잡다, 취하다"},{"type":"suffix","text":"-able","meaning":"할 수 있는"}],"story":"어떤 일을 내 손으로 꽉 '잡을(cap)' 수 '있는(able)' → 유능한.","example":{"en":"She is a capable leader.","ko":"그녀는 유능한 리더다."}},
  {"word":"vocal","level":"middle","meaning":"목소리의","pronunciation":"/ˈvoʊkl/","parts":[{"type":"root","text":"voc","meaning":"목소리 (voice)"},{"type":"suffix","text":"-al","meaning":"형용사형"}],"story":"'목소리(voc)'와 관련된 → 음성의, 보컬.","example":{"en":"Vocal cords.","ko":"성대."}},
  {"word":"vocabulary","level":"middle","meaning":"어휘","pronunciation":"/vəˈkæbjəleri/","parts":[{"type":"root","text":"vocab","meaning":"부르다 (call)"},{"type":"suffix","text":"-ary","meaning":"모음"}],"story":"사물을 '부르는(voc)' 이름(단어)들의 모음집 → 어휘.","example":{"en":"Improve your vocabulary.","ko":"어휘력을 기르다."}},
  {"word":"provoke","level":"high","meaning":"도발하다","pronunciation":"/prəˈvoʊk/","parts":[{"type":"prefix","text":"pro-","meaning":"앞으로 (forward)"},{"type":"root","text":"vok","meaning":"부르다 (call)"}],"story":"상대방을 내 '앞으로(pro)' 나오라고 '불러내다(vok)' → 도발하다.","example":{"en":"Don't provoke him.","ko":"그를 도발하지 마."}},
  {"word":"evoke","level":"high","meaning":"일깨우다","pronunciation":"/ɪˈvoʊk/","parts":[{"type":"prefix","text":"e-","meaning":"밖으로 (out)"},{"type":"root","text":"vok","meaning":"부르다 (call)"}],"story":"기억이나 감정을 '밖으로(e)' '불러내다(vok)' → 일깨우다.","example":{"en":"Evoke memories.","ko":"기억을 일깨우다."}},
  {"word":"advocate","level":"high","meaning":"옹호하다","pronunciation":"/ˈædvəkət/","parts":[{"type":"prefix","text":"ad-","meaning":"~를 향해 (toward)"},{"type":"root","text":"voc","meaning":"부르다 (call)"}],"story":"위기에 처한 사람 '쪽으로(ad)' 가서 목소리를 내어 '불러주다(voc)' → 옹호하다.","example":{"en":"Advocate for human rights.","ko":"인권을 옹호하다."}},
  {"word":"spirit","level":"middle","meaning":"정신, 영혼","pronunciation":"/ˈspɪrɪt/","parts":[{"type":"root","text":"spir","meaning":"숨쉬다 (breathe)"},{"type":"suffix","text":"-it","meaning":"명사형"}],"story":"생명의 근원인 '숨(spir)'결 → 생명력, 영혼, 정신.","example":{"en":"Team spirit.","ko":"팀 정신(단결력)."}},
  {"word":"inspire","level":"middle","meaning":"영감을 주다","pronunciation":"/ɪnˈspaɪər/","parts":[{"type":"prefix","text":"in-","meaning":"안으로 (into)"},{"type":"root","text":"spir","meaning":"숨쉬다 (breathe)"}],"story":"사람의 마음 '속에(in)' 새로운 열정의 숨결을 '불어넣다(spir)' → 영감을 주다.","example":{"en":"The book inspired me.","ko":"그 책은 내게 영감을 주었다."}},
  {"word":"expire","level":"high","meaning":"만료되다","pronunciation":"/ɪkˈspaɪər/","parts":[{"type":"prefix","text":"ex-","meaning":"밖으로 (out)"},{"type":"root","text":"spir","meaning":"숨쉬다 (breathe)"}],"story":"마지막 숨을 '밖으로(ex)' '내쉬다(spir)' → 기한이 끝나다.","example":{"en":"My passport expires soon.","ko":"내 여권이 곧 만료된다."}},
  {"word":"aspire","level":"high","meaning":"열망하다","pronunciation":"/əˈspaɪər/","parts":[{"type":"prefix","text":"a-","meaning":"~를 향해 (toward)"},{"type":"root","text":"spir","meaning":"숨쉬다 (breathe)"}],"story":"목표를 '향해(a)' 거칠게 숨을 '몰아쉬며(spir)' 달려가다 → 열망하다.","example":{"en":"Aspire to be a doctor.","ko":"의사가 되기를 열망하다."}},
  {"word":"perspire","level":"high","meaning":"땀을 흘리다","pronunciation":"/pərˈspaɪər/","parts":[{"type":"prefix","text":"per-","meaning":"통과하여 (through)"},{"type":"root","text":"spir","meaning":"숨쉬다 (breathe)"}],"story":"피부 구멍을 '통과하여(per)' 수분이 숨을 '쉬듯(spir)' 나오다 → 땀 흘리다.","example":{"en":"He was perspiring heavily.","ko":"그는 땀을 뻘뻘 흘리고 있었다."}},
  {"word":"nation","level":"middle","meaning":"국가, 민족","pronunciation":"/ˈneɪʃn/","parts":[{"type":"root","text":"nat","meaning":"태어나다 (born)"},{"type":"suffix","text":"-ion","meaning":"집단"}],"story":"같은 혈통을 가지고 '태어난(nat)' 사람들의 무리 → 민족, 국가.","example":{"en":"An independent nation.","ko":"독립 국가."}},
  {"word":"native","level":"middle","meaning":"원주민의","pronunciation":"/ˈneɪtɪv/","parts":[{"type":"root","text":"nat","meaning":"태어나다 (born)"},{"type":"suffix","text":"-ive","meaning":"형용사형"}],"story":"그 지역에서 '태어난(nat)' → 토착의, 원주민의.","example":{"en":"Native speaker.","ko":"원어민."}},
  {"word":"nature","level":"middle","meaning":"자연, 본성","pronunciation":"/ˈneɪtʃər/","parts":[{"type":"root","text":"nat","meaning":"태어나다 (born)"},{"type":"suffix","text":"-ure","meaning":"상태"}],"story":"인공적이지 않고 '태어난(nat)' 그대로의 상태 → 자연, 타고난 본성.","example":{"en":"It is human nature.","ko":"그것이 인간의 본성이다."}},
  {"word":"innate","level":"high","meaning":"선천적인","pronunciation":"/ɪˈneɪt/","parts":[{"type":"prefix","text":"in-","meaning":"안에 (in)"},{"type":"root","text":"nat","meaning":"태어난 (born)"}],"story":"'태어날(nat)' 때부터 몸 '안에(in)' 지니고 있는 → 선천적인.","example":{"en":"Innate ability.","ko":"타고난 능력."}},
  {"word":"natural","level":"middle","meaning":"자연의, 당연한","pronunciation":"/ˈnætʃrəl/","parts":[{"type":"root","text":"natur","meaning":"자연"},{"type":"suffix","text":"-al","meaning":"형용사형"}],"story":"자연적인 이치에 맞는 → 당연한, 자연스러운.","example":{"en":"It is natural to feel sad.","ko":"슬픈 것은 당연하다."}},
  {"word":"finish","level":"middle","meaning":"끝내다","pronunciation":"/ˈfɪnɪʃ/","parts":[{"type":"root","text":"fin","meaning":"끝 (end)"},{"type":"suffix","text":"-ish","meaning":"동사형"}],"story":"어떤 일의 '끝(fin)'을 내다 → 끝마치다.","example":{"en":"Finish your homework.","ko":"숙제를 끝내라."}},
  {"word":"final","level":"middle","meaning":"마지막의","pronunciation":"/ˈfaɪnl/","parts":[{"type":"root","text":"fin","meaning":"끝 (end)"},{"type":"suffix","text":"-al","meaning":"형용사형"}],"story":"가장 '끝(fin)'에 있는 → 마지막의.","example":{"en":"The final game.","ko":"결승전."}},
  {"word":"fine","level":"middle","meaning":"훌륭한, 벌금","pronunciation":"/faɪn/","parts":[{"type":"root","text":"fin","meaning":"끝, 완성 (end)"}],"story":"(끝까지 다듬어) 훌륭한. 또는 사건을 끝내기 위해 내는 돈=벌금.","example":{"en":"Pay a fine.","ko":"벌금을 내다."}},
  {"word":"define","level":"high","meaning":"정의하다","pronunciation":"/dɪˈfaɪn/","parts":[{"type":"prefix","text":"de-","meaning":"완전히 (down)"},{"type":"root","text":"fin","meaning":"경계 (limit)"}],"story":"개념의 '경계(fin)'를 '확실히(de)' 긋다 → 뜻을 정의하다.","example":{"en":"Define the word.","ko":"단어를 정의하다."}},
  {"word":"infinite","level":"high","meaning":"무한한","pronunciation":"/ˈɪnfɪnət/","parts":[{"type":"prefix","text":"in-","meaning":"없는 (not)"},{"type":"root","text":"fin","meaning":"끝 (end)"}],"story":"'끝(fin)'이 '없는(in)' → 무한한.","example":{"en":"Infinite space.","ko":"무한한 공간."}},
  {"word":"sign","level":"middle","meaning":"신호, 서명하다","pronunciation":"/saɪn/","parts":[{"type":"root","text":"sign","meaning":"표시 (mark)"}],"story":"남들이 알 수 있게 '표시(sign)'하는 것 → 신호, 서명.","example":{"en":"A stop sign.","ko":"정지 표지판."}},
  {"word":"signal","level":"middle","meaning":"신호(를 보내다)","pronunciation":"/ˈsɪɡnəl/","parts":[{"type":"root","text":"sign","meaning":"표시 (mark)"},{"type":"suffix","text":"-al","meaning":"명사형"}],"story":"빛이나 소리로 '표시(sign)'를 보내는 것 → 신호.","example":{"en":"Traffic signals.","ko":"교통 신호등."}},
  {"word":"design","level":"middle","meaning":"설계하다","pronunciation":"/dɪˈzaɪn/","parts":[{"type":"prefix","text":"de-","meaning":"아래로 (down)"},{"type":"root","text":"sign","meaning":"표시하다 (mark)"}],"story":"종이 '아래에(de)' 구상을 '그려 넣다(sign)' → 설계하다.","example":{"en":"Design a website.","ko":"웹사이트를 디자인하다."}},
  {"word":"assign","level":"high","meaning":"할당하다","pronunciation":"/əˈsaɪn/","parts":[{"type":"prefix","text":"as-","meaning":"~에게 (to)"},{"type":"root","text":"sign","meaning":"표시하다 (mark)"}],"story":"누군가'에게(as)' 할 일을 '표시해(sign)' 주다 → 할당하다.","example":{"en":"Assign homework.","ko":"숙제를 내주다."}},
  {"word":"resign","level":"high","meaning":"사임하다","pronunciation":"/rɪˈzaɪn/","parts":[{"type":"prefix","text":"re-","meaning":"뒤로 (back)"},{"type":"root","text":"sign","meaning":"서명하다 (mark)"}],"story":"계약서에 '서명(sign)'을 취소하고 '물러나겠다(re)'고 하다.","example":{"en":"He resigned from his job.","ko":"그는 직장에서 사임했다."}},
  {"word":"press","level":"middle","meaning":"누르다, 언론","pronunciation":"/pres/","parts":[{"type":"root","text":"press","meaning":"누르다 (press)"}],"story":"종이를 '눌러서' 인쇄하는 기계 → 신문, 언론.","example":{"en":"Press the button.","ko":"버튼을 누르세요."}},
  {"word":"pressure","level":"middle","meaning":"압력","pronunciation":"/ˈpreʃər/","parts":[{"type":"root","text":"press","meaning":"누르다 (press)"},{"type":"suffix","text":"-ure","meaning":"명사형"}],"story":"물리적으로 '누르는(press)' 힘 → 압력.","example":{"en":"Blood pressure.","ko":"혈압."}},
  {"word":"express","level":"middle","meaning":"표현하다","pronunciation":"/ɪkˈspres/","parts":[{"type":"prefix","text":"ex-","meaning":"밖으로 (out)"},{"type":"root","text":"press","meaning":"누르다 (press)"}],"story":"마음속 생각을 '밖으로(ex)' '밀어내다(press)' → 표현하다.","example":{"en":"Express your feelings.","ko":"감정을 표현해라."}},
  {"word":"impress","level":"high","meaning":"감동을 주다","pronunciation":"/ɪmˈpres/","parts":[{"type":"prefix","text":"im-","meaning":"안에 (in)"},{"type":"root","text":"press","meaning":"누르다 (press)"}],"story":"누군가의 마음 '속에(im)' 강한 도장을 꾹 '찍다(press)' → 감동을 주다.","example":{"en":"I was impressed.","ko":"나는 깊은 인상을 받았다."}},
  {"word":"depress","level":"high","meaning":"우울하게 하다","pronunciation":"/dɪˈpres/","parts":[{"type":"prefix","text":"de-","meaning":"아래로 (down)"},{"type":"root","text":"press","meaning":"누르다 (press)"}],"story":"기분을 '아래로(de)' '짓누르다(press)' → 우울하게 하다.","example":{"en":"The news depressed him.","ko":"그 뉴스는 그를 우울하게 했다."}},
  {"word":"stand","level":"middle","meaning":"서다, 참다","pronunciation":"/stænd/","parts":[{"type":"root","text":"stand","meaning":"서다 (stand)"}],"story":"힘든 상황에서도 꼿꼿이 '서서' 버티다 → 참다.","example":{"en":"I can't stand the noise.","ko":"나는 그 소음을 참을 수 없다."}},
  {"word":"station","level":"middle","meaning":"역, 정거장","pronunciation":"/ˈsteɪʃn/","parts":[{"type":"root","text":"sta","meaning":"서다 (stand)"},{"type":"suffix","text":"-tion","meaning":"장소"}],"story":"기차나 버스가 '서있는(sta)' 장소 → 정거장.","example":{"en":"Subway station.","ko":"지하철역."}},
  {"word":"status","level":"high","meaning":"지위, 상태","pronunciation":"/ˈsteɪtəs/","parts":[{"type":"root","text":"sta","meaning":"서다 (stand)"},{"type":"suffix","text":"-tus","meaning":"명사형"}],"story":"사회가 한 사람을 어떻게 '서 있게(sta)' 대우하는가 → 사회적 지위.","example":{"en":"Social status.","ko":"사회적 지위."}},
  {"word":"constant","level":"high","meaning":"끊임없는","pronunciation":"/ˈkɑːnstənt/","parts":[{"type":"prefix","text":"con-","meaning":"함께, 똑같이"},{"type":"root","text":"sta","meaning":"서다 (stand)"}],"story":"변함없이 '똑같은(con)' 자리에 계속 '서 있는(sta)' → 끊임없는.","example":{"en":"A constant speed.","ko":"일정한 속도."}},
  {"word":"distance","level":"middle","meaning":"거리","pronunciation":"/ˈdɪstəns/","parts":[{"type":"prefix","text":"dis-","meaning":"떨어져서 (apart)"},{"type":"root","text":"sta","meaning":"서다 (stand)"}],"story":"서로 '떨어져서(dis)' '서 있는(sta)' 공간 → 거리.","example":{"en":"Walk a short distance.","ko":"짧은 거리를 걷다."}},
  {"word":"tend","level":"middle","meaning":"~하는 경향이 있다","pronunciation":"/tend/","parts":[{"type":"root","text":"tend","meaning":"뻗다 (stretch)"}],"story":"마음이나 행동이 한쪽으로만 '뻗어간다(tend)' → 경향.","example":{"en":"I tend to wake up early.","ko":"나는 일찍 일어나는 경향이 있다."}},
  {"word":"attend","level":"middle","meaning":"참석하다","pronunciation":"/əˈtend/","parts":[{"type":"prefix","text":"at-","meaning":"~에 (to)"},{"type":"root","text":"tend","meaning":"뻗다 (stretch)"}],"story":"어떤 행사장 '쪽으로(at)' 몸을 '뻗어' 가다 → 참석하다.","example":{"en":"Attend a meeting.","ko":"회의에 참석하다."}},
  {"word":"extend","level":"high","meaning":"연장하다","pronunciation":"/ɪkˈstend/","parts":[{"type":"prefix","text":"ex-","meaning":"밖으로 (out)"},{"type":"root","text":"tend","meaning":"뻗다 (stretch)"}],"story":"길이나 크기를 한계 '밖으로(ex)' 쭈욱 '뻗다(tend)' → 연장하다.","example":{"en":"Extend the deadline.","ko":"마감일을 연장하다."}},
  {"word":"intend","level":"high","meaning":"의도하다","pronunciation":"/ɪnˈtend/","parts":[{"type":"prefix","text":"in-","meaning":"안으로 (into)"},{"type":"root","text":"tend","meaning":"뻗다 (stretch)"}],"story":"마음 '속에서(in)' 하려고 생각을 '뻗다(tend)' → 의도하다.","example":{"en":"I didn't intend to hurt you.","ko":"상처 줄 의도는 없었다."}},
  {"word":"tension","level":"high","meaning":"긴장","pronunciation":"/ˈtenʃn/","parts":[{"type":"root","text":"tens","meaning":"뻗다 (stretch)"},{"type":"suffix","text":"-ion","meaning":"명사형"}],"story":"줄이나 마음이 양쪽으로 강하게 '뻗어(tens)' 당겨진 상태 → 긴장.","example":{"en":"Muscle tension.","ko":"근육 긴장."}},
  {"word":"educate","level":"middle","meaning":"교육하다","pronunciation":"/ˈedʒukeɪt/","parts":[{"type":"prefix","text":"e-","meaning":"밖으로 (out)"},{"type":"root","text":"duc","meaning":"이끌다 (lead)"}],"story":"잠재력을 '밖으로(e)' '이끌어내다(duc)' → 교육하다.","example":{"en":"Educate children.","ko":"아이들을 교육하다."}},
  {"word":"produce","level":"middle","meaning":"생산하다","pronunciation":"/prəˈduːs/","parts":[{"type":"prefix","text":"pro-","meaning":"앞으로 (forward)"},{"type":"root","text":"duc","meaning":"이끌다 (lead)"}],"story":"결과물을 '앞으로(pro)' '끌어내다(duc)' → 생산하다.","example":{"en":"Produce goods.","ko":"상품을 생산하다."}},
  {"word":"reduce","level":"middle","meaning":"줄이다","pronunciation":"/rɪˈduːs/","parts":[{"type":"prefix","text":"re-","meaning":"뒤로 (back)"},{"type":"root","text":"duc","meaning":"이끌다 (lead)"}],"story":"크기나 양을 '뒤로(re)' '끌어내리다(duc)' → 줄이다.","example":{"en":"Reduce pollution.","ko":"오염을 줄이다."}},
  {"word":"introduce","level":"middle","meaning":"소개하다","pronunciation":"/ˌɪntrəˈduːs/","parts":[{"type":"prefix","text":"intro-","meaning":"안으로 (into)"},{"type":"root","text":"duc","meaning":"이끌다 (lead)"}],"story":"새로운 사람이나 지식을 우리 '안으로(intro)' '이끌고 오다(duc)' → 소개하다.","example":{"en":"Introduce a new system.","ko":"새 시스템을 도입하다."}},
  {"word":"conduct","level":"high","meaning":"수행하다, 지휘하다","pronunciation":"/kənˈdʌkt/","parts":[{"type":"prefix","text":"con-","meaning":"함께 (together)"},{"type":"root","text":"duct","meaning":"이끌다 (lead)"}],"story":"프로젝트를 '함께(con)' '이끌어가다(duct)' → 지휘하다.","example":{"en":"Conduct an experiment.","ko":"실험을 수행하다."}},
  {"word":"generate","level":"middle","meaning":"발생시키다","pronunciation":"/ˈdʒenəreɪt/","parts":[{"type":"root","text":"gen","meaning":"발생하다 (birth)"},{"type":"suffix","text":"-ate","meaning":"동사형"}],"story":"새로운 것을 '태어나게(gen)' 하다 → 발생시키다.","example":{"en":"Generate electricity.","ko":"전기를 발생시키다."}},
  {"word":"general","level":"middle","meaning":"일반적인","pronunciation":"/ˈdʒenərəl/","parts":[{"type":"root","text":"gen","meaning":"부류 (kind)"},{"type":"suffix","text":"-al","meaning":"형용사형"}],"story":"특정 집단이나 '종류(gen)' 전체에 고루 해당하는 → 일반적인.","example":{"en":"A general rule.","ko":"일반적인 규칙."}},
  {"word":"generous","level":"middle","meaning":"관대한","pronunciation":"/ˈdʒenərəs/","parts":[{"type":"root","text":"gen","meaning":"태생 (birth)"},{"type":"suffix","text":"-ous","meaning":"형용사형"}],"story":"훌륭한 '태생(gen)'에서 나와 베풀 줄 아는 → 관대한.","example":{"en":"A generous person.","ko":"관대한 사람."}},
  {"word":"genius","level":"middle","meaning":"천재","pronunciation":"/ˈdʒiːniəs/","parts":[{"type":"root","text":"gen","meaning":"태어나다 (birth)"}],"story":"'태어날(gen)' 때부터 신이 부여한 특별한 재능 → 천재.","example":{"en":"He is a musical genius.","ko":"그는 음악 천재다."}},
  {"word":"genuine","level":"high","meaning":"진짜의","pronunciation":"/ˈdʒenjuɪn/","parts":[{"type":"root","text":"gen","meaning":"태어나다 (birth)"}],"story":"'태어난(gen)' 그대로 거짓이 없는 → 진짜의.","example":{"en":"Genuine leather.","ko":"진짜 가죽."}},
  {"word":"move","level":"middle","meaning":"움직이다","pronunciation":"/muːv/","parts":[{"type":"root","text":"mov","meaning":"움직이다 (move)"}],"story":"물리적으로 '움직이거나', 마음을 '움직여' 감동시키다.","example":{"en":"The movie moved me to tears.","ko":"그 영화는 나를 눈물 흘리게 감동시켰다."}},
  {"word":"motion","level":"middle","meaning":"움직임","pronunciation":"/ˈmoʊʃn/","parts":[{"type":"root","text":"mot","meaning":"움직이다 (move)"},{"type":"suffix","text":"-ion","meaning":"명사형"}],"story":"'움직이는(mot)' 상태 → 동작, 움직임.","example":{"en":"Slow motion.","ko":"느린 동작."}},
  {"word":"motive","level":"middle","meaning":"동기","pronunciation":"/ˈmoʊtɪv/","parts":[{"type":"root","text":"mot","meaning":"움직이다 (move)"},{"type":"suffix","text":"-ive","meaning":"명사형"}],"story":"사람의 마음을 '움직이게(mot)' 만드는 원인 → 동기.","example":{"en":"The motive for the crime.","ko":"범죄의 동기."}},
  {"word":"promote","level":"high","meaning":"촉진하다, 승진시키다","pronunciation":"/prəˈmoʊt/","parts":[{"type":"prefix","text":"pro-","meaning":"앞으로 (forward)"},{"type":"root","text":"mot","meaning":"움직이다 (move)"}],"story":"지위를 '앞으로(pro)' '이동시키다(mot)' → 승진시키다.","example":{"en":"Promote health.","ko":"건강을 증진하다."}},
  {"word":"remote","level":"middle","meaning":"멀리 떨어진","pronunciation":"/rɪˈmoʊt/","parts":[{"type":"prefix","text":"re-","meaning":"뒤로 (back)"},{"type":"root","text":"mot","meaning":"움직이다 (move)"}],"story":"중심지에서 '뒤로(re)' 한참 '이동한(mot)' 곳에 있는 → 외딴.","example":{"en":"A remote island.","ko":"외딴 섬."}},
  {"word":"sense","level":"middle","meaning":"감각, 느낌","pronunciation":"/sens/","parts":[{"type":"root","text":"sens","meaning":"느끼다 (feel)"}],"story":"몸이나 마음으로 '느끼는(sens)' 것 → 감각.","example":{"en":"A sense of humor.","ko":"유머 감각."}},
  {"word":"sensitive","level":"middle","meaning":"민감한","pronunciation":"/ˈsensətɪv/","parts":[{"type":"root","text":"sens","meaning":"느끼다 (feel)"},{"type":"suffix","text":"-itive","meaning":"형용사형"}],"story":"작은 자극도 예민하게 잘 '느끼는(sens)' → 민감한.","example":{"en":"Sensitive skin.","ko":"민감한 피부."}},
  {"word":"sensible","level":"high","meaning":"분별 있는","pronunciation":"/ˈsensəbl/","parts":[{"type":"root","text":"sens","meaning":"느끼다 (feel)"},{"type":"suffix","text":"-ible","meaning":"할 수 있는"}],"story":"상황을 올바르게 '느끼고(sens)' 판단할 수 있는 → 분별 있는.","example":{"en":"A sensible decision.","ko":"합리적인 결정."}},
  {"word":"consent","level":"high","meaning":"동의하다","pronunciation":"/kənˈsent/","parts":[{"type":"prefix","text":"con-","meaning":"함께 (together)"},{"type":"root","text":"sent","meaning":"느끼다 (feel)"}],"story":"상대방과 '함께(con)' 같은 마음을 '느끼다(sent)' → 동의하다.","example":{"en":"Parental consent.","ko":"부모의 동의."}},
  {"word":"resent","level":"high","meaning":"분개하다","pronunciation":"/rɪˈzent/","parts":[{"type":"prefix","text":"re-","meaning":"반대로 (back)"},{"type":"root","text":"sent","meaning":"느끼다 (feel)"}],"story":"마음속에 '반대되는(re)' 나쁜 감정을 '느끼다(sent)' → 분개하다.","example":{"en":"I resent his remarks.","ko":"나는 그의 발언에 분개한다."}},
  {"word":"proceed","level":"middle","meaning":"진행하다","pronunciation":"/proʊˈsiːd/","parts":[{"type":"prefix","text":"pro-","meaning":"앞으로 (forward)"},{"type":"root","text":"ceed","meaning":"가다 (go)"}],"story":"'앞으로(pro)' 계속 나아'가다(ceed)' → 진행하다.","example":{"en":"Proceed to the next step.","ko":"다음 단계로 진행하세요."}},
  {"word":"succeed","level":"middle","meaning":"성공하다, 뒤를 잇다","pronunciation":"/səkˈsiːd/","parts":[{"type":"prefix","text":"suc-","meaning":"아래에, 뒤에 (sub)"},{"type":"root","text":"ceed","meaning":"가다 (go)"}],"story":"어려움 '아래(sub)'에서 올라오거나, 이전 사람 '뒤를 이어(sub)' '가다(ceed)' → 성공하다.","example":{"en":"He succeeded in business.","ko":"그는 사업에 성공했다."}},
  {"word":"exceed","level":"high","meaning":"초과하다","pronunciation":"/ɪkˈsiːd/","parts":[{"type":"prefix","text":"ex-","meaning":"넘어서 (out)"},{"type":"root","text":"ceed","meaning":"가다 (go)"}],"story":"정해진 한계를 '넘어서(ex)' '가버리다(ceed)' → 초과하다.","example":{"en":"Exceed the speed limit.","ko":"제한 속도를 초과하다."}},
  {"word":"access","level":"middle","meaning":"접근","pronunciation":"/ˈækses/","parts":[{"type":"prefix","text":"ac-","meaning":"~에 (to)"},{"type":"root","text":"cess","meaning":"가다 (go)"}],"story":"어떤 곳을 향해 가까이 '가다(cess)' → 접근.","example":{"en":"Access to the internet.","ko":"인터넷 접속."}},
  {"word":"recede","level":"high","meaning":"물러나다","pronunciation":"/rɪˈsiːd/","parts":[{"type":"prefix","text":"re-","meaning":"뒤로 (back)"},{"type":"root","text":"cede","meaning":"가다 (go)"}],"story":"파도나 머리카락이 '뒤로(re)' 물러나 '가다(cede)' → 물러나다.","example":{"en":"The flood waters receded.","ko":"홍수 물이 빠졌다."}},
  {"word":"fluent","level":"middle","meaning":"유창한","pronunciation":"/ˈfluːənt/","parts":[{"type":"root","text":"flu","meaning":"흐르다 (flow)"},{"type":"suffix","text":"-ent","meaning":"형용사형"}],"story":"말이 물 '흐르듯이(flu)' 자연스럽게 나오는 → 유창한.","example":{"en":"He is fluent in English.","ko":"그는 영어가 유창하다."}},
  {"word":"fluid","level":"high","meaning":"액체, 유동적인","pronunciation":"/ˈfluːɪd/","parts":[{"type":"root","text":"flu","meaning":"흐르다 (flow)"},{"type":"suffix","text":"-id","meaning":"명사형"}],"story":"형태가 고정되지 않고 물처럼 '흐르는(flu)' 것 → 액체, 유동적인.","example":{"en":"Drink plenty of fluids.","ko":"액체를 많이 마셔라."}},
  {"word":"influence","level":"middle","meaning":"영향을 미치다","pronunciation":"/ˈɪnfluəns/","parts":[{"type":"prefix","text":"in-","meaning":"안으로 (into)"},{"type":"root","text":"flu","meaning":"흐르다 (flow)"}],"story":"어떤 힘이나 생각이 남의 마음 '안으로(in)' '흘러(flu)' 들어가다 → 영향을 미치다.","example":{"en":"He has a good influence on me.","ko":"그는 내게 좋은 영향을 미친다."}},
  {"word":"flu","level":"middle","meaning":"독감","pronunciation":"/fluː/","parts":[{"type":"root","text":"flu","meaning":"흐르다 (flow)"}],"story":"과거에 별의 기운이 사람에게 '흘러들어와(flu)' 병이 생긴다고 믿은 데서 유래.","example":{"en":"Catch the flu.","ko":"독감에 걸리다."}},
  {"word":"flush","level":"high","meaning":"물을 내리다, 붉어지다","pronunciation":"/flʌʃ/","parts":[{"type":"root","text":"flu","meaning":"흐르다 (flow)"},{"type":"suffix","text":"-sh","meaning":"동사형"}],"story":"변기에 물이 확 '흐르게(flu)' 하다, 피가 얼굴로 확 흘러 붉어지다.","example":{"en":"Flush the toilet.","ko":"변기 물을 내리다."}},
  {"word":"complete","level":"middle","meaning":"완료하다, 완전한","pronunciation":"/kəmˈpliːt/","parts":[{"type":"prefix","text":"com-","meaning":"완전히 (completely)"},{"type":"root","text":"plet","meaning":"채우다 (fill)"}],"story":"부족한 부분 없이 '완전히(com)' 꽉 '채우다(plet)' → 완료하다, 완전한.","example":{"en":"Complete the form.","ko":"양식을 완성하세요."}},
  {"word":"deplete","level":"high","meaning":"고갈시키다","pronunciation":"/dɪˈpliːt/","parts":[{"type":"prefix","text":"de-","meaning":"빼내다 (down)"},{"type":"root","text":"plet","meaning":"채우다 (fill)"}],"story":"'채워져(plet)' 있던 것을 반대로 '다 빼내다(de)' → 고갈시키다.","example":{"en":"Deplete natural resources.","ko":"천연자원을 고갈시키다."}},
  {"word":"supplement","level":"high","meaning":"보충하다, 영양제","pronunciation":"/ˈsʌplɪmənt/","parts":[{"type":"prefix","text":"sup-","meaning":"아래에서 (under)"},{"type":"root","text":"ple","meaning":"채우다 (fill)"}],"story":"부족한 것을 '아래에서부터(sup)' 꽉꽉 '채워 넣다(ple)' → 보충하다.","example":{"en":"Vitamin supplements.","ko":"비타민 보충제."}},
  {"word":"plenty","level":"middle","meaning":"풍부함","pronunciation":"/ˈplenti/","parts":[{"type":"root","text":"plen","meaning":"가득 찬 (full)"},{"type":"suffix","text":"-ty","meaning":"명사형"}],"story":"창고에 물건이 꽉 '채워져(ple)' 있는 상태 → 풍부함.","example":{"en":"We have plenty of time.","ko":"우리는 시간이 많다."}},
  {"word":"implement","level":"high","meaning":"실행하다, 도구","pronunciation":"/ˈɪmplɪment/","parts":[{"type":"prefix","text":"im-","meaning":"안에 (in)"},{"type":"root","text":"ple","meaning":"채우다 (fill)"}],"story":"계획의 빈 곳을 '채워서(ple)' 현실 '속으로(im)' 가져오다 → 실행하다.","example":{"en":"Implement a new policy.","ko":"새 정책을 실행하다."}},
  {"word":"position","level":"middle","meaning":"위치, 입장","pronunciation":"/pəˈzɪʃn/","parts":[{"type":"root","text":"pos","meaning":"놓다 (place)"},{"type":"suffix","text":"-ition","meaning":"명사형"}],"story":"사물이나 사람이 '놓여(pos)' 있는 곳 → 위치.","example":{"en":"A high position.","ko":"높은 지위."}},
  {"word":"compose","level":"middle","meaning":"구성하다, 작곡하다","pronunciation":"/kəmˈpoʊz/","parts":[{"type":"prefix","text":"com-","meaning":"함께 (together)"},{"type":"root","text":"pos","meaning":"놓다 (put)"}],"story":"여러 부분이나 음표를 '함께(com)' 제자리에 '놓다(pos)' → 구성하다, 작곡하다.","example":{"en":"Compose a song.","ko":"노래를 작곡하다."}},
  {"word":"oppose","level":"middle","meaning":"반대하다","pronunciation":"/əˈpoʊz/","parts":[{"type":"prefix","text":"op-","meaning":"~에 맞서 (against)"},{"type":"root","text":"pos","meaning":"놓다 (put)"}],"story":"상대방의 의견에 '맞서서(op)' 내 의견을 떡하니 '놓다(pos)' → 반대하다.","example":{"en":"Oppose the plan.","ko":"계획에 반대하다."}},
  {"word":"propose","level":"middle","meaning":"제안하다, 청혼하다","pronunciation":"/prəˈpoʊz/","parts":[{"type":"prefix","text":"pro-","meaning":"앞으로 (forward)"},{"type":"root","text":"pos","meaning":"놓다 (put)"}],"story":"내 아이디어나 마음을 사람들 '앞에(pro)' '내놓다(pos)' → 제안하다, 청혼하다.","example":{"en":"Propose a solution.","ko":"해결책을 제안하다."}},
  {"word":"suppose","level":"middle","meaning":"가정하다, 추측하다","pronunciation":"/səˈpoʊz/","parts":[{"type":"prefix","text":"sup-","meaning":"아래에 (under)"},{"type":"root","text":"pos","meaning":"놓다 (put)"}],"story":"결론을 내리기 전에 마음 '아래에(sup)' 잠시 생각을 '내려놓다(pos)' → 가정해보다.","example":{"en":"I suppose you are right.","ko":"네 말이 맞을 거라 추측해."}},
  {"word":"describe","level":"middle","meaning":"묘사하다","pronunciation":"/dɪˈskraɪb/","parts":[{"type":"prefix","text":"de-","meaning":"아래로 (down)"},{"type":"root","text":"scrib","meaning":"쓰다 (write)"}],"story":"본 것을 종이 '아래로(de)' 자세히 '써내려가다(scrib)' → 묘사하다.","example":{"en":"Describe the suspect.","ko":"용의자를 묘사하다."}},
  {"word":"prescribe","level":"high","meaning":"처방하다","pronunciation":"/prɪˈskraɪb/","parts":[{"type":"prefix","text":"pre-","meaning":"미리 (before)"},{"type":"root","text":"scrib","meaning":"쓰다 (write)"}],"story":"환자가 약국에 가기 전에 의사가 '미리(pre)' 약 이름을 '써주다(scrib)' → 처방하다.","example":{"en":"Prescribe antibiotics.","ko":"항생제를 처방하다."}},
  {"word":"subscribe","level":"middle","meaning":"구독하다, 가입하다","pronunciation":"/səbˈskraɪb/","parts":[{"type":"prefix","text":"sub-","meaning":"아래에 (under)"},{"type":"root","text":"scrib","meaning":"쓰다 (write)"}],"story":"잡지를 받기 위해 계약서 '아래에(sub)' 내 이름을 '쓰다(scrib)' → 구독하다.","example":{"en":"Subscribe to a channel.","ko":"채널을 구독하다."}},
  {"word":"script","level":"middle","meaning":"대본, 원고","pronunciation":"/skrɪpt/","parts":[{"type":"root","text":"script","meaning":"쓰다 (write)"}],"story":"배우들이 읽도록 '쓰인(script)' 것 → 대본.","example":{"en":"Read the script.","ko":"대본을 읽다."}},
  {"word":"scribble","level":"high","meaning":"갈겨쓰다, 낙서하다","pronunciation":"/ˈskrɪbl/","parts":[{"type":"root","text":"scrib","meaning":"쓰다 (write)"},{"type":"suffix","text":"-le","meaning":"반복"}],"story":"종이 위에 계속해서 의미 없이 '쓰다(scrib)' → 낙서하다.","example":{"en":"Scribble on a paper.","ko":"종이에 낙서하다."}},
  {"word":"advent","level":"high","meaning":"도래, 출현","pronunciation":"/ˈædvent/","parts":[{"type":"prefix","text":"ad-","meaning":"~를 향해 (toward)"},{"type":"root","text":"vent","meaning":"오다 (come)"}],"story":"새로운 시대나 기술이 우리를 '향해(ad)' '다가옴(vent)' → 출현, 도래.","example":{"en":"The advent of the internet.","ko":"인터넷의 도래."}},
  {"word":"invent","level":"middle","meaning":"발명하다","pronunciation":"/ɪnˈvent/","parts":[{"type":"prefix","text":"in-","meaning":"위로 (up)"},{"type":"root","text":"vent","meaning":"오다 (come)"}],"story":"없던 아이디어가 머릿속에 '탁 하고 떠올라 오다(vent)' → 발명하다.","example":{"en":"Invent a new machine.","ko":"새 기계를 발명하다."}},
  {"word":"prevent","level":"middle","meaning":"예방하다, 막다","pronunciation":"/prɪˈvent/","parts":[{"type":"prefix","text":"pre-","meaning":"미리 (before)"},{"type":"root","text":"vent","meaning":"오다 (come)"}],"story":"나쁜 일이 '오기(vent)' 전에 '미리(pre)' 손을 쓰다 → 예방하다.","example":{"en":"Prevent disease.","ko":"질병을 예방하다."}},
  {"word":"convention","level":"high","meaning":"회의, 관습","pronunciation":"/kənˈvenʃn/","parts":[{"type":"prefix","text":"con-","meaning":"함께 (together)"},{"type":"root","text":"vent","meaning":"오다 (come)"}],"story":"사람들이 '함께(con)' '모여드는(vent)' 것 → 회의. 옛날부터 함께 오던 방식 → 관습.","example":{"en":"A medical convention.","ko":"의학 총회."}},
  {"word":"intervene","level":"high","meaning":"개입하다","pronunciation":"/ˌɪntərˈviːn/","parts":[{"type":"prefix","text":"inter-","meaning":"사이에 (between)"},{"type":"root","text":"vene","meaning":"오다 (come)"}],"story":"싸우는 두 사람 '사이로(inter)' 내가 '걸어 들어가다(vene)' → 개입하다.","example":{"en":"Intervene in a dispute.","ko":"분쟁에 개입하다."}}
]